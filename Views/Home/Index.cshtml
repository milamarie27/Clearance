@{
    ViewData["Title"] = "Welcome";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>CTUG Online Clearance</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
            background: #0d1f17;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .landing-frame {
            width: 100%;
            height: 100vh;
            background: linear-gradient(145deg, #1a4731 0%, #12301f 60%, #0d2118 100%);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            position: relative;
        }

        /* Decorative background circles */
        .landing-frame::before {
            content: '';
            position: absolute;
            width: 600px; height: 600px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(201,168,76,0.07) 0%, transparent 70%);
            top: -150px; right: -150px;
            pointer-events: none;
        }
        .landing-frame::after {
            content: '';
            position: absolute;
            width: 400px; height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(201,168,76,0.05) 0%, transparent 70%);
            bottom: -100px; left: -100px;
            pointer-events: none;
        }

        /* Top nav */
        .top-nav {
            display: flex; align-items: center;
            justify-content: space-between;
            padding: 22px 36px 0;
            position: relative; z-index: 1;
        }
        .brand-dot {
            display: flex; align-items: center; gap: 10px;
            color: white; font-weight: 700; font-size: 14px;
            letter-spacing: 0.3px;
        }
        .brand-dot::before {
            content: '';
            width: 9px; height: 9px;
            background: #c9a84c;
            border-radius: 50%;
            display: inline-block;
            box-shadow: 0 0 8px rgba(201,168,76,0.6);
        }
        .nav-links { display: flex; gap: 32px; }
        .nav-links a {
            color: rgba(255,255,255,0.65);
            text-decoration: none;
            font-size: 13px; font-weight: 500;
            transition: color 0.2s;
            letter-spacing: 0.2px;
        }
        .nav-links a:hover { color: #c9a84c; }

        /* Hero */
        .hero {
            flex: 1;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            text-align: center;
            padding: 40px 60px;
            position: relative; z-index: 1;
        }

        .logo-group {
            display: flex; align-items: center;
            margin-bottom: 32px;
        }
        .logo-circle {
            width: 90px; height: 90px;
            border-radius: 50%;
            background: linear-gradient(135deg, #d4b060, #c9a84c, #b8922e);
            display: flex; align-items: center; justify-content: center;
            border: 3px solid rgba(255,255,255,0.2);
            box-shadow: 0 8px 32px rgba(201,168,76,0.35),
                        0 0 0 6px rgba(201,168,76,0.08);
            overflow: hidden;
        }

        .hero h1 {
            font-size: 30px; font-weight: 800; color: white;
            line-height: 1.4; margin-bottom: 10px;
            max-width: 580px;
            letter-spacing: -0.3px;
        }
        .hero h2 {
            font-size: 16px; font-weight: 500;
            color: #c9a84c;
            margin-bottom: 18px;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        /* Gold divider */
        .hero-divider {
            width: 48px; height: 3px;
            background: linear-gradient(90deg, transparent, #c9a84c, transparent);
            border-radius: 2px;
            margin: 0 auto 20px;
        }

        .hero p {
            font-size: 14px; color: rgba(255,255,255,0.6);
            line-height: 1.8; max-width: 420px; margin-bottom: 40px;
        }

        .btn-get-started {
            background: linear-gradient(135deg, #c9a84c, #b8922e);
            border: none;
            color: #1a4731;
            border-radius: 50px;
            padding: 13px 34px;
            font-size: 14px; font-weight: 700;
            display: inline-flex; align-items: center; gap: 10px;
            text-decoration: none;
            transition: all 0.3s;
            box-shadow: 0 4px 20px rgba(201,168,76,0.4);
            letter-spacing: 0.3px;
        }
        .btn-get-started:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(201,168,76,0.5);
            color: #1a4731;
        }
        .btn-get-started .arrow {
            font-size: 16px;
            transition: transform 0.2s;
        }
        .btn-get-started:hover .arrow { transform: translateX(4px); }

        /* Footer */
        .landing-footer {
            display: flex; align-items: center;
            justify-content: space-between;
            padding: 16px 36px;
            border-top: 1px solid rgba(255,255,255,0.07);
            position: relative; z-index: 1;
        }
        .landing-footer span {
            font-size: 11px;
            color: rgba(255,255,255,0.35);
            letter-spacing: 0.2px;
        }
        .portal-status {
            display: flex; align-items: center; gap: 7px;
            font-size: 11px; color: rgba(255,255,255,0.55);
        }
        .portal-status::before {
            content: '';
            width: 7px; height: 7px;
            background: #4ade80;
            border-radius: 50%;
            display: inline-block;
            box-shadow: 0 0 6px rgba(74,222,128,0.6);
            animation: pulse 2s infinite;
        }
        @@keyframes pulse {
            0%, 100% { opacity: 1; }
            50%       { opacity: 0.5; }
        }

        @@media (max-width: 600px) {
            .hero { padding: 32px 24px; }
            .hero h1 { font-size: 22px; }
        }
    </style>
</head>
<body>
<div class="landing-frame">
    <nav class="top-nav">
        <div class="brand-dot">CTU – Ginatilan</div>
        <div class="nav-links">
            <a href="#">About</a>
            <a href="#">Help</a>
            <a href="#">Contact</a>
        </div>
    </nav>

    <div class="hero">
        <div class="logo-group">
            <div class="logo-circle">
                <img src="/images/CTUG-logo-transparent.png" alt="Logo"
                     style="width:100%; height:100%; object-fit:cover;">
            </div>
        </div>

        <h1>Cebu Technological University<br/>Ginatilan Extension Campus</h1>
        <h2>Online Clearance</h2>
        <div class="hero-divider"></div>
        <p>A faster, paperless way to complete your school clearance.
           Track requirements, get signed off, and download your clearance – all in one place.</p>

        <a href="/Home/Login" class="btn-get-started">
            Get Started <span class="arrow">→</span>
        </a>
    </div>

    <footer class="landing-footer">
        <span>Cebu Technological University — Ginatilan Campus · All rights reserved</span>
        <span class="portal-status">Portal is open</span>
    </footer>
</div>
</body>
</html>