@model OnlineClearanceSystem.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Login – Online Clearance</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: url('/images/ctu-g.jpg') no-repeat center center;
            background-size: cover;
            min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
            position: relative;
        }
        body::before {
            content: '';
            position: absolute; inset: 0;
            background: rgba(0,0,0,0.55);
            backdrop-filter: blur(2px);
        }

        .auth-frame {
            width: 900px; min-height: 520px;
            display: flex; border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 24px 80px rgba(0,0,0,0.6);
            position: relative; z-index: 1;
        }

        /* LEFT */
        .auth-left {
            width: 43%;
            background: linear-gradient(160deg, #1e5438 0%, #1a4731 50%, #122e1f 100%);
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            padding: 52px 36px; text-align: center; gap: 20px;
            position: relative; overflow: hidden;
        }
        .auth-left::before {
            content: '';
            position: absolute;
            width: 300px; height: 300px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(201,168,76,0.1) 0%, transparent 70%);
            top: -80px; right: -80px;
        }
        .auth-left::after {
            content: '';
            position: absolute;
            width: 200px; height: 200px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(201,168,76,0.07) 0%, transparent 70%);
            bottom: -60px; left: -60px;
        }

        .logo-circle {
            width: 80px; height: 80px;
            border-radius: 50%;
            background: linear-gradient(135deg, #d4b060, #c9a84c, #b8922e);
            display: flex; align-items: center; justify-content: center;
            border: 3px solid rgba(255,255,255,0.2);
            box-shadow: 0 8px 32px rgba(201,168,76,0.4),
                        0 0 0 8px rgba(201,168,76,0.08);
            overflow: hidden;
            position: relative; z-index: 1;
        }

        .auth-left h2 {
            font-size: 17px; font-weight: 700;
            color: white; line-height: 1.5;
            position: relative; z-index: 1;
        }

        .left-divider {
            width: 40px; height: 2px;
            background: linear-gradient(90deg, transparent, #c9a84c, transparent);
            border-radius: 2px;
            position: relative; z-index: 1;
        }

        /* RIGHT */
        .auth-right {
            flex: 1;
            background: #ffffff;
            display: flex; flex-direction: column;
            justify-content: center; padding: 52px 48px;
        }

        .auth-title {
            font-size: 24px; font-weight: 800;
            color: #111827; margin-bottom: 6px;
            letter-spacing: -0.3px;
        }
        .auth-sub {
            font-size: 13px; color: #9ca3af;
            margin-bottom: 28px; line-height: 1.6;
        }

        .form-label-sm {
            font-size: 12px; font-weight: 600;
            color: #374151; margin-bottom: 6px; display: block;
            letter-spacing: 0.3px;
        }
        .form-input {
            width: 100%;
            border: 1.5px solid #e5e7eb;
            border-radius: 8px;
            padding: 11px 14px;
            font-size: 13.5px; font-family: inherit;
            color: #111827; outline: none;
            background: #f9fafb;
            transition: all 0.2s;
        }
        .form-input:focus {
            border-color: #1a4731;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(26,71,49,0.1);
        }

        .btn-login {
            width: 100%;
            background: linear-gradient(135deg, #22c55e, #16a34a);
            color: white; border: none;
            border-radius: 8px; padding: 13px;
            font-size: 14px; font-weight: 700;
            cursor: pointer; font-family: inherit;
            transition: all 0.25s;
            box-shadow: 0 4px 14px rgba(34,197,94,0.35);
            letter-spacing: 0.3px;
        }
        .btn-login:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(34,197,94,0.45);
        }
        .btn-login:active { transform: translateY(0); }

        .alert-danger-sm {
            background: #fef2f2;
            border: 1.5px solid #fecaca;
            border-radius: 8px; padding: 11px 14px;
            font-size: 13px; color: #dc2626;
            margin-bottom: 18px;
            display: flex; align-items: center; gap: 8px;
        }
        .alert-success-sm {
            background: #f0fdf4;
            border: 1.5px solid #bbf7d0;
            border-radius: 8px; padding: 11px 14px;
            font-size: 13px; color: #16a34a;
            margin-bottom: 18px;
            display: flex; align-items: center; gap: 8px;
        }

        .form-check-sm {
            display: flex; align-items: center; gap: 8px;
            font-size: 13px; color: #6b7280; cursor: pointer;
        }
        .form-check-sm input { accent-color: #16a34a; }
        .field-error {
            font-size: 11px; color: #dc2626;
            margin-top: 4px; display: block;
        }

        @@media (max-width: 640px) {
            .auth-frame { flex-direction: column; width: 96vw; }
            .auth-left  { width: 100%; padding: 36px 24px; }
            .auth-right { padding: 36px 24px; }
        }
    </style>
</head>
<body>
<div class="auth-frame">

    <!-- LEFT PANEL -->
    <div class="auth-left">
        <div class="logo-circle">
            <img src="/images/CTUG-logo-transparent.png" alt="Logo"
                 style="width:100%; height:100%; object-fit:cover;">
        </div>
        <div class="left-divider"></div>
        <h2>Cebu Technological University - Ginatilan Extension – Online Clearance</h2>
    </div>

    <!-- RIGHT PANEL -->
    <div class="auth-right">
        <h2 class="auth-title">Account Login</h2>
        <p class="auth-sub">
            If you are already a member you can login with<br/>
            your username and password.
        </p>

        @if (!string.IsNullOrEmpty(ViewBag.SuccessMessage))
        {
            <div class="alert-success-sm">✔ @ViewBag.SuccessMessage</div>
        }

        @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
        {
            <div class="alert-danger-sm">⚠ @ViewBag.ErrorMessage</div>
        }

        <form asp-action="Login" asp-controller="Home" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div style="margin-bottom:16px;">
                <label class="form-label-sm" asp-for="Username">Username</label>
                <input asp-for="Username"
                       class="form-input"
                       type="text"
                       placeholder="Enter your username"
                       autocomplete="username"/>
                <span asp-validation-for="Username" class="field-error"></span>
            </div>

            <div style="margin-bottom:14px;">
                <label class="form-label-sm" asp-for="Password">Password</label>
                <input asp-for="Password"
                       class="form-input"
                       type="password"
                       placeholder="Enter your password"
                       autocomplete="current-password"/>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div style="margin-bottom:28px;">
                <label class="form-check-sm">
                    <input asp-for="RememberMe" type="checkbox"/>
                    Remember me
                </label>
            </div>

            <button type="submit" class="btn-login">Log-in Account</button>
        </form>

        <p style="text-align:center;font-size:13px;color:#9ca3af;margin-top:22px;">
            Don't have an account? &nbsp;
            <a href="/Home/Register"
               style="color:#16a34a;font-weight:700;text-decoration:none;">
                Register here
            </a>
        </p>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
document.querySelector('form').addEventListener('submit', function(e) {
    let valid = true;
    const un = document.querySelector('input[name="Username"]');
    const pw = document.querySelector('input[name="Password"]');
    if (!un.value.trim()) { un.style.borderColor='#dc2626'; valid=false; }
    else                   { un.style.borderColor=''; }
    if (!pw.value.trim()) { pw.style.borderColor='#dc2626'; valid=false; }
    else                   { pw.style.borderColor=''; }
    if (!valid) e.preventDefault();
});
</script>
</body>
</html>