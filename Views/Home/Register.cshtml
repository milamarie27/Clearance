@model OnlineClearanceSystem.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Register – Online Clearance</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: url('/images/ctu-g.jpg') no-repeat center center;
            background-size: cover;
            min-height: 100vh;
            display: flex; align-items: center;
            justify-content: center; padding: 20px 0;
            position: relative;
        }
        body::before {
            content: '';
            position: absolute; inset: 0;
            background: rgba(0,0,0,0.55);
            backdrop-filter: blur(2px);
        }

        .auth-frame {
            width: 960px; display: flex;
            border-radius: 16px; overflow: hidden;
            box-shadow: 0 24px 80px rgba(0,0,0,0.6);
            position: relative; z-index: 1;
        }

        /* ── LEFT ── */
        .auth-left {
            width: 36%;
            background: linear-gradient(160deg, #1e5438 0%, #1a4731 50%, #122e1f 100%);
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            padding: 44px 28px; text-align: center; gap: 14px;
            position: relative; overflow: hidden;
        }
        .auth-left::before {
            content: '';
            position: absolute;
            width: 300px; height: 300px; border-radius: 50%;
            background: radial-gradient(circle, rgba(201,168,76,0.1) 0%, transparent 70%);
            top: -80px; right: -80px;
        }
        .logo-circle {
            width: 76px; height: 76px; border-radius: 50%;
            background: linear-gradient(135deg, #d4b060, #c9a84c, #b8922e);
            display: flex; align-items: center; justify-content: center;
            border: 3px solid rgba(255,255,255,0.2);
            box-shadow: 0 8px 32px rgba(201,168,76,0.4),
                        0 0 0 8px rgba(201,168,76,0.08);
            overflow: hidden; position: relative; z-index: 1;
        }
        .auth-left h2 {
            font-size: 15px; font-weight: 700;
            color: white; line-height: 1.5;
            position: relative; z-index: 1;
        }
        .left-divider {
            width: 40px; height: 2px;
            background: linear-gradient(90deg, transparent, #c9a84c, transparent);
            border-radius: 2px; position: relative; z-index: 1;
        }
        .notice-box {
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(201,168,76,0.25);
            border-radius: 10px; padding: 12px 14px;
            font-size: 11.5px; color: rgba(255,255,255,0.75);
            line-height: 1.7; text-align: left;
            position: relative; z-index: 1;
        }
        .notice-box strong { color: #c9a84c; }

        /* ── RIGHT ── */
        .auth-right {
            flex: 1; background: #ffffff;
            padding: 28px 38px;
            display: flex; flex-direction: column;
            justify-content: center; position: relative;
            overflow-y: auto;
        }
        .back-link {
            position: absolute; top: 14px; left: 18px;
            font-size: 12px; color: #9ca3af;
            text-decoration: none; font-weight: 500;
            display: flex; align-items: center; gap: 4px;
            transition: color 0.2s;
        }
        .back-link:hover { color: #1a4731; }

        .auth-title {
            font-size: 20px; font-weight: 800;
            color: #111827; margin-bottom: 2px;
            margin-top: 18px; letter-spacing: -0.3px;
        }
        .auth-sub {
            font-size: 12px; color: #9ca3af;
            margin-bottom: 14px; line-height: 1.5;
        }

        .form-label-sm {
            font-size: 11px; font-weight: 600;
            color: #374151; margin-bottom: 4px;
            display: block; letter-spacing: 0.3px;
        }
        .req { color: #dc2626; }

        .form-input {
            width: 100%;
            border: 1.5px solid #e5e7eb;
            border-radius: 7px; padding: 8px 11px;
            font-size: 12.5px; font-family: inherit;
            color: #111827; outline: none;
            background: #f9fafb;
            transition: all 0.2s;
        }
        .form-input:focus {
            border-color: #1a4731;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(26,71,49,0.1);
        }
        .field-error {
            font-size: 10.5px; color: #dc2626;
            margin-top: 2px; display: block;
        }
        .alert-danger-sm {
            background: #fef2f2;
            border: 1.5px solid #fecaca;
            border-radius: 8px; padding: 9px 12px;
            font-size: 12px; color: #dc2626;
            margin-bottom: 12px;
            display: flex; align-items: center; gap: 8px;
        }

        /* ── SECTION DIVIDER ── */
        .section-divider {
            border-top: 1.5px dashed #e5e7eb;
            margin: 4px 0 8px;
        }
        .section-label {
            font-size: 10px; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.9px;
            color: #9ca3af; margin-bottom: 1px;
        }
        .section-hint {
            font-size: 10.5px; color: #b0b7c3;
            margin-bottom: 8px; line-height: 1.5;
        }

        /* ── LOGIN CREDENTIALS BOX ── */
        .credentials-box {
            background: #f0fdf4;
            border: 1.5px solid #bbf7d0;
            border-radius: 10px;
            padding: 14px 16px 10px;
            margin-bottom: 4px;
        }
        .credentials-box-label {
            font-size: 10px; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.9px;
            color: #16a34a; margin-bottom: 8px;
            display: flex; align-items: center; gap: 5px;
        }

        .btn-register {
            width: 100%;
            background: linear-gradient(135deg, #22c55e, #16a34a);
            color: white; border: none;
            border-radius: 8px; padding: 11px;
            font-size: 13.5px; font-weight: 700;
            cursor: pointer; font-family: inherit;
            transition: all 0.25s; margin-top: 14px;
            box-shadow: 0 4px 14px rgba(34,197,94,0.35);
            letter-spacing: 0.3px;
        }
        .btn-register:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(34,197,94,0.45);
        }
        .btn-register:active { transform: translateY(0); }

        @@media (max-width: 640px) {
            .auth-frame { flex-direction: column; width: 96vw; }
            .auth-left  { width: 100%; padding: 28px 20px; }
            .auth-right { padding: 24px; }
        }
    </style>
</head>
<body>
<div class="auth-frame">

    <!-- LEFT -->
    <div class="auth-left">
        <div class="logo-circle">
            <img src="/images/CTUG-logo-transparent.png" alt="Logo"
                 style="width:100%; height:100%; object-fit:cover;">
        </div>
        <div class="left-divider"></div>
        <h2>Cebu Technological University – Ginatilan Extension Campus – Online Clearance</h2>
        <div class="notice-box">
            <strong>Note:</strong> After registering, your account will be reviewed by the Admin.
            You will be notified via email once your account is activated.
        </div>
    </div>

    <!-- RIGHT -->
    <div class="auth-right">
        <div class="auth-title">Create Account</div>
        <p class="auth-sub">Fill in your information below to register.</p>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert-danger-sm">⚠ Please correct the errors below.</div>
        }
        @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
        {
            <div class="alert-danger-sm">⚠ @ViewBag.ErrorMessage</div>
        }

        <form asp-action="Register" asp-controller="Home" method="post" novalidate>
            @Html.AntiForgeryToken()
            <div class="row g-2">

                <!-- ── 1. LOGIN CREDENTIALS (most important) ── -->
                <div class="col-12">
                    <div class="credentials-box">
                        <div class="credentials-box-label">
                            🔐 Login Credentials
                        </div>
                        <div class="row g-2">
                            <div class="col-md-6">
                                <label class="form-label-sm">ID Number <span class="req">*</span></label>
                                <input asp-for="IdNumber" class="form-input"
                                       placeholder="e.g. 2024-00001" autofocus/>
                                <span asp-validation-for="IdNumber" class="field-error"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-sm">Password <span class="req">*</span></label>
                                <input asp-for="Password" class="form-input" type="password"
                                       placeholder="Min. 6 characters" autocomplete="new-password"/>
                                <span asp-validation-for="Password" class="field-error"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ── 2. PERSONAL INFO ── -->
                <div class="col-12">
                    <div class="section-divider"></div>
                    <div class="section-label">👤 Personal Information</div>
                </div>

                <div class="col-md-5">
                    <label class="form-label-sm">First Name <span class="req">*</span></label>
                    <input asp-for="FirstName" class="form-input" placeholder="First name"/>
                    <span asp-validation-for="FirstName" class="field-error"></span>
                </div>
                <div class="col-md-2">
                    <label class="form-label-sm">M.I.</label>
                    <input asp-for="MiddleInitial" class="form-input" placeholder="M.I." maxlength="3"/>
                </div>
                <div class="col-md-5">
                    <label class="form-label-sm">Last Name <span class="req">*</span></label>
                    <input asp-for="LastName" class="form-input" placeholder="Last name"/>
                    <span asp-validation-for="LastName" class="field-error"></span>
                </div>

                <!-- ── 3. EMAIL ── -->
                <div class="col-12">
                    <label class="form-label-sm">Email Address <span class="req">*</span></label>
                    <input asp-for="Email" class="form-input" type="email"
                           placeholder="e.g. yourname@email.com" autocomplete="email"/>
                    <span asp-validation-for="Email" class="field-error"></span>
                    <span style="font-size:10.5px;color:#9ca3af;margin-top:2px;display:block;">
                        📧 You will be notified at this email when your account is activated.
                    </span>
                </div>

                <!-- ── 4. STUDENT INFO (optional) ── -->
                <div class="col-12">
                    <div class="section-divider"></div>
                    <div class="section-label">🎓 Student Information</div>
                    <div class="section-hint">
                        For students only — leave blank if you are an Instructor or Staff.
                    </div>
                </div>

                <div class="col-12">
                    <label class="form-label-sm">Course</label>
                    <select asp-for="Course"
                            asp-items="Model.CourseOptions"
                            class="form-input"
                            id="courseSelect">
                        <option value="">— Select course —</option>
                    </select>
                    <span asp-validation-for="Course" class="field-error"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label-sm">Year Level</label>
                    <select asp-for="YearLevel" class="form-input">
                        <option value="">— Select year level —</option>
                        <option value="1">1st Year</option>
                        <option value="2">2nd Year</option>
                        <option value="3">3rd Year</option>
                        <option value="4">4th Year</option>
                    </select>
                    <span asp-validation-for="YearLevel" class="field-error"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label-sm">Section</label>
                    <select asp-for="Section" class="form-input" id="sectionSelect">
                        <option value="">— Select a course first —</option>
                    </select>
                    <span asp-validation-for="Section" class="field-error"></span>
                </div>
            </div>

            <button type="submit" class="btn-register">Register Account</button>
        </form>

        <p style="text-align:center;font-size:12px;color:#9ca3af;margin-top:12px;">
            Already have an account? &nbsp;
            <a href="/Home/Login" style="color:#16a34a;font-weight:700;text-decoration:none;">
                Log in here
            </a>
        </p>
    </div>
</div>

<script>
document.querySelector('form').addEventListener('submit', function(e) {
    const pw  = document.querySelector('input[name="Password"]');
    const cpw = document.getElementById('cpw');
    if (pw && cpw && pw.value !== cpw.value) {
        cpw.style.borderColor = '#dc2626';
        e.preventDefault();
    } else if (cpw) {
        cpw.style.borderColor = '';
    }
});

document.getElementById('courseSelect').addEventListener('change', async function () {
    const courseId = this.value;
    const sectionSelect = document.getElementById('sectionSelect');

    sectionSelect.innerHTML = '<option value="">— Loading... —</option>';

    if (!courseId) {
        sectionSelect.innerHTML = '<option value="">— Select a course first —</option>';
        return;
    }

    try {
        const res      = await fetch(`/Home/GetSections?courseId=${courseId}`);
        const sections = await res.json();

        sectionSelect.innerHTML = '<option value="">— Select section —</option>';

        if (sections.length === 0) {
            sectionSelect.innerHTML = '<option value="">— No sections found —</option>';
            return;
        }

        sections.forEach(s => {
            const opt = document.createElement('option');
            opt.value = s.value;
            opt.textContent = s.text;
            opt.dataset.yearLevel = s.yearLevel;  // ← carry year level
            sectionSelect.appendChild(opt);
        });

    } catch {
        sectionSelect.innerHTML = '<option value="">— Error loading sections —</option>';
    }
});

// Auto-fill Year Level when section is picked
document.getElementById('sectionSelect').addEventListener('change', function () {
    const selected = this.options[this.selectedIndex];
    const yearLevel = selected?.dataset?.yearLevel;
    if (yearLevel) {
        document.querySelector('select[name="YearLevel"]').value = yearLevel;
    }
});
</script>
</body>
</html>