@model OnlineClearanceSystem.Models.StudentDashboardViewModel
@{
    ViewData["Title"]      = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
}

<style>
    .check-box { width: 22px; height: 22px; border-radius: 50%; border: 2px solid #ccc; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: 0.3s; background: white; }
    .check-box i { display: none; font-size: 12px; }
    .check-box.active { background: var(--green); border-color: var(--green); }
    .check-box.active i { display: block; color: white; }
</style>

<!-- WELCOME BANNER -->
<div class="welcome-card mb-4">
    <div>
        <h4>Welcome,</h4>
        <h2>@(Model?.StudentName ?? "Student")!</h2>
    </div>
    <div class="period-box">
        <div class="period-icon"><i class="fas fa-calendar-alt"></i></div>
        <div>
            <div class="period-label">Active Academic Period</div>
            <div class="period-value">@(Model?.ActivePeriod ?? "A.Y. 2025-2026, 2nd Semester")</div>
        </div>
        <span class="active-badge">Active</span>
    </div>
</div>

<!-- STAT CARDS -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon green">
                <i class="fas fa-clipboard-check"></i>
                <span class="stat-dot ok"><i class="fas fa-check"></i></span>
            </div>
            <div>
                <div class="stat-num">
                    @(Model?.SubjectCleared ?? 0)
                    <span style="font-size:16px;color:#888;"></span>
                </div>
                <div class="stat-label">Subject Cleared</div>
                <div class="stat-sub">Total Subjects</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon orange">
                <i class="fas fa-clock"></i>
                <span class="stat-dot bad"><i class="fas fa-times"></i></span>
            </div>
            <div>
                <div class="stat-num">@(Model?.SubjectIncomplete ?? 0)</div>
                <div class="stat-label">Subject Incomplete</div>
                <div class="stat-sub">Across all enrolled subjects</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon blue">
                <i class="fas fa-sitemap"></i>
            </div>
            <div>
                <div class="stat-num">
                    @(Model?.OrgCleared ?? 0)
                    <span style="font-size:16px;color:#888;"></span>
                </div>
                <div class="stat-label">Organization Cleared</div>
                <div class="stat-sub">Across all organization signatures</div>
            </div>
        </div>
    </div>
</div>

<!-- CHECKLIST + ANNOUNCEMENTS -->
<div class="row g-3">

    <!-- CHECKLIST — steps stay static as requested -->
    <div class="col-md-5">
        <div class="page-card">
            <div style="background:var(--green);color:white;padding:13px 18px;
                        display:flex;justify-content:space-between;align-items:center;">
                <span style="font-weight:700;font-size:14px;">
                    <i class="fas fa-tasks me-2"></i>Clearance Checklist
                </span>
                <span id="progress-badge"
                      style="background:var(--green-accent);border-radius:20px;
                             padding:3px 12px;font-size:11px;font-weight:700;">
                    0/5 Completed
                </span>
            </div>
            @foreach (var step in new[] {
                new { title="Step 1: Select Subject",
                      desc="Select the subjects you enrolled." },
                new { title="Step 2: Confirm Enrolled Subjects",
                      desc="Confirm your selected enrolled subjects, then submit to the assigned Instructor." },
                new { title="Step 3: Subject Instructor's Approval",
                      desc="Wait for your Subject Instructors to sign your clearance." },
                new { title="Step 4: Final Approval",
                      desc="Lastly, get approval from the Organization's Signatories." },
                new { title="Final Check",
                      desc="Download and print the PDF. Make sure all of the above are approved to proceed." },
            })
            {
                <div class="checklist-item">
                    <div class="check-box"><i class="fas fa-check"></i></div>
                    <div>
                        <div class="check-title">@step.title</div>
                        <div class="check-desc">@step.desc</div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- ANNOUNCEMENTS — from DB -->
    <div class="col-md-7">
        <div style="background:white;border-radius:12px;padding:18px;
                    box-shadow:0 1px 4px rgba(0,0,0,0.07);">

            <div class="d-flex gap-2 mb-3 flex-wrap">
                <button class="ann-tab active" onclick="filterAnn('all',this)">ALL</button>
                <button class="ann-tab" onclick="filterAnn('Pinned',this)"
                        style="background:#1a4731;color:white;border-color:#1a4731;">
                    <i class="fas fa-thumbtack me-1"></i>PINNED
                </button>
                <button class="ann-tab" onclick="filterAnn('Urgent',this)"
                        style="background:#dc3545;color:white;border-color:#dc3545;">
                    URGENT
                </button>
                <button class="ann-tab" onclick="filterAnn('Event',this)"
                        style="background:#0d6efd;color:white;border-color:#0d6efd;">
                    EVENTS
                </button>
            </div>

            <div id="ann-list">
                @if (Model?.Announcements != null && Model.Announcements.Any())
                {
                    @foreach (var ann in Model.Announcements)
                    {
                        <div class="ann-card" data-tag="@ann.Type.ToLower()">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="ann-avatar">SA</div>
                                    <div>
                                        <div style="font-weight:700;font-size:12px;">System Administrator</div>
                                        <div style="font-size:11px;color:#888;">@ann.Date</div>
                                    </div>
                                </div>
                                <div class="d-flex gap-1">
                                    @if (ann.Type == "Pinned")
                                    {
                                        <span class="ann-tag tag-pinned">
                                            <i class="fas fa-thumbtack me-1"></i>Pinned
                                        </span>
                                    }
                                    @if (ann.Type == "Urgent")
                                    {
                                        <span class="ann-tag tag-urgent">Urgent</span>
                                    }
                                    @if (ann.Type == "Event")
                                    {
                                        <span class="ann-tag tag-event">Event</span>
                                    }
                                    @if (ann.Type == "General" || string.IsNullOrEmpty(ann.Type))
                                    {
                                        <span class="ann-tag"
                                              style="background:#f3f4f6;color:#555;">
                                            General
                                        </span>
                                    }
                                </div>
                            </div>
                            <div style="font-weight:700;font-size:13px;margin-bottom:6px;">
                                @ann.Title
                            </div>
                            <div style="font-size:12px;color:#555;line-height:1.6;">
                                @ann.Content
                            </div>
                        </div>
                    }
                }
                else
                {
                    <!-- Empty announcements state -->
                    <div style="text-align:center;padding:40px 24px;color:#888;">
                        <i class="fas fa-bullhorn"
                           style="font-size:32px;color:#ddd;margin-bottom:12px;display:block;"></i>
                        <div style="font-size:14px;font-weight:600;color:#aaa;">
                            No announcements yet
                        </div>
                        <div style="font-size:12px;margin-top:4px;">
                            Check back later for updates from the Admin.
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function filterAnn(tag, btn) {
    document.querySelectorAll('.ann-tab').forEach(b => {
        b.style.background  = 'white';
        b.style.color       = '#555';
        b.style.borderColor = '#dee2e6';
    });
    btn.style.background  = '#28a745';
    btn.style.color       = 'white';
    btn.style.borderColor = '#28a745';

    document.querySelectorAll('#ann-list .ann-card').forEach(c => {
        c.style.display = tag === 'all'
            ? ''
            : (c.dataset.tag || '').toLowerCase()
                .includes(tag.toLowerCase()) ? '' : 'none';
    });
}

document.querySelectorAll('.check-box').forEach(box => {
    box.addEventListener('click', () => {
        box.classList.toggle('active');
        const total   = document.querySelectorAll('.check-box').length;
        const checked = document.querySelectorAll('.check-box.active').length;
        document.getElementById('progress-badge').textContent =
            `${checked}/${total} Completed`;
    });
});
</script>
}