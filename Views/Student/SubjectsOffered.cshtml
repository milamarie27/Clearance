@model OnlineClearanceSystem.Models.SubjectOfferedViewModel

@{
    ViewData["Title"]      = "Subjects Offered";
    ViewData["ActivePage"] = "SubjectsOffered";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
    bool showConfirm = ViewData["ShowConfirm"] is true;
}

<!-- STEP 1: SELECT SUBJECTS -->
<div id="step-select" style="display:@(showConfirm ? "none" : "block")">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h5 class="fw-bold mb-0" style="color:#1a1a2e;"></h5>
        <span class="semester-badge">
            <i class="fas fa-calendar-alt me-2"></i>
            @(Model?.ActivePeriod ?? "2nd Semester · A.Y. 2025-2026")
        </span>
    </div>

    <div class="page-card">
        <div class="page-card-hd dark">
            <i class="fas fa-book-open me-2"></i>Available Subjects — Select yours
        </div>

        <!-- SEARCH BAR -->
        <div style="padding:12px 16px;border-bottom:1px solid var(--border);
                    display:flex;align-items:center;gap:10px;">
            <div style="position:relative;flex:1;max-width:380px;">
                <i class="fas fa-search"
                   style="position:absolute;left:12px;top:50%;
                          transform:translateY(-50%);color:#aaa;font-size:13px;"></i>
                <input type="text"
                       id="subject-search"
                       placeholder="Search by MIS code, subject, description or instructor..."
                       oninput="filterSubjects(this.value)"
                       style="width:100%;padding:8px 12px 8px 34px;
                              border:1px solid #dee2e6;border-radius:8px;
                              font-size:13px;font-family:inherit;outline:none;" />
            </div>
            <span id="search-count" style="font-size:12px;color:#888;white-space:nowrap;"></span>
        </div>

        @if (Model?.AvailableSubjects != null && Model.AvailableSubjects.Any())
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width:40px;"></th>
                            <th>MIS CODE</th>
                            <th>SUBJECT CODE</th>
                            <th>DESCRIPTION</th>
                            <th>INSTRUCTOR</th>
                            <th>STATUS</th>
                        </tr>
                    </thead>
                    <tbody id="subject-tbody">
                        @foreach (var s in Model.AvailableSubjects)
                        {
                            var rowStyle = s.AlreadyEnrolled ? "opacity:0.6;" : "";
                            <tr class="subject-row"
                                style="@rowStyle"
                                data-search-mis="@s.MisCode.ToLower()"
                                data-search-subj="@s.SubjectCode.ToLower()"
                                data-search-desc="@s.Description.ToLower()"
                                data-search-inst="@s.InstructorName.ToLower()">
                                <td>
                                    @if (s.AlreadyEnrolled)
                                    {
                                        <input type="checkbox"
                                               disabled
                                               checked
                                               style="width:16px;height:16px;cursor:not-allowed;" />
                                    }
                                    else
                                    {
                                        <input type="checkbox"
                                               class="subject-check"
                                               value="@s.MisCode"
                                               style="width:16px;height:16px;
                                                      accent-color:var(--green-accent);
                                                      cursor:pointer;" />
                                    }
                                </td>
                                <td><span class="code-badge">@s.MisCode</span></td>
                                <td style="font-weight:600;">@s.SubjectCode</td>
                                <td>@s.Description</td>
                                <td>@s.InstructorName</td>
                                <td>
                                    @if (s.AlreadyEnrolled)
                                    {
                                        var badgeColor = s.EnrolledStatus switch {
                                            "Cleared"  => "background:rgba(56,161,105,0.15);color:#38a169;",
                                            "Pending"  => "background:rgba(246,173,85,0.15);color:#f6ad55;",
                                            "Declined" => "background:rgba(229,62,62,0.15);color:#e53e3e;",
                                            _          => ""
                                        };
                                        <span style="@badgeColor padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;">
                                            @s.EnrolledStatus
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div id="no-results"
                 style="display:none;padding:24px;text-align:center;
                        color:#888;font-size:13px;">
                <i class="fas fa-search me-2"></i>No subjects found.
            </div>

            <div style="padding:16px 20px;border-top:1px solid var(--border);
                        text-align:right;">
                <button class="btn-green" onclick="showConfirmStep()">
                    <i class="fas fa-arrow-right me-2"></i>Proceed to Confirm
                </button>
            </div>
        }
        else
        {
            <div style="display:flex;flex-direction:column;align-items:center;
                        justify-content:center;padding:64px 24px;text-align:center;gap:14px;">
                <div style="width:80px;height:80px;border-radius:50%;
                            background:#f0fdf4;border:2px solid #bbf7d0;
                            display:flex;align-items:center;justify-content:center;
                            font-size:32px;color:#16a34a;">
                    <i class="fas fa-book-open"></i>
                </div>
                <div style="font-size:16px;font-weight:700;color:#1a1a2e;">
                    No subjects offered yet
                </div>
                <div style="font-size:13px;color:#888;line-height:1.7;max-width:360px;">
                    The administrator has not set up any subjects for the
                    current academic period yet. Please check back later.
                </div>
            </div>
        }
    </div>
</div>

<!-- STEP 2: CONFIRM SUBJECTS -->
<div id="step-confirm" style="display:@(showConfirm ? "block" : "none")">
    <div class="page-card">
        <div style="padding:18px 20px;text-align:center;font-size:14px;
                    font-weight:500;color:#333;border-bottom:1px solid var(--border);">
            <i class="fas fa-question-circle me-2" style="color:#1a4731;"></i>
            Are you sure these are all the subjects you're enrolled in this semester?
        </div>

        <div class="page-card-hd" style="font-size:14px;">Selected Subjects</div>

        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>MIS CODE</th>
                        <th>SUBJECT CODE</th>
                        <th>DESCRIPTION</th>
                        <th>INSTRUCTOR</th>
                        <th style="width:60px;">ACTION</th>
                    </tr>
                </thead>
                <tbody id="confirm-body"></tbody>
            </table>
            <div id="confirm-empty"
                 style="display:none;padding:20px;text-align:center;
                        font-size:13px;color:#888;">
                No subjects selected. Please go back and select at least one.
            </div>
        </div>

        <div style="padding:16px 20px;background:#f8f9fa;
                    display:flex;gap:12px;justify-content:space-between;
                    align-items:center;">
            <button class="btn-dark" onclick="backToSelect()">
                <i class="fas fa-arrow-left me-2"></i>BACK
            </button>
            <form asp-action="ConfirmSubjects" asp-controller="Student"
                  method="post" id="confirm-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="selectedSubjects" id="selected-hidden" />
                <button type="submit" id="submit-btn"
                        class="btn-green" onclick="return prepareSubmit()">
                    <i class="fas fa-check me-2"></i>YES, Confirm
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    /*
     * Build lookup map from Razor model — keyed by MisCode
     * so the value we POST matches exactly what's in the database.
     */
    const subjectMap = {};
    @if (Model?.AvailableSubjects != null)
    {
        foreach (var s in Model.AvailableSubjects)
        {
            <text>
    subjectMap[@Html.Raw(Json.Serialize(s.MisCode))] = {
        mis:  @Html.Raw(Json.Serialize(s.MisCode)),
        subj: @Html.Raw(Json.Serialize(s.SubjectCode)),
        desc: @Html.Raw(Json.Serialize(s.Description)),
        inst: @Html.Raw(Json.Serialize(s.InstructorName))
    };
            </text>
        }
    }

    /* ── Search / filter ── */
    function filterSubjects(query) {
        const q = query.toLowerCase().trim();
        const rows = document.querySelectorAll('.subject-row');
        let visible = 0;

        rows.forEach(row => {
            const match = !q
                || row.dataset.searchMis.includes(q)
                || row.dataset.searchSubj.includes(q)
                || row.dataset.searchDesc.includes(q)
                || row.dataset.searchInst.includes(q);

            row.style.display = match ? '' : 'none';
            if (match) visible++;
        });

        const countEl = document.getElementById('search-count');
        countEl.textContent = q
            ? `${visible} result${visible !== 1 ? 's' : ''} found`
            : '';
        document.getElementById('no-results').style.display =
            visible === 0 ? 'block' : 'none';
    }

    /* ── Proceed to confirm step ── */
    function showConfirmStep() {
        const checked = [...document.querySelectorAll('.subject-check:checked')];
        if (checked.length === 0) {
            alert('Please select at least one subject.');
            return;
        }

        const tbody = document.getElementById('confirm-body');
        tbody.innerHTML = '';

        checked.forEach(cb => {
            // cb.value is now the MisCode directly
            const misCode = cb.value;
            const d = subjectMap[misCode];
            if (!d) return;

            const tr = document.createElement('tr');
            tr.id = 'confirm-row-' + misCode;
            tr.innerHTML = `
                <td><span class="code-badge">${d.mis}</span></td>
                <td style="font-weight:600;">${d.subj}</td>
                <td>${d.desc}</td>
                <td>${d.inst}</td>
                <td style="text-align:center;">
                    <button type="button"
                            onclick="removeConfirmRow('${misCode}')"
                            style="background:none;border:none;cursor:pointer;
                                   color:#dc3545;font-size:18px;"
                            title="Remove">
                        <i class="fas fa-times-circle"></i>
                    </button>
                </td>`;
            tbody.appendChild(tr);
        });

        document.getElementById('step-select').style.display  = 'none';
        document.getElementById('step-confirm').style.display = 'block';
        checkConfirmEmpty();
    }

    /* ── Remove a row in the confirm step ── */
    function removeConfirmRow(misCode) {
        document.getElementById('confirm-row-' + misCode)?.remove();
        const cb = document.querySelector(`.subject-check[value="${misCode}"]`);
        if (cb) cb.checked = false;
        checkConfirmEmpty();
    }

    /* ── Show empty message if all rows removed ── */
    function checkConfirmEmpty() {
        const rows  = document.querySelectorAll('#confirm-body tr');
        const empty = document.getElementById('confirm-empty');
        const btn   = document.getElementById('submit-btn');
        empty.style.display = rows.length === 0 ? 'block' : 'none';
        btn.disabled        = rows.length === 0;
    }

    /* ── Go back to selection step ── */
    function backToSelect() {
        document.getElementById('step-select').style.display  = 'block';
        document.getElementById('step-confirm').style.display = 'none';
        document.getElementById('subject-search').value = '';
        filterSubjects('');
    }

    /* ── Pack MIS codes into hidden input before POST ── */
    function prepareSubmit() {
        const misCodes = [...document.querySelectorAll('#confirm-body tr')]
            .map(r => r.id.replace('confirm-row-', ''));

        if (misCodes.length === 0) {
            alert('You have removed all subjects. Please go back and select at least one.');
            return false;
        }

        // This posts e.g. "GT-1,GT-2,GT-3" — matching mis_code in the DB
        document.getElementById('selected-hidden').value = misCodes.join(',');
        return true;
    }
</script>
}