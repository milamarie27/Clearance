@* ═══════════════════════════════════════════════════════════════════════════
   Views/Instructor/Organization.cshtml
   ═══════════════════════════════════════════════════════════════════════════ *@
@model IEnumerable<OnlineClearanceSystem.Models.OrganizationRequest>
@{
    ViewData["Title"]      = "Organization";
    ViewData["ActivePage"] = "Organization";
    Layout = "~/Views/Shared/_InstructorLayout.cshtml";
}

@* ── Alerts ───────────────────────────────────────────────────────────── *@
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="page-card">
    <div class="page-card-hd dark">
        <i class="fas fa-sitemap me-2"></i>Organization Requests
        @if (Model != null && Model.Any())
        {
            <span class="badge bg-warning text-dark ms-2" style="font-size:12px;">
                @Model.Count() pending
            </span>
        }
    </div>
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width:80px;text-align:center;">NO.</th>
                    <th>POSITION</th>
                    <th>REQUESTED BY</th>
                    <th style="text-align:center;">ACTION</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    int i = 1;
                    foreach (var item in Model)
                    {
                        <tr>
                            <td style="text-align:center;">
                                <span class="code-badge">@i.ToString("D2")</span>
                            </td>

                            <td style="font-weight:600;">@item.Position</td>

                            <td>
                                <div style="font-weight:600;font-size:13px;">@item.StudentName</div>
                                <div style="font-size:11px;color:#888;">@item.Course</div>
                            </td>

                            @* ── Action column ────────────────────────────── *@
                            <td style="text-align:center;">
                                @if (item.Status == "Cleared")
                                {
                                    <span class="status-approved">Cleared</span>
                                }
                                else if (item.Status == "Declined")
                                {
                                    <span class="status-declined">Declined</span>
                                }
                                else
                                {
                                    @* Pending – show Approve / Decline buttons *@
                                    <div class="d-flex gap-2 justify-content-center">
                                        <form asp-action="ApproveOrg" asp-controller="Instructor"
                                              method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn-approve"
                                                    onclick="return confirm('Clear this student?')">
                                                <i class="fas fa-check me-1"></i>Cleared
                                            </button>
                                        </form>
                                        <form asp-action="DeclineOrg" asp-controller="Instructor"
                                              method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn-decline"
                                                    onclick="return confirm('Decline this request?')">
                                                <i class="fas fa-times me-1"></i>Decline
                                            </button>
                                        </form>
                                    </div>
                                }
                            </td>
                        </tr>
                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" style="padding:40px;text-align:center;color:#888;">
                            <i class="fas fa-sitemap"
                               style="font-size:28px;color:#ddd;display:block;margin-bottom:10px;"></i>
                            No pending organization requests.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Styles {
<style>
    .btn-approve {
        background: #2e7d32;
        color: #fff;
        border: none;
        border-radius: 7px;
        padding: 6px 14px;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        font-family: inherit;
        transition: opacity .2s;
    }
    .btn-approve:hover { opacity: .85; }

    .btn-decline {
        background: #c62828;
        color: #fff;
        border: none;
        border-radius: 7px;
        padding: 6px 14px;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        font-family: inherit;
        transition: opacity .2s;
    }
    .btn-decline:hover { opacity: .85; }

    .status-approved {
        background: #e8f5e9;
        color: #2e7d32;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 700;
    }
    .status-declined {
        background: #fce4ec;
        color: #c62828;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 700;
    }
</style>
}
