@model IEnumerable<OnlineClearanceSystem.Models.SubjectOfferingDto>
@{
    ViewData["Title"]      = "Assigned Subjects";
    ViewData["ActivePage"] = "SubjectOfferings";
    Layout = "~/Views/Shared/_InstructorLayout.cshtml";
}

<div class="page-card">
    <div class="page-card-hd dark"><i class="fas fa-book-open me-2"></i>Assigned Subjects</div>
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>MIS CODE</th><th>SUBJECT CODE</th><th>DESCRIPTION</th>
                    <th style="text-align:center;">LAB UNIT</th>
                    <th style="text-align:center;">LEC UNIT</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="code-badge">@item.MisCode</span></td>
                            <td style="font-weight:600;">@item.SubjectCode</td>
                            <td>@item.Description</td>
                            <td style="text-align:center;font-weight:700;">@item.LabUnit</td>
                            <td style="text-align:center;font-weight:700;">@item.LecUnit</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" style="padding:40px;text-align:center;color:#888;">
                        <i class="fas fa-book-open" style="font-size:28px;color:#ddd;display:block;margin-bottom:10px;"></i>
                        No subjects assigned yet.
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
