@model IEnumerable<OnlineClearanceSystem.Models.SignedClearance>

@{
    ViewData["Title"] = "Signed Clearance";
    ViewData["ActivePage"] = "SignedClearance";
    Layout = "~/Views/Shared/_InstructorLayout.cshtml";

    string currentFilter = ViewData["Filter"]?.ToString() ?? "all";
}

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3">
        <i class="fas fa-exclamation-circle me-2"></i>
        @ViewBag.ErrorMessage

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>
    </div>
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h5 class="fw-bold mb-0" style="color:#1a1a2e;">
        
    </h5>
</div>

<div class="page-card">

    <div class="page-card-hd dark">
        <i class="fas fa-file-signature me-2"></i>

        Signed Clearance

        @if (Model != null && Model.Any())
        {
            <span class="badge bg-secondary ms-2"
                  style="font-size:12px;">
                @Model.Count() record(s)
            </span>
        }
    </div>

    <div class="page-card-body p-3">

        @* Filter Bar *@
        <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">

            <a href="?filter=all"
               class="filter-btn @(currentFilter == "all" ? "active-filter" : "")">
                All
            </a>

            <a href="?filter=approved"
               class="filter-btn @(currentFilter == "approved" ? "approved-filter" : "")">
                Approved
            </a>

            <a href="?filter=rejected"
               class="filter-btn @(currentFilter == "rejected" ? "rejected-filter" : "")">
                Rejected
            </a>

        </div>

        <div class="table-responsive">

            <table class="data-table">

                <thead>
                    <tr>
                        <th>MIS CODE</th>
                        <th>SUBJECT CODE</th>
                        <th>DESCRIPTION</th>
                        <th>STUDENT</th>
                        <th style="text-align:center;">STATUS</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    <span class="code-badge">
                                        @item.MisCode
                                    </span>
                                </td>

                                <td class="fw-semibold">
                                    @item.SubjectCode
                                </td>

                                <td>
                                    @item.Description
                                </td>

                                <td>
                                    <div class="fw-semibold">
                                        @item.StudentName
                                    </div>

                                    <div class="student-course">
                                        @item.StudentCourse
                                    </div>
                                </td>

                                <td style="text-align:center;">

                                    @if (item.Status == "Approved")
                                    {
                                        <span class="status-approved">
                                            Approved
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-declined">
                                            Declined
                                        </span>
                                    }

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5"
                                class="empty-state">

                                <i class="fas fa-file-signature empty-icon"></i>

                                No signed clearances found.

                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

@section Styles {

<style>

    .filter-btn{
        padding:6px 16px;
        border-radius:20px;
        border:1.5px solid #dee2e6;
        background:white;
        color:#555;
        font-size:12px;
        font-weight:700;
        text-decoration:none;
        transition:0.2s;
        font-family:inherit;
    }

    .filter-btn:hover{
        border-color:#1a4731;
        color:#1a4731;
    }

    .active-filter{
        background:#1a4731;
        color:white !important;
        border-color:#1a4731;
    }

    .approved-filter{
        background:#28a745;
        color:white !important;
        border-color:#28a745;
    }

    .rejected-filter{
        background:#dc3545;
        color:white !important;
        border-color:#dc3545;
    }

    .status-approved{
        background:#e8f5e9;
        color:#2e7d32;
        border-radius:20px;
        padding:4px 12px;
        font-size:11px;
        font-weight:700;
    }

    .status-declined{
        background:#fce4ec;
        color:#c62828;
        border-radius:20px;
        padding:4px 12px;
        font-size:11px;
        font-weight:700;
    }

    .student-course{
        font-size:11px;
        color:#888;
    }

    .empty-state{
        padding:40px;
        text-align:center;
        color:#888;
    }

    .empty-icon{
        font-size:28px;
        color:#ddd;
        display:block;
        margin-bottom:10px;
    }

</style>
}