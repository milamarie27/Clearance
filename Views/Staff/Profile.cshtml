@model OnlineClearanceSystem.Models.StaffProfileViewModel

@{
    ViewData["Title"]      = "Profile";
    ViewData["ActivePage"] = "Profile";
    Layout = "~/Views/Shared/_StaffLayout.cshtml";
}

@Html.AntiForgeryToken()

@if (TempData["ProfileSaved"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="fas fa-check-circle me-2"></i>@TempData["ProfileSaved"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
{
    <div class="alert alert-danger mb-3">⚠ @ViewBag.ErrorMessage</div>
}

<div class="row g-3">

    <!-- ── LEFT COLUMN: Edit Profile ── -->
    <div class="col-md-7">

        <!-- EDIT PROFILE -->
        <div style="background:white;border-radius:12px;border:1px solid #e2e8f0;overflow:hidden;margin-bottom:12px;">
            <div style="padding:14px 18px;background:var(--green);display:flex;align-items:center;gap:8px;">
                <i class="fas fa-user-edit" style="color:white;"></i>
                <span style="font-size:14px;font-weight:700;color:white;">Edit Profile</span>
            </div>
            <div style="padding:20px;">
                <form asp-action="SaveStaffProfile" asp-controller="Staff" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div class="row g-3">

                        <div class="col-md-6">
                            <label class="profile-label">First Name</label>
                            <div class="profile-input-wrap">
                                <input asp-for="FirstName" class="profile-input" placeholder="First Name"/>
                                <i class="fas fa-pen profile-edit-icon"></i>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="profile-label">Last Name</label>
                            <div class="profile-input-wrap">
                                <input asp-for="LastName" class="profile-input" placeholder="Last Name"/>
                                <i class="fas fa-pen profile-edit-icon"></i>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="profile-label">Middle Initial</label>
                            <div class="profile-input-wrap">
                                <input asp-for="MiddleInitial" class="profile-input" placeholder="M.I." maxlength="3"/>
                                <i class="fas fa-pen profile-edit-icon"></i>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="profile-label">Staff ID</label>
                            <div class="profile-input-wrap">
                                <input asp-for="StaffId" class="profile-input" placeholder="Staff ID"
                                       readonly style="background:#f3f4f6;color:#9ca3af;cursor:not-allowed;"/>
                                <i class="fas fa-lock profile-edit-icon"></i>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="profile-label">Department</label>
                            <div class="profile-input-wrap">
                                <input asp-for="Department" class="profile-input" placeholder="e.g. Library"/>
                                <i class="fas fa-pen profile-edit-icon"></i>
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="profile-label">Email</label>
                            <div class="profile-input-wrap">
                                <input asp-for="Email" class="profile-input" placeholder="Email"/>
                                <i class="fas fa-pen profile-edit-icon"></i>
                            </div>
                        </div>

                        <!-- ASSIGNED POSITION (read-only, merged into profile) -->
                        <div class="col-12">
                            <label class="profile-label">Assigned Position</label>
                            @if (Model?.Positions != null && Model.Positions.Any())
                            {
                                <div style="display:flex;flex-wrap:wrap;gap:6px;">
                                    @foreach (var pos in Model.Positions)
                                    {
                                        <div style="background:#f3f4f6;border:1px solid #e2e8f0;border-radius:8px;
                                                    padding:9px 13px;font-size:13px;font-weight:600;color:#9ca3af;
                                                    cursor:not-allowed;display:flex;align-items:center;gap:6px;">
                                            <i class="fas fa-lock" style="font-size:11px;color:#c0c4cc;"></i>
                                            @pos
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div style="background:#f3f4f6;border:1px solid #e2e8f0;border-radius:8px;
                                            padding:9px 13px;font-size:13px;color:#c0c4cc;">
                                    <i class="fas fa-lock me-1" style="font-size:11px;"></i>No position assigned yet.
                                </div>
                            }
                        </div>

                        <div class="col-12">
                            <label class="profile-label">
                                Account Password
                                <span style="font-weight:400;color:#aaa;font-size:10px;">(leave blank to keep current)</span>
                            </label>
                            <div class="profile-input-wrap" style="position:relative;">
                                <input id="pw-field" asp-for="Password" class="profile-input"
                                       type="password" placeholder="Enter new password to change"
                                       autocomplete="new-password"/>
                                <button type="button" onclick="togglePw()"
                                        style="position:absolute;right:10px;top:50%;transform:translateY(-50%);
                                               background:none;border:none;cursor:pointer;color:#aaa;padding:0;font-size:14px;">
                                    <i class="fas fa-eye-slash" id="pw-icon"></i>
                                </button>
                            </div>
                        </div>

                    </div>

                    <div style="margin-top:20px;text-align:center;">
                        <button type="submit" class="btn-green"
                                style="padding:11px 60px;font-size:14px;letter-spacing:1px;">
                            SAVE PROFILE
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ── RIGHT COLUMN: E-Signature ── -->
    <div class="col-md-5">

        <!-- E-SIGNATURE -->
        <div style="background:white;border-radius:12px;border:1px solid #e2e8f0;overflow:hidden;margin-bottom:12px;">
            <div style="padding:14px 18px;background:var(--green);display:flex;align-items:center;gap:8px;">
                <i class="fas fa-signature" style="color:white;"></i>
                <span style="font-size:14px;font-weight:700;color:white;">E-Signature</span>
            </div>
            <div style="padding:16px;">

                <!-- MODE TOGGLE -->
                <div style="display:flex;gap:8px;margin-bottom:14px;">
                    <button id="mode-draw" onclick="switchMode('draw')"
                            style="flex:1;padding:8px;border-radius:8px;border:none;background:var(--green);color:white;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;">
                        <i class="fas fa-pen me-1"></i>Draw
                    </button>
                    <button id="mode-upload" onclick="switchMode('upload')"
                            style="flex:1;padding:8px;border-radius:8px;border:1.5px solid #dee2e6;background:white;color:#555;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;">
                        <i class="fas fa-upload me-1"></i>Upload
                    </button>
                </div>

                <!-- DRAW PANEL -->
                <div id="draw-panel">
                    <div style="font-size:11px;color:#888;margin-bottom:5px;">
                        Draw your signature using your mouse or touch:
                    </div>
                    <canvas id="sig-canvas"
                            style="width:100%;height:150px;background:#111;border-radius:10px;
                                   cursor:crosshair;display:block;touch-action:none;"></canvas>
                    <div style="display:flex;gap:8px;margin-top:8px;">
                        <button onclick="clearCanvas()"
                                style="flex:1;padding:7px;border-radius:8px;border:1.5px solid #dee2e6;
                                       background:white;color:#555;font-size:12px;font-weight:600;
                                       cursor:pointer;font-family:inherit;">
                            <i class="fas fa-eraser me-1"></i>Clear
                        </button>
                        <button onclick="saveDrawnSignature()"
                                style="flex:2;padding:7px;border-radius:8px;border:none;
                                       background:var(--green-accent);color:white;font-size:12px;
                                       font-weight:700;cursor:pointer;font-family:inherit;">
                            <i class="fas fa-check me-1"></i>Use This Signature
                        </button>
                    </div>
                </div>

                <!-- UPLOAD PANEL -->
                <div id="upload-panel" style="display:none;">
                    <div style="font-size:11px;color:#888;margin-bottom:5px;">
                        Upload a signature image (PNG transparent background recommended):
                    </div>
                    <div onclick="document.getElementById('sig-upload').click()"
                         style="border:2px dashed #dee2e6;border-radius:10px;height:120px;
                                display:flex;flex-direction:column;align-items:center;
                                justify-content:center;cursor:pointer;background:#fafafa;"
                         onmouseover="this.style.borderColor='var(--green)'"
                         onmouseout="this.style.borderColor='#dee2e6'">
                        <i class="fas fa-cloud-upload-alt" style="font-size:24px;color:#aaa;margin-bottom:6px;"></i>
                        <div style="font-size:12px;font-weight:600;color:#555;">Click to upload signature</div>
                        <div style="font-size:11px;color:#aaa;">PNG, JPG supported</div>
                    </div>
                    <input type="file" id="sig-upload" accept="image/*" style="display:none;"
                           onchange="previewUploadedSignature(this)"/>
                </div>

                <!-- SAVED SIGNATURE PREVIEW -->
                <div style="margin-top:14px;border-top:1px solid #e2e8f0;padding-top:12px;">
                    <div style="font-size:11px;font-weight:700;color:#555;margin-bottom:6px;">
                        Current Saved Signature
                    </div>
                    <div style="background:#111;border-radius:10px;height:80px;
                                display:flex;align-items:center;justify-content:center;overflow:hidden;">
                        <img id="saved-sig-preview" src="" style="display:none;max-height:100%;max-width:100%;object-fit:contain;"/>
                        <span id="saved-sig-placeholder" style="color:rgba(255,255,255,0.3);font-size:12px;">
                            No signature saved yet
                        </span>
                    </div>
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-top:8px;">
                        <span id="sig-status"
                              style="background:#f8f9fa;color:#888;border-radius:20px;
                                     padding:4px 12px;font-size:11px;font-weight:700;">
                            <i class="fas fa-clock me-1"></i>Not yet saved
                        </span>
                        <span id="sig-timestamp" style="font-size:10px;color:#aaa;"></span>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Styles {
<style>
    .profile-label      { font-size:11px; font-weight:700; color:#555; margin-bottom:5px; display:block; letter-spacing:0.3px; }
    .profile-input-wrap { position:relative; }
    .profile-input      { width:100%; border:1px solid #d1d5db; border-radius:8px; padding:10px 40px 10px 13px; font-size:13px; font-family:inherit; color:#1a1a2e; outline:none; transition:border-color 0.2s,box-shadow 0.2s; background:white; appearance:none; }
    .profile-input:focus{ border-color:#1a4731; box-shadow:0 0 0 3px rgba(26,71,49,0.1); }
    .profile-edit-icon  { position:absolute; right:12px; top:50%; transform:translateY(-50%); color:#aaa; font-size:12px; pointer-events:none; }
</style>
}

@section Scripts {
<script>
// ── PASSWORD TOGGLE ──
function togglePw() {
    const f = document.getElementById('pw-field');
    const i = document.getElementById('pw-icon');
    if (f.type === 'password') { f.type = 'text';     i.className = 'fas fa-eye'; }
    else                        { f.type = 'password'; i.className = 'fas fa-eye-slash'; }
}

// ── SIGNATURE MODE ──
function switchMode(mode) {
    const dp = document.getElementById('draw-panel');
    const up = document.getElementById('upload-panel');
    const bD = document.getElementById('mode-draw');
    const bU = document.getElementById('mode-upload');
    if (mode === 'draw') {
        dp.style.display = ''; up.style.display = 'none';
        bD.style.cssText = 'flex:1;padding:8px;border-radius:8px;border:none;background:var(--green);color:white;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;';
        bU.style.cssText = 'flex:1;padding:8px;border-radius:8px;border:1.5px solid #dee2e6;background:white;color:#555;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;';
    } else {
        dp.style.display = 'none'; up.style.display = '';
        bU.style.cssText = 'flex:1;padding:8px;border-radius:8px;border:none;background:var(--green);color:white;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;';
        bD.style.cssText = 'flex:1;padding:8px;border-radius:8px;border:1.5px solid #dee2e6;background:white;color:#555;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;';
    }
}

// ── CANVAS ──
const canvas = document.getElementById('sig-canvas');
const ctx    = canvas.getContext('2d');
let drawing = false, lastX = 0, lastY = 0;

function resizeCanvas() {
    const d = canvas.toDataURL();
    canvas.width  = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;
    const img = new Image();
    img.onload = () => ctx.drawImage(img, 0, 0);
    img.src = d;
}
window.addEventListener('resize', resizeCanvas);
resizeCanvas();

function getPos(e) {
    const r  = canvas.getBoundingClientRect();
    const sx = canvas.width  / r.width;
    const sy = canvas.height / r.height;
    return e.touches
        ? { x: (e.touches[0].clientX - r.left) * sx, y: (e.touches[0].clientY - r.top) * sy }
        : { x: (e.clientX - r.left) * sx,             y: (e.clientY - r.top) * sy };
}

function draw(e) {
    if (!drawing) return;
    const p = getPos(e);
    ctx.beginPath();
    ctx.moveTo(lastX, lastY);
    ctx.lineTo(p.x, p.y);
    ctx.strokeStyle = 'white';
    ctx.lineWidth   = 2.5;
    ctx.lineCap     = 'round';
    ctx.stroke();
    lastX = p.x; lastY = p.y;
}

canvas.addEventListener('mousedown',  e => { drawing = true; const p = getPos(e); lastX = p.x; lastY = p.y; });
canvas.addEventListener('mousemove',  draw);
canvas.addEventListener('mouseup',    () => drawing = false);
canvas.addEventListener('mouseleave', () => drawing = false);
canvas.addEventListener('touchstart', e => { e.preventDefault(); drawing = true; const p = getPos(e); lastX = p.x; lastY = p.y; }, { passive: false });
canvas.addEventListener('touchmove',  e => { e.preventDefault(); draw(e); }, { passive: false });
canvas.addEventListener('touchend',   () => drawing = false);

function clearCanvas() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
}

function saveDrawnSignature() {
    setSavedSignature(canvas.toDataURL('image/png'));
}

function previewUploadedSignature(input) {
    if (!input.files || !input.files[0]) return;
    if (input.files[0].size > 5 * 1024 * 1024) {
        alert('Image is too large. Please upload an image under 5MB.');
        input.value = '';
        return;
    }
    const reader = new FileReader();
    reader.onload = e => {
        const img = new Image();
        img.onload = () => {
            const tmp  = document.createElement('canvas');
            tmp.width  = img.naturalWidth;
            tmp.height = img.naturalHeight;
            const tCtx = tmp.getContext('2d');
            tCtx.fillStyle = '#111111';
            tCtx.fillRect(0, 0, tmp.width, tmp.height);
            tCtx.drawImage(img, 0, 0);
            const d = tCtx.getImageData(0, 0, tmp.width, tmp.height);
            for (let i = 0; i < d.data.length; i += 4) {
                d.data[i]   = 255 - d.data[i];
                d.data[i+1] = 255 - d.data[i+1];
                d.data[i+2] = 255 - d.data[i+2];
            }
            tCtx.putImageData(d, 0, 0);
            setSavedSignature(tmp.toDataURL('image/png'));
        };
        img.src = e.target.result;
    };
    reader.readAsDataURL(input.files[0]);
}

// ── SAVE SIGNATURE ──
const _csrf = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

function setSavedSignature(dataUrl) {
    const prev = document.getElementById('saved-sig-preview');
    const ph   = document.getElementById('saved-sig-placeholder');
    const st   = document.getElementById('sig-status');
    const ts   = document.getElementById('sig-timestamp');

    prev.src           = dataUrl;
    prev.style.display = '';
    ph.style.display   = 'none';
    st.innerHTML       = '<i class="fas fa-spinner fa-spin me-1"></i>Saving...';
    st.style.cssText   = 'background:#f8f9fa;color:#888;border-radius:20px;padding:4px 12px;font-size:11px;font-weight:700;';

    fetch('/Staff/SaveSignature', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': _csrf },
        body:    JSON.stringify({ signatureData: dataUrl })
    })
    .then(r => r.json())
    .then(d => {
        if (d.success) {
            st.innerHTML     = '<i class="fas fa-check-circle me-1"></i>Verified & Active';
            st.style.cssText = 'background:#e6f4ea;color:var(--green-accent);border-radius:20px;padding:4px 12px;font-size:11px;font-weight:700;';
            ts.textContent   = 'Saved at ' + new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
        } else {
            st.innerHTML     = '<i class="fas fa-exclamation-circle me-1"></i>Save failed';
            st.style.cssText = 'background:#fff5f5;color:#e53e3e;border-radius:20px;padding:4px 12px;font-size:11px;font-weight:700;';
        }
    })
    .catch(() => {
        st.innerHTML     = '<i class="fas fa-exclamation-circle me-1"></i>Save failed';
        st.style.cssText = 'background:#fff5f5;color:#e53e3e;border-radius:20px;padding:4px 12px;font-size:11px;font-weight:700;';
    });
}

// ── LOAD SAVED SIGNATURE ON PAGE LOAD ──
(function () {
    const saved = '@Html.Raw(Model?.SignatureBase64 ?? "")';
    if (saved && saved.startsWith('data:')) {
        const prev = document.getElementById('saved-sig-preview');
        const ph   = document.getElementById('saved-sig-placeholder');
        const st   = document.getElementById('sig-status');
        prev.src           = saved;
        prev.style.display = '';
        ph.style.display   = 'none';
        st.innerHTML       = '<i class="fas fa-check-circle me-1"></i>Verified & Active';
        st.style.cssText   = 'background:#e6f4ea;color:var(--green-accent);border-radius:20px;padding:4px 12px;font-size:11px;font-weight:700;';
    }
})();
</script>
}