@model OnlineClearanceSystem.Models.StaffDashboardViewModel
@{
    ViewData["Title"]      = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
    Layout = "~/Views/Shared/_StaffLayout.cshtml";
}

<div class="d-flex align-items-start justify-content-between mb-4 flex-wrap gap-3">
    <div>
         
        <p style="font-size:13px;color:#888;margin:0;"></p>
    </div>
    <div class="period-box" style="background:white;box-shadow:0 1px 4px rgba(0,0,0,0.07);">
        <div class="period-icon" style="background:#e6f4ea;">
            <i class="fas fa-calendar-alt" style="color:var(--green);"></i>
        </div>
        <div>
            <div class="period-label" style="color:#888;">Active Academic Period</div>
            <div class="period-value" style="color:var(--green);">@(Model?.ActivePeriod ?? "—")</div>
        </div>
        <span class="active-badge">Active</span>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon green"><i class="fas fa-check"></i></div>
            <div>
                <div class="stat-num">@(Model?.Approved ?? 0)</div>
                <div class="stat-label">Approved</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon orange"><i class="fas fa-clock"></i></div>
            <div>
                <div class="stat-num">@(Model?.Pending ?? 0)</div>
                <div class="stat-label">Pending</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- CHECKLIST — static -->
    <div class="col-md-5">
        <div class="page-card">
            <div class="page-card-hd dark" style="display:flex;justify-content:space-between;align-items:center;">
                <span><i class="fas fa-tasks me-2"></i>Clearance Checklist</span>
                <span id="progress-badge" style="background:var(--green-accent);border-radius:20px;padding:3px 12px;font-size:11px;font-weight:700;">0/3 Completed</span>
            </div>
            @foreach (var step in new[] {
                new { title="Step 1: Upload E-Signature", desc="Add your e-signature in your profile dashboard." },
                new { title="Step 2: Review Organization Requests", desc="Approve or decline organization/department requests." },
                new { title="Step 3: Final Review", desc="Check all entries and make corrections if needed." },
            })
            {
                <div class="checklist-item">
                    <div class="check-box"><i class="fas fa-check"></i></div>
                    <div>
                        <div class="check-title">@step.title</div>
                        <div class="check-desc">@step.desc</div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- ANNOUNCEMENTS — from DB -->
    <div class="col-md-7">
        <div class="page-card">
            <div class="page-card-hd dark">
                <div class="ann-tabs" style="margin-bottom:0;">
                    <button class="ann-tab active" onclick="filterAnn('all', this)">ALL</button>
                    <button class="ann-tab" onclick="filterAnn('Pinned', this)" style="background:var(--green);color:white;border-color:var(--green);"><i class="fas fa-thumbtack me-1"></i>PINNED</button>
                    <button class="ann-tab" onclick="filterAnn('Urgent', this)" style="background:var(--red);color:white;border-color:var(--red);">URGENT</button>
                    <button class="ann-tab" onclick="filterAnn('Event', this)" style="background:#0d6efd;color:white;border-color:#0d6efd;">EVENTS</button>
                </div>
            </div>
            <div id="ann-list" style="padding:16px;">
                @if (Model?.Announcements != null && Model.Announcements.Any())
                {
                    @foreach (var ann in Model.Announcements)
                    {
                        <div class="ann-card mb-3" data-tag="@ann.Type.ToLower()">
                            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <div class="ann-avatar">SA</div>
                                    <div>
                                        <div style="font-weight:700;font-size:13px;">System Administrator</div>
                                        <div style="font-size:11px;color:#888;">@ann.Date</div>
                                    </div>
                                </div>
                                <span class="ann-tag" style="background:#f3f4f6;color:#555;">@ann.Type</span>
                            </div>
                            <div class="ann-title">@ann.Title</div>
                            <div class="ann-body">@ann.Content</div>
                        </div>
                    }
                }
                else
                {
                    <div style="text-align:center;padding:40px 24px;color:#888;">
                        <i class="fas fa-bullhorn" style="font-size:32px;color:#ddd;display:block;margin-bottom:12px;"></i>
                        <div style="font-size:14px;font-weight:600;color:#aaa;">No announcements yet</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.querySelectorAll('.check-box').forEach(box => {
        box.addEventListener('click', () => { box.classList.toggle('active'); updateProgress(); });
    });
    function updateProgress() {
        const t = document.querySelectorAll('.check-box').length;
        const c = document.querySelectorAll('.check-box.active').length;
        document.getElementById('progress-badge').textContent = `${c}/${t} Completed`;
    }
    updateProgress();

    function filterAnn(tag, btn) {
        document.querySelectorAll('.ann-tab').forEach(b => { b.style.background='white'; b.style.color='#555'; b.style.borderColor='#dee2e6'; });
        btn.style.background='#28a745'; btn.style.color='white'; btn.style.borderColor='#28a745';
        document.querySelectorAll('#ann-list [data-tag]').forEach(c => {
            c.style.display = tag === 'all' ? '' : (c.getAttribute('data-tag')||'').toLowerCase().includes(tag.toLowerCase()) ? '' : 'none';
        });
    }
</script>
}