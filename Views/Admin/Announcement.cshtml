@{
    ViewData["Title"]      = "Announcement";
    ViewData["ActivePage"] = "Announcement";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-title">Announcement</div>

<!-- COMPOSE FORM -->
<div class="ann-compose mb-4">
    <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
        <div style="width:44px;height:44px;border-radius:50%;background:#4299e1;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:16px;flex-shrink:0;">A</div>
        <div style="font-size:15px;font-weight:700;flex:1;">Admin</div>
        <div style="display:flex;align-items:center;gap:8px;">
            <div style="background:rgba(40,167,69,0.15);border:1px solid rgba(40,167,69,0.4);border-radius:20px;padding:4px 14px;font-size:11px;font-weight:700;color:#68d391;">
                <i class="fas fa-circle me-1"></i>CEBU TECHNOLOGICAL UNIVERSITY OF GINATILAN
            </div>
        </div>
        <div class="position-relative" style="min-width:160px;">
            <select class="dark-input dark-select" id="ann-type" style="padding:8px 36px 8px 12px;font-size:12px;font-weight:700;">
                <option value="GENERAL">GENERAL</option>
                <option value="URGENT">URGENT</option>
                <option value="EVENT">EVENT</option>
                <option value="REMINDER">REMINDER</option>
            </select>
        </div>
    </div>

    <input type="text" class="dark-input mb-2" id="ann-title" placeholder="Title" />
    <textarea class="dark-input mb-3" id="ann-body" rows="3" placeholder="Write an announcement to students and instructors..."></textarea>

    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div class="d-flex gap-3">
            <button style="background:none;border:none;color:var(--muted);font-size:18px;cursor:pointer;" title="Schedule"><i class="fas fa-calendar-alt"></i></button>
            <button style="background:none;border:none;color:var(--muted);font-size:18px;cursor:pointer;" title="Location"><i class="fas fa-map-marker-alt"></i></button>
        </div>
        <div class="d-flex align-items-center gap-3">
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;color:var(--muted);">
                <input type="checkbox" id="pin-post" style="accent-color:var(--green);width:16px;height:16px;" />
                Pin post
            </label>
            <button class="btn-blue-sm" onclick="postAnnouncement()">Post Announcement</button>
        </div>
    </div>
</div>

<!-- FILTER TABS -->
<div class="d-flex gap-2 mb-4 flex-wrap">
    <button class="ann-filter-btn active" onclick="filterAnn('all',this)">ALL</button>
    <button class="ann-filter-btn" onclick="filterAnn('pinned',this)"  style="border-color:rgba(66,153,225,0.4);color:#63b3ed;"><i class="fas fa-thumbtack me-1"></i>PINNED</button>
    <button class="ann-filter-btn" onclick="filterAnn('urgent',this)"  style="border-color:rgba(229,62,62,0.4);color:#fc8181;">URGENT</button>
    <button class="ann-filter-btn" onclick="filterAnn('event',this)"   style="border-color:rgba(40,167,69,0.4);color:#68d391;">EVENTS</button>
    <button class="ann-filter-btn" onclick="filterAnn('general',this)" style="border-color:rgba(128,90,213,0.4);color:#b794f4;">GENERAL</button>
</div>

<!-- EDIT MODAL -->
<div id="edit-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:9999;align-items:center;justify-content:center;">
    <div style="background:var(--card);border:1px solid var(--border);border-radius:14px;padding:28px;width:100%;max-width:520px;margin:16px;">
        <div style="font-size:15px;font-weight:700;margin-bottom:16px;color:var(--text);">
            <i class="fas fa-pen me-2" style="color:#4299e1;"></i>Edit Announcement
        </div>
        <input  type="text" class="dark-input mb-2" id="edit-title" placeholder="Title" />
        <textarea class="dark-input mb-2" id="edit-body" rows="4" placeholder="Body"></textarea>
        <div class="position-relative mb-3" style="max-width:200px;">
            <select class="dark-input dark-select" id="edit-type" style="padding:8px 36px 8px 12px;font-size:12px;font-weight:700;">
                <option value="GENERAL">GENERAL</option>
                <option value="URGENT">URGENT</option>
                <option value="EVENT">EVENT</option>
                <option value="REMINDER">REMINDER</option>
            </select>
        </div>
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;color:var(--muted);margin-bottom:20px;">
            <input type="checkbox" id="edit-pin" style="accent-color:var(--green);width:16px;height:16px;" />
            Pin post
        </label>
        <div class="d-flex justify-content-end gap-2">
            <button onclick="closeEdit()"
                    style="background:rgba(255,255,255,0.07);border:1px solid var(--border);color:var(--muted);border-radius:8px;padding:7px 18px;font-size:12px;cursor:pointer;">
                Cancel
            </button>
            <button class="btn-blue-sm" onclick="saveEdit()">
                <i class="fas fa-save me-1"></i>Save Changes
            </button>
        </div>
    </div>
</div>

<!-- DELETE CONFIRM MODAL -->
<div id="delete-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:9999;align-items:center;justify-content:center;">
    <div style="background:var(--card);border:1px solid var(--border);border-radius:14px;padding:28px;width:100%;max-width:400px;margin:16px;text-align:center;">
        <div style="width:56px;height:56px;border-radius:50%;background:rgba(229,62,62,0.12);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
            <i class="fas fa-trash" style="font-size:22px;color:#fc8181;"></i>
        </div>
        <div style="font-size:15px;font-weight:700;margin-bottom:8px;">Delete Announcement?</div>
        <div style="font-size:13px;color:var(--muted);margin-bottom:24px;">This action cannot be undone. The announcement will be permanently removed.</div>
        <div class="d-flex justify-content-center gap-3">
            <button onclick="closeDelete()"
                    style="background:rgba(255,255,255,0.07);border:1px solid var(--border);color:var(--muted);border-radius:8px;padding:8px 22px;font-size:13px;cursor:pointer;">
                Cancel
            </button>
            <button onclick="confirmDelete()"
                    style="background:#e53e3e;border:none;color:white;border-radius:8px;padding:8px 22px;font-size:13px;font-weight:700;cursor:pointer;">
                <i class="fas fa-trash me-1"></i>Delete
            </button>
        </div>
    </div>
</div>

<!-- ANNOUNCEMENTS LIST -->
<div id="ann-list"></div>

<!-- EMPTY STATE — shown when no announcements -->
<div id="ann-empty" style="padding:64px 24px;text-align:center;">
    <div style="width:72px;height:72px;border-radius:50%;background:rgba(66,153,225,0.10);display:flex;align-items:center;justify-content:center;margin:0 auto 18px;">
        <i class="fas fa-bullhorn" style="font-size:30px;color:#4299e1;opacity:0.6;"></i>
    </div>
    <div style="font-size:15px;font-weight:700;color:var(--text);margin-bottom:8px;">No Announcements Yet</div>
    <div style="font-size:13px;color:var(--muted);max-width:380px;margin:0 auto;line-height:1.6;">
        Announcements will appear here once they are posted.
        Use the compose form above to create your first announcement.
    </div>
</div>

@section Scripts {
<script>
    let announcements = [];
let editingId     = null;
let deletingId    = null;

const tagMap = {
    general:'tag-general', urgent:'tag-urgent',
    event:'tag-event',     reminder:'tag-reminder'
};

// ── Load from DB ──────────────────────────────────
async function loadAnnouncements() {
    try {
        const res  = await fetch('/api/admin/announcements');
        announcements = await res.json();
        renderAll();
    } catch { renderAll(); }
}

function renderAll() {
    const list  = document.getElementById('ann-list');
    const empty = document.getElementById('ann-empty');
    list.innerHTML = '';
    if (announcements.length === 0) { empty.style.display = 'block'; return; }
    empty.style.display = 'none';
    const sorted = [...announcements].sort((a, b) => {
        if (a.pinned !== b.pinned) return a.pinned ? -1 : 1;
        return b.id - a.id;
    });
    sorted.forEach(a => list.insertAdjacentHTML('beforeend', buildCard(a)));
}

function buildCard(a) {
    const type   = (a.type || 'general').toLowerCase();
    const pinTag = a.pinned ? `<span class="ann-tag tag-pinned me-1"><i class="fas fa-thumbtack me-1"></i>Pinned</span>` : '';
    const tags   = `${type}${a.pinned ? ' pinned' : ''}`;
    return `
    <div class="ann-post-card" data-tag="${tags}" data-id="${a.id}">
        <div class="d-flex align-items-center justify-content-between mb-2 flex-wrap gap-2">
            <div class="d-flex align-items-center gap-10">
                <div style="width:38px;height:38px;border-radius:50%;background:#4299e1;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:14px;margin-right:10px;">A</div>
                <div>
                    <div style="font-weight:700;font-size:13px;">Admin</div>
                    <div style="font-size:11px;color:var(--muted);">System Administrator</div>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2">
                ${pinTag}
                <span class="ann-tag ${tagMap[type] ?? 'tag-general'}">${type.toUpperCase()}</span>
                <span style="font-size:11px;color:var(--muted);">${a.date}</span>
            </div>
        </div>
        <div style="font-size:15px;font-weight:700;margin-bottom:8px;">${escHtml(a.title)}</div>
        <div style="font-size:13px;color:rgba(255,255,255,0.75);line-height:1.7;white-space:pre-wrap;">${escHtml(a.body)}</div>
        <div class="d-flex justify-content-end gap-2 mt-3">
            <button class="btn-blue-sm" style="font-size:12px;padding:6px 16px;" onclick="openEdit(${a.id})">
                <i class="fas fa-pen me-1"></i>Edit
            </button>
            <button style="background:#e53e3e;border:none;color:white;border-radius:8px;padding:6px 16px;font-size:12px;font-weight:700;cursor:pointer;" onclick="openDelete(${a.id})">
                <i class="fas fa-trash me-1"></i>Delete
            </button>
        </div>
    </div>`;
}

async function postAnnouncement() {
    const title  = document.getElementById('ann-title').value.trim();
    const body   = document.getElementById('ann-body').value.trim();
    const type   = document.getElementById('ann-type').value;
    const pinned = document.getElementById('pin-post').checked;
    if (!title || !body) { alert('Please enter a title and body.'); return; }
    try {
        const res  = await fetch('/api/admin/announcements', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title, body, type, pinned })
        });
        const data = await res.json();
        if (data.success) {
            announcements.unshift({
                id: data.id, title, body, type, pinned,
                date: new Date().toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})
            });
            renderAll();
            document.getElementById('ann-title').value  = '';
            document.getElementById('ann-body').value   = '';
            document.getElementById('pin-post').checked = false;
        }
    } catch (e) { alert('Error: ' + e.message); }
}

function openEdit(id) {
    const a = announcements.find(x => x.id === id);
    if (!a) return;
    editingId = id;
    document.getElementById('edit-title').value = a.title;
    document.getElementById('edit-body').value  = a.body;
    document.getElementById('edit-type').value  = a.type;
    document.getElementById('edit-pin').checked = a.pinned;
    showModal('edit-modal');
}

function closeEdit() { hideModal('edit-modal'); editingId = null; }

async function saveEdit() {
    const a = announcements.find(x => x.id === editingId);
    if (!a) return;
    a.title  = document.getElementById('edit-title').value.trim();
    a.body   = document.getElementById('edit-body').value.trim();
    a.type   = document.getElementById('edit-type').value;
    a.pinned = document.getElementById('edit-pin').checked;
    if (!a.title || !a.body) { alert('Title and body cannot be empty.'); return; }
    try {
        await fetch(`/api/admin/announcements/${editingId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title: a.title, body: a.body, type: a.type, pinned: a.pinned })
        });
    } catch { }
    closeEdit();
    renderAll();
}

function openDelete(id) { deletingId = id; showModal('delete-modal'); }
function closeDelete() { hideModal('delete-modal'); deletingId = null; }

async function confirmDelete() {
    try {
        await fetch(`/api/admin/announcements/${deletingId}`, { method: 'DELETE' });
        announcements = announcements.filter(x => x.id !== deletingId);
    } catch { }
    closeDelete();
    renderAll();
}

function filterAnn(tag, btn) {
    document.querySelectorAll('.ann-filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('#ann-list .ann-post-card').forEach(c => {
        c.style.display = tag === 'all' ? '' : (c.dataset.tag || '').includes(tag) ? '' : 'none';
    });
}

function showModal(id) {
    const m = document.getElementById(id);
    m.style.display = 'flex';
    m.onclick = e => { if (e.target === m) id === 'edit-modal' ? closeEdit() : closeDelete(); };
}

function hideModal(id) { document.getElementById(id).style.display = 'none'; }

function escHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

loadAnnouncements();
    // Initial render (empty)
    renderAll();
</script>
}