let currentSubFilter = 'all';
function subFilter(f) {
    currentSubFilter = f;
    ['all','cleared','pending'].forEach(x =>
        document.getElementById('sf-' + x)?.classList.toggle('active', x === f)
    );
    renderStudentRows(f);
}

function renderStudentRows(f) {
    let list = students;
    if (f === 'cleared') list = students.filter(s => s.cs === 'Cleared');
    if (f === 'pending') list = students.filter(s => s.cs !== 'Cleared');

    const tbody = document.getElementById('student-tbody');
    const empty = document.getElementById('student-empty');
    if (!tbody) return;

    if (!list.length) {
        tbody.innerHTML = '';
        if (empty) empty.style.display = 'block';
        return;
    }
    if (empty) empty.style.display = 'none';

    tbody.innerHTML = list.map((s, i) => `
        <tr>
            <td style="color:var(--muted);">${String(i+1).padStart(2,'0')}</td>
            <td>
                <div class="d-flex align-items-center gap-2">
                    <div class="user-avatar-sm" style="background:#9f7aea;">${escHtml(s.name.charAt(0))}</div>
                    <span style="font-weight:600;font-size:13px;">${escHtml(s.name)}</span>
                </div>
            </td>
            <td style="color:var(--muted);">${escHtml(s.idNum || '—')}</td>
            <td>${escHtml(s.course || '—')}</td>
            <td style="color:var(--muted);">${s.year || '—'}</td>
            <td style="color:var(--muted);">${escHtml(s.section || '—')}</td>
            <td>
                ${s.cs === 'Cleared'
                    ? `<span style="${badgeStyle('#38a169','rgba(56,161,105,0.15)')}"><i class="fas fa-check-circle me-1"></i>Cleared</span>`
                    : `<span style="${badgeStyle('#f6ad55','rgba(246,173,85,0.15)')}"><i class="fas fa-clock me-1"></i>Pending</span>`}
            </td>
            <td>
                <button onclick="viewUser(${s.id},'Student')" style="${btnStyle('#9f7aea')}">
                    <i class="fas fa-eye me-1"></i>View
                </button>
            </td>
        </tr>`).join('');
}

