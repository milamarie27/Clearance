                <td><span style="${badgeStyle('#0d9488','rgba(13,148,136,0.15)')}">${escHtml(p.pos)}</span></td>
                <td><span style="${badgeStyle('#68d391','rgba(56,161,105,0.15)')}">${p.approved ?? 0}</span></td>
                <td><span style="${badgeStyle('#f6e05e','rgba(236,201,75,0.15)')}">${p.pending  ?? 0}</span></td>
