        : `<tr><td colspan="4" style="text-align:center;color:var(--muted);padding:28px 0;font-size:12px;">
               <i class="fas fa-id-badge" style="display:block;font-size:22px;opacity:0.25;margin-bottom:8px;"></i>
               No positions assigned yet.</td></tr>`;

    document.getElementById('vm-body').innerHTML = `
        ${vmProfileCard([
            { label:'ID Number', value: staff.id_number || '—' }
