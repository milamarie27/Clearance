//  STAFF TABLE
// ══════════════════════════════════════════════════════════════════════════════
function renderStaffTable() {
    const panel = document.getElementById('main-panel');

    if (!staffList.length) {
        panel.innerHTML = emptyState('fa-user-tie', 'No Staff Registered Yet', 'Staff accounts will appear here once registered.');
        return;
    }

    const rows = staffList.map(s => {
        const assigned = staffPositions.find(p => p.name === s.name);
        return { ...s, posLabel: assigned ? assigned.pos : null, approved: assigned?.approved ?? 0, pending: assigned?.pending ?? 0 };
    });

    panel.innerHTML = `
        <div class="panel-hd">
            <span class="panel-hd-title"><i class="fas fa-user-tie me-2"></i>Staff & Admin</span>
            <div class="d-flex gap-2">
                <div class="search-wrap">
                    <i class="fas fa-search"></i>
                    <input class="search-input" placeholder="Search name, ID..."
                           oninput="filterTable(this,'staff-table')" />
                </div>
                <button class="btn-blue-sm" onclick="openStaffAssign()">
                    <i class="fas fa-id-badge me-1"></i>Assign Positions
                </button>
            </div>
        </div>
        <div class="table-responsive">
            <table class="data-table" id="staff-table">
                <thead>
                    <tr>
                        <th>#</th><th>Name</th><th>ID Number</th>
                        <th>Position</th><th>Approved</th><th>Pending</th><th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    ${rows.map((s, i) => `
                        <tr>
                            <td style="color:var(--muted);">${String(i+1).padStart(2,'0')}</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="user-avatar-sm" style="background:#0d9488;">${escHtml(s.name.charAt(0))}</div>
                                    <span style="font-weight:600;font-size:13px;">${escHtml(s.name)}</span>
                                </div>
                            </td>
                            <td style="color:var(--muted);font-size:12px;">${escHtml(s.id_number || '—')}</td>
                            <td>
                                ${s.posLabel
                                    ? `<span style="${badgeStyle('#0d9488','rgba(13,148,136,0.15)')};">${escHtml(s.posLabel)}</span>`
                                    : `<span style="color:var(--muted);font-size:12px;">—</span>`}
                            </td>
                            <td><span style="${badgeStyle('#68d391','rgba(56,161,105,0.15)');}">${s.approved}</span></td>
                            <td><span style="${badgeStyle('#f6e05e','rgba(236,201,75,0.15)');}">${s.pending}</span></td>
                            <td><span style="${badgeStyle('#38a169','rgba(56,161,105,0.15)')}">Active</span></td>
                        </tr>`).join('')}
                </tbody>
            </table>
        </div>`;
