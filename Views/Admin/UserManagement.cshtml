//  INSTRUCTOR ASSIGN — SEARCH DROPDOWN
// ══════════════════════════════════════════════════════════════════════════════
function filterInstDD(q) {
    const dd = document.getElementById('ia-dropdown');
    if (!dd) return;
    const term = q.toLowerCase().trim();
    const hits = instructors.filter(i =>
        term === '' || i.name.toLowerCase().includes(term) ||
        (i.employeeId ?? '').toLowerCase().includes(term)
    ).slice(0, 8);

    dd.innerHTML = hits.length === 0
        ? `<div style="padding:12px 16px;font-size:12px;color:var(--muted);text-align:center;">No instructors found.</div>`
        : hits.map(i => `
            <div onclick="selectInst(${i.id})"
                 style="padding:10px 14px;cursor:pointer;border-bottom:1px solid var(--border);
                        display:flex;align-items:center;gap:10px;transition:background 0.15s;"
                 onmouseover="this.style.background='rgba(66,153,225,0.08)'"
                 onmouseout="this.style.background=''">
                <div class="user-avatar-sm" style="background:#4299e1;flex-shrink:0;">${escHtml(i.name.charAt(0))}</div>
                <div>
                    <div style="font-size:13px;font-weight:600;color:var(--text);">${escHtml(i.name)}</div>
                    <div style="font-size:11px;color:var(--muted);">EID: ${escHtml(i.employeeId ?? '—')}</div>
                </div>
            </div>`).join('');
    dd.style.display = 'block';
}

function selectInst(id) {
    selectedInstructor = instructors.find(i => i.id === id);
    if (!selectedInstructor) return;
    document.getElementById('ia-dropdown').style.display = 'none';
    document.getElementById('ia-search').value           = '';
    document.getElementById('ia-pill-av').textContent    = selectedInstructor.name.charAt(0);
    document.getElementById('ia-pill-name').textContent  = selectedInstructor.name;
    document.getElementById('ia-pill-meta').textContent  = `EID: ${selectedInstructor.employeeId ?? '—'}`;
    document.getElementById('ia-pill').style.display     = 'flex';
}

function clearInstSelection() {
    selectedInstructor = null;
    document.getElementById('ia-pill').style.display   = 'none';
    document.getElementById('ia-search').value         = '';
    document.getElementById('ia-dropdown').style.display = 'none';
}

document.addEventListener('click', e => {
    const dd    = document.getElementById('ia-dropdown');
    const input = document.getElementById('ia-search');
    if (dd && input && !dd.contains(e.target) && e.target !== input)
        dd.style.display = 'none';
});

// ══════════════════════════════════════════════════════════════════════════════
//  INSTRUCTOR ASSIGN — POSITION EXTRAS
// ══════════════════════════════════════════════════════════════════════════════
function toggleIAExtras(val) {
    const wrap   = document.getElementById('ia-section-wrap');
    const custom = document.getElementById('ia-pos-custom');
    if (wrap)   wrap.style.display   = val === 'Class Adviser' ? 'block' : 'none';
    if (custom) custom.style.display = val === '__custom__'    ? 'block' : 'none';
    if (custom && val !== '__custom__') custom.value = '';
    if (val === 'Class Adviser') iaPopulateCourses();
}

function iaPopulateCourses() {
    const sel      = document.getElementById('ia-ca-course');
    if (!sel) return;
    const takenIds = new Set(orgSignatories.filter(s => s.pos === 'Class Adviser' && s.curriculumId).map(s => s.curriculumId));
    const available= curriculums.filter(c => !takenIds.has(c.id));
    const courses  = [...new Set(available.map(c => c.courseCode))].sort();
    sel.innerHTML  = `<option value="" disabled selected>— Select Course —</option>`;
    courses.forEach(code => { const o = document.createElement('option'); o.value = o.textContent = code; sel.appendChild(o); });
    document.getElementById('ia-ca-year').innerHTML    = `<option value="" disabled selected>— Year —</option>`;
    document.getElementById('ia-ca-section').innerHTML = `<option value="" disabled selected>— Section —</option>`;
}

function iaFilterYear() {
    const course   = document.getElementById('ia-ca-course')?.value;
    const yearSel  = document.getElementById('ia-ca-year');
    if (!yearSel) return;
    const takenIds = new Set(orgSignatories.filter(s => s.pos === 'Class Adviser' && s.curriculumId).map(s => s.curriculumId));
    const avail    = curriculums.filter(c => (!course || c.courseCode === course) && !takenIds.has(c.id));
    const years    = [...new Set(avail.map(c => c.yearLevel))].sort((a, b) => a - b);
    yearSel.innerHTML = `<option value="" disabled selected>— Year —</option>`;
    years.forEach(y => {
        const lbl = y == 1 ? '1st Year' : y == 2 ? '2nd Year' : y == 3 ? '3rd Year' : '4th Year';
        const o   = document.createElement('option'); o.value = y; o.textContent = lbl; yearSel.appendChild(o);
    });
    document.getElementById('ia-ca-section').innerHTML = `<option value="" disabled selected>— Section —</option>`;
}

function iaFilterSection() {
    const course   = document.getElementById('ia-ca-course')?.value;
    const year     = document.getElementById('ia-ca-year')?.value;
    const secSel   = document.getElementById('ia-ca-section');
    if (!secSel) return;
    const takenIds = new Set(orgSignatories.filter(s => s.pos === 'Class Adviser' && s.curriculumId).map(s => s.curriculumId));
    const avail    = curriculums.filter(c =>
        (!course || c.courseCode === course) &&
        (!year   || String(c.yearLevel) === String(year)) &&
        !takenIds.has(c.id)
    );
    secSel.innerHTML = `<option value="" disabled selected>— Section —</option>`;
    avail.forEach(c => {
        const o = document.createElement('option'); o.value = c.id; o.textContent = c.section; secSel.appendChild(o);
    });
    iaUpdatePreview();
}

function iaUpdatePreview() {
    const preview = document.getElementById('ia-ca-preview');
    if (!preview) return;
    const secSel  = document.getElementById('ia-ca-section');
    const selected= curriculums.find(c => String(c.id) === String(secSel?.value));
    preview.textContent = selected ? selected.section : '—';
}

// ══════════════════════════════════════════════════════════════════════════════
//  ADD / REMOVE — ORG SIGNATORIES (Instructor)
// ══════════════════════════════════════════════════════════════════════════════
async function addOrgSignatory() {
    if (!selectedInstructor) { alert('Please select an instructor first.'); return; }
    const posSel = document.getElementById('ia-pos')?.value;
    if (!posSel) { alert('Please select a position.'); return; }

    if (posSel === 'Class Adviser') {
        const courseVal    = document.getElementById('ia-ca-course')?.value;
        const yearVal      = document.getElementById('ia-ca-year')?.value;
        const secSel       = document.getElementById('ia-ca-section');
        const curriculumId = secSel?.value;
        if (!courseVal)    { alert('Please select a course.');     return; }
        if (!yearVal)      { alert('Please select a year level.'); return; }
        if (!curriculumId) { alert('Please select a section.');    return; }
        try {
            const res  = await fetch('/api/admin/org-signatories', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId: selectedInstructor.id, pos: 'Class Adviser', curriculumId: parseInt(curriculumId) })
            });
            const data = await res.json();
            if (data.success) {
                await loadOrgSignatories();
                renderAssignedSignatories();
                iaPopulateCourses();
                clearInstSelection();
                if (document.getElementById('ia-pos')) document.getElementById('ia-pos').value = '';
                document.getElementById('ia-section-wrap').style.display = 'none';
            } else { alert('Error: ' + (data.error ?? 'Unknown')); }
        } catch (e) { alert('Error: ' + e.message); }
        return;
    }

    let pos = posSel === '__custom__'
        ? (document.getElementById('ia-pos-custom')?.value.trim() || '')
        : posSel.trim();
    if (!pos) { alert('Please type a custom position.'); return; }

    const dup = orgSignatories.find(s => s.userId === selectedInstructor.id && s.pos === pos);
    if (dup) { alert('This instructor already has this exact position assigned.'); return; }

    try {
        const res  = await fetch('/api/admin/org-signatories', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: selectedInstructor.id, pos })
        });
        const data = await res.json();
        if (data.success) {
            orgSignatories.push({ id: data.id, userId: selectedInstructor.id,
                name: selectedInstructor.name, eid: selectedInstructor.employeeId,
                pos, curriculumId: null, courseCode: '', yearLevel: '', section: '' });
            renderAssignedSignatories();
            clearInstSelection();
            if (document.getElementById('ia-pos'))        document.getElementById('ia-pos').value = '';
            if (document.getElementById('ia-pos-custom')) { document.getElementById('ia-pos-custom').value = ''; document.getElementById('ia-pos-custom').style.display = 'none'; }
        } else { alert('Error: ' + (data.error ?? 'Unknown')); }
    } catch (e) { alert('Error: ' + e.message); }
}

async function removeOrgSignatory(id) {
    if (!confirm('Remove this signatory?')) return;
    try {
        const res  = await fetch(`/api/admin/org-signatories/${id}`, { method: 'DELETE' });
        const data = await res.json();
        if (data.success) {
            orgSignatories = orgSignatories.filter(s => s.id !== id);
            renderAssignedSignatories();
            if (document.getElementById('ia-section-wrap')?.style.display === 'block') iaPopulateCourses();
        } else { alert('Error: ' + (data.error ?? 'Unknown')); }
    } catch (e) { alert('Error: ' + e.message); }
}

function renderAssignedSignatories() {
    const tbody = document.getElementById('assign-tbody');
    const empty = document.getElementById('assign-empty');
    if (!tbody) return;
    tbody.innerHTML = '';
    if (!orgSignatories.length) { empty.style.display = 'block'; return; }
    empty.style.display = 'none';

    orgSignatories.forEach((s, i) => {
        let posDisplay = '';
        if (s.pos === 'Class Adviser' && s.courseCode) {
            const yl = s.yearLevel == 1 ? '1st' : s.yearLevel == 2 ? '2nd' : s.yearLevel == 3 ? '3rd' : s.yearLevel + 'th';
            posDisplay = `<span style="${badgeStyle('#38a169','rgba(56,161,105,0.12)')}">Class Adviser</span>
                <div style="font-size:11px;color:var(--muted);margin-top:4px;">
                    <i class="fas fa-layer-group me-1" style="color:#4299e1;"></i>
                    ${escHtml(s.courseCode)} · ${yl} Year · ${escHtml(s.section)}
                </div>`;
        } else {
            posDisplay = `<span style="${badgeStyle('#4299e1','rgba(66,153,225,0.12)')}">${escHtml(s.pos)}</span>`;
        }
        const row = document.createElement('tr');
        row.innerHTML = `
            <td style="color:var(--muted);">${String(i+1).padStart(2,'0')}</td>
            <td>
                <div class="d-flex align-items-center gap-2">
                    <div class="user-avatar-sm" style="background:#4299e1;">${escHtml(s.name.charAt(0))}</div>
                    <span style="font-weight:600;">${escHtml(s.name)}</span>
                </div>
            </td>
            <td style="color:var(--muted);">${escHtml(s.eid ?? '—')}</td>
            <td>${posDisplay}</td>
            <td>
                <button onclick="removeOrgSignatory(${s.id})" style="${btnStyle('#e53e3e','rgba(229,62,62,0.12)')}">
                    <i class="fas fa-trash-alt me-1"></i>Remove
                </button>
            </td>`;
        tbody.appendChild(row);
    });
}

// ══════════════════════════════════════════════════════════════════════════════
//  ADD / REMOVE — STAFF POSITIONS
// ══════════════════════════════════════════════════════════════════════════════
async function addStaffPosition() {
    const staffSel = document.getElementById('sp-staff');
    const posSel   = document.getElementById('sp-pos');
    const staffId  = staffSel?.value;
    const pos      = posSel?.value;
    const name     = staffSel?.options[staffSel.selectedIndex]?.textContent ?? '';
    if (!staffId || !pos) { alert('Please select a staff member and a position.'); return; }
    try {
        const res  = await fetch('/api/admin/staff-positions', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ staffId: parseInt(staffId), eid: '', pos })
        });
        const data = await res.json();
        if (data.success) {
            staffPositions.push({ id: data.id, name, eid: '—', pos, approved: 0, pending: 0 });
            renderAssignedPositions();
            renderStaffTable();
            if (staffSel) staffSel.value = '';
            if (posSel)   posSel.value   = '';
        } else { alert(data.error || 'Failed.'); }
    } catch (e) { alert('Error: ' + e.message); }
}

async function removeStaffPosition(id) {
    if (!confirm('Remove this position assignment?')) return;
    try {
        await fetch(`/api/admin/staff-positions/${id}`, { method: 'DELETE' });
        staffPositions = staffPositions.filter(p => p.id !== id);
        renderAssignedPositions();
        renderStaffTable();
    } catch {}
}

function renderAssignedPositions() {
    const tbody = document.getElementById('assign-tbody');
    const empty = document.getElementById('assign-empty');
    if (!tbody) return;
    tbody.innerHTML = '';
    if (!staffPositions.length) { empty.style.display = 'block'; return; }
    empty.style.display = 'none';

    staffPositions.forEach((p, i) => {
        const row = document.createElement('tr');
        row.innerHTML = `
            <td style="color:var(--muted);">${String(i+1).padStart(2,'0')}</td>
            <td>
                <div class="d-flex align-items-center gap-2">
                    <div class="user-avatar-sm" style="background:#0d9488;">${escHtml(p.name.charAt(0))}</div>
                    <span style="font-weight:600;font-size:13px;">${escHtml(p.name)}</span>
                </div>
            </td>
            <td><span style="${badgeStyle('#0d9488','rgba(13,148,136,0.15)')}">${escHtml(p.pos)}</span></td>
            <td>
                <span style="${badgeStyle('#68d391','rgba(56,161,105,0.15)')}">${p.approved ?? 0} Approved</span>
                &nbsp;
                <span style="${badgeStyle('#f6e05e','rgba(236,201,75,0.15)')}">${p.pending ?? 0} Pending</span>
            </td>
            <td>
                <button onclick="removeStaffPosition(${p.id})" style="${btnStyle('#e53e3e','rgba(229,62,62,0.12)')}">
                    <i class="fas fa-trash-alt me-1"></i>Remove
                </button>
            </td>`;
        tbody.appendChild(row);
    });
}

// ══════════════════════════════════════════════════════════════════════════════
//  HELPERS
// ══════════════════════════════════════════════════════════════════════════════
function roleColor(role) {
    return { Student: '#9f7aea', Instructor: '#4299e1', Staff: '#0d9488' }[role] || '#718096';
}
function roleColorBg(role) {
    return { Student: 'rgba(159,122,234,0.15)', Instructor: 'rgba(66,153,225,0.15)', Staff: 'rgba(13,148,136,0.15)' }[role] || 'rgba(113,128,150,0.15)';
}
function badgeStyle(color, bg) {
    return `background:${bg};color:${color};padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;`;
}
function btnStyle(color, bg = color + '22') {
    return `background:${bg};border:none;color:${color};border-radius:6px;padding:5px 12px;font-size:12px;font-weight:600;cursor:pointer;`;
}
function emptyState(icon, title, sub) {
    return `<div style="padding:56px 24px;text-align:center;">
        <div style="width:72px;height:72px;border-radius:50%;background:rgba(66,153,225,0.10);
                    display:flex;align-items:center;justify-content:center;margin:0 auto 18px;">
            <i class="fas ${icon}" style="font-size:30px;color:#4299e1;opacity:0.7;"></i>
        </div>
        <div style="font-size:15px;font-weight:700;color:var(--text);margin-bottom:8px;">${title}</div>
        <div style="font-size:13px;color:var(--muted);">${sub}</div>
    </div>`;
}
function filterTable(input, id) {
    const q = input.value.toLowerCase();
    document.querySelectorAll('#' + id + ' tbody tr').forEach(r =>
        r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none'
    );
}
function escHtml(str) {
    return String(str ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

init();
</script>
}
