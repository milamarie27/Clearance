async function viewUser(id, role) {
    const modal = document.getElementById('view-modal');
    modal.style.display = 'flex';
    document.getElementById('vm-name').textContent     = 'Loading…';
    document.getElementById('vm-avatar').textContent   = '?';
    document.getElementById('vm-role-badge').innerHTML = '';
    document.getElementById('vm-body').innerHTML       = vmLoadingHtml();

    if      (role === 'Student')    await vmLoadStudent(id);
    else if (role === 'Instructor') await vmLoadInstructor(id);
    else if (role === 'Staff')           vmLoadStaff(id);
}

function closeViewModal() {
    document.getElementById('view-modal').style.display = 'none';
}

document.getElementById('view-modal').addEventListener('click', function(e) {
    if (e.target === this) closeViewModal();
});

// ── Student view ─────────────────────────────────────────────────────────────
async function vmLoadStudent(id) {
    const student = students.find(s => s.id === id);
    if (!student) return;

    document.getElementById('vm-name').textContent        = student.name;
    document.getElementById('vm-avatar').textContent      = student.name.charAt(0);
    document.getElementById('vm-avatar').style.background = '#9f7aea';
    document.getElementById('vm-role-badge').innerHTML    =
        `<span style="${badgeStyle('#c4a3fb','rgba(159,122,234,0.25)')}">
            <i class="fas fa-user-graduate me-1"></i>Student
         </span>`;

    let data = { subjects: [], orgs: [] };
    try {
        const res = await fetch(`/api/admin/students/${id}/clearance`);
        data = await res.json();
    } catch {}

    if (data.error) { document.getElementById('vm-body').innerHTML = vmErrorHtml(data.error); return; }

    const subjects  = data.subjects || [];
    const orgs      = data.orgs     || [];
    const totalSub  = subjects.length;
    const clrSub    = subjects.filter(s => s.status === 'Cleared').length;
    const totalOrg  = orgs.length;
    const clrOrg    = orgs.filter(o => o.status === 'Cleared').length;

    const subRows = totalSub
        ? subjects.map((s, i) => `
            <tr>
                <td style="color:var(--muted);">${String(i+1).padStart(2,'0')}</td>
                <td><span style="${badgeStyle('#4299e1','rgba(66,153,225,0.13)')}">${escHtml(s.code)}</span></td>
                <td style="color:var(--muted);font-size:12px;">${escHtml(s.desc)}</td>
                <td>
                    ${s.status === 'Cleared'
                        ? `<span style="${badgeStyle('#38a169','rgba(56,161,105,0.15)')}"><i class="fas fa-check-circle me-1"></i>Cleared</span>`
                        : `<span style="${badgeStyle('#f6ad55','rgba(246,173,85,0.15)')}"><i class="fas fa-clock me-1"></i>Pending</span>`}
                </td>
            </tr>`).join('')
        : `<tr><td colspan="4" style="text-align:center;color:var(--muted);padding:28px 0;font-size:12px;">
               <i class="fas fa-book" style="display:block;font-size:22px;opacity:0.25;margin-bottom:8px;"></i>
               No subject clearances on record.</td></tr>`;

    const orgRows = totalOrg
        ? orgs.map((o, i) => `
            <tr>
                <td style="color:var(--muted);">${String(i+1).padStart(2,'0')}</td>
                <td style="font-weight:600;font-size:13px;">${escHtml(o.position)}</td>
                <td>
                    ${o.status === 'Cleared'
