//  ORG OFFICERS (STUDENT SIGNATORIES)
// ══════════════════════════════════════════════════════════════════════════════
function renderOrgOfficers() {
    const tbody = document.getElementById('sig-tbody');
    const empty = document.getElementById('sig-empty');
    tbody.innerHTML = '';

    if (!stuSignatories.length) {
        empty.style.display = 'block'; return;
    }
    empty.style.display = 'none';

    stuSignatories.forEach((s, i) => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td style="color:var(--muted);">${String(i+1).padStart(2,'0')}</td>
            <td>
                <div class="d-flex align-items-center gap-2">
                    <div class="user-avatar-sm" style="background:#9f7aea;">${escHtml(s.name.charAt(0))}</div>
                    <span style="font-weight:600;font-size:13px;">${escHtml(s.name)}</span>
                </div>
            </td>
            <td style="color:var(--muted);">${escHtml(s.idNum || '—')}</td>
            <td>${escHtml(s.course || '—')}</td>
            <td><span style="${badgeStyle('#9f7aea','rgba(159,122,234,0.15)')};">${escHtml(s.position || '—')}</span></td>
            <td>
                <button onclick="removeStuSignatory(${s.id})"
                        style="${btnStyle('#e53e3e','rgba(229,62,62,0.12)')}">
                    <i class="fas fa-trash-alt me-1"></i>Remove
                </button>
            </td>`;
        tbody.appendChild(tr);
    });
}

function populateStudentDropdown() {
    const sel = document.getElementById('sig-student-sel');
    sel.innerHTML = '<option value="">-- Select Student --</option>';
    students.forEach(s => {
        const opt = document.createElement('option');
        opt.value       = s.id;
        opt.textContent = `${s.name} (${s.idNum || '—'})`;
        sel.appendChild(opt);
    });
}

async function addStudentSignatory() {
    const userId   = document.getElementById('sig-student-sel').value;
    const position = document.getElementById('sig-position').value.trim();
    if (!userId || !position) { alert('Please select a student and enter a position.'); return; }
    try {
        const res  = await fetch('/api/admin/student-signatories', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: parseInt(userId), position })
        });
        const data = await res.json();
        if (data.success) {
            await loadStuSignatories();
            renderOrgOfficers();
            document.getElementById('sig-student-sel').value = '';
            document.getElementById('sig-position').value    = '';
        } else { alert(data.error || 'Failed to assign position.'); }
    } catch (e) { alert('Error: ' + e.message); }
}

async function removeStuSignatory(id) {
    if (!confirm('Remove this org officer assignment?')) return;
    try {
        await fetch(`/api/admin/student-signatories/${id}`, { method: 'DELETE' });
        stuSignatories = stuSignatories.filter(s => s.id !== id);
        renderOrgOfficers();
    } catch (e) { alert('Error: ' + e.message); }
}

// ══════════════════════════════════════════════════════════════════════════════
//  INSTRUCTOR DETAIL
// ══════════════════════════════════════════════════════════════════════════════
async function viewDetail(id) {
    document.getElementById('detail-panel').style.display  = 'block';
    document.getElementById('det-error').style.display     = 'none';
    document.getElementById('det-header-name').textContent = 'Loading...';
    document.getElementById('det-name').textContent        = 'Loading...';
    document.getElementById('det-avatar').textContent      = '?';
    ['det-first','det-last','det-eid'].forEach(fid => {
        const el = document.getElementById(fid); if (el) el.value = '';
    });
    document.getElementById('det-positions').innerHTML = '';
    setTimeout(() => document.getElementById('detail-panel')
        .scrollIntoView({ behavior:'smooth', block:'start' }), 50);

    try {
        const res  = await fetch(`/api/admin/instructors/${id}`);
        const data = await res.json();
        if (data.error) {
            document.getElementById('det-error').style.display     = 'block';
            document.getElementById('det-error-msg').textContent   = data.error;
            document.getElementById('det-header-name').textContent = 'Error';
            document.getElementById('det-name').textContent        = 'Error';
            return;
        }
        const fullName = [data.firstName, data.lastName].filter(x => x && x !== '—').join(' ');
        document.getElementById('det-header-name').textContent = fullName || '—';
        document.getElementById('det-avatar').textContent      = data.firstName?.charAt(0) ?? '?';
        document.getElementById('det-name').textContent        = fullName || '—';
        document.getElementById('det-eid-label').textContent   = `Employee ID: ${data.employeeId ?? '—'}`;
        document.getElementById('det-first').value             = data.firstName  ?? '—';
        document.getElementById('det-last').value              = data.lastName   ?? '—';
        document.getElementById('det-eid').value               = data.employeeId ?? '—';

        const posDiv    = document.getElementById('det-positions');
        const positions = Array.isArray(data.positions) ? data.positions : [];
        posDiv.innerHTML = positions.length
            ? positions.map(p => `<span style="${badgeStyle('#4299e1','rgba(66,153,225,0.15)')};font-size:11px;">${escHtml(p)}</span>`).join('')
            : `<span style="font-size:12px;color:var(--muted);">No positions assigned</span>`;
    } catch (e) {
        document.getElementById('det-error').style.display     = 'block';
        document.getElementById('det-error-msg').textContent   = e.message;
        document.getElementById('det-header-name').textContent = 'Error';
    }
}

function closeDetail() { document.getElementById('detail-panel').style.display = 'none'; }

