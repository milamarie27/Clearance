@{
    ViewData["Title"]      = "User Management";
    ViewData["ActivePage"] = "UserManagement";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-title">User Management</div>

<!-- STATS ROW -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-all">0</div>
                <div class="stat-label">Total Users</div>
                <div class="stat-sub">All roles combined</div>
            </div>
            <div class="stat-icon-wrap si-blue"><i class="fas fa-users"></i></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-students">0</div>
                <div class="stat-label">Students</div>
                <div class="stat-sub" id="stat-students-sub">—</div>
            </div>
            <div class="stat-icon-wrap si-purple"><i class="fas fa-user-graduate"></i></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-instructors">0</div>
                <div class="stat-label">Instructors</div>
                <div class="stat-sub">Active faculty</div>
            </div>
            <div class="stat-icon-wrap si-green"><i class="fas fa-chalkboard-teacher"></i></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-staff">0</div>
                <div class="stat-label">Staff / Admin</div>
                <div class="stat-sub">Support personnel</div>
            </div>
            <div class="stat-icon-wrap si-teal"><i class="fas fa-user-tie"></i></div>
        </div>
    </div>
</div>

<!-- ROLE FILTER TABS -->
<div class="d-flex gap-2 flex-wrap mb-4" id="role-tabs">
    <button class="ann-filter-btn active" id="tab-all"        onclick="switchRole('all')">
        <i class="fas fa-users me-1"></i>All Users
    </button>
    <button class="ann-filter-btn"        id="tab-Student"    onclick="switchRole('Student')">
        <i class="fas fa-user-graduate me-1"></i>Students
    </button>
    <button class="ann-filter-btn"        id="tab-Instructor" onclick="switchRole('Instructor')">
        <i class="fas fa-chalkboard-teacher me-1"></i>Instructors
    </button>
    <button class="ann-filter-btn"        id="tab-Staff"      onclick="switchRole('Staff')">
        <i class="fas fa-user-tie me-1"></i>Staff
    </button>
    <button class="ann-filter-btn"        id="tab-Org"        onclick="switchRole('Org')">
        <i class="fas fa-id-badge me-1"></i>Org Officers
    </button>
</div>

<!-- ─── MAIN TABLE PANEL (all / Student / Instructor / Staff) ─── -->
<div class="panel" id="main-panel"><!-- populated by JS --></div>

<!-- ─── ORG OFFICERS PANEL ─── -->
<div id="org-panel" style="display:none;">
    <div class="panel mb-4">
        <div class="panel-hd" style="display:flex;align-items:center;justify-content:space-between;">
            <span class="panel-hd-title"><i class="fas fa-id-badge me-2"></i>Org Officers &amp; Signatories</span>
            <button onclick="openAssignOrgModal()"
                    style="background:rgba(56,161,105,0.2);border:1px solid rgba(56,161,105,0.4);
                           color:#68d391;border-radius:8px;padding:6px 16px;font-size:12px;
                           font-weight:700;cursor:pointer;display:flex;align-items:center;gap:6px;">
                <i class="fas fa-user-plus"></i> Assign Position
            </button>
        </div>
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Role</th>
                        <th>ID / Student No.</th>
                        <th>Position</th>
                        <th>Section (if Adviser)</th>
                        <th style="text-align:center;">Actions</th>
                    </tr>
                </thead>
                <tbody id="all-org-tbody"></tbody>
            </table>
        </div>
        <div id="all-org-empty"
             style="padding:48px 24px;text-align:center;color:var(--muted);font-size:13px;display:none;">
            <i class="fas fa-id-badge" style="font-size:28px;opacity:0.3;display:block;margin-bottom:10px;"></i>
            No org officers or signatories assigned yet.
        </div>
    </div>
</div>

<!-- ─── ASSIGN ORG POSITION MODAL ─── -->
<div id="assign-org-overlay"
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:1040;"
     onclick="closeAssignOrgModal()"></div>
<div id="assign-org-modal"
     style="display:none;position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);
            width:520px;max-height:90vh;overflow-y:auto;background:var(--card);
            border-radius:14px;box-shadow:0 20px 60px rgba(0,0,0,0.5);z-index:1050;padding:0;">
    <div style="background:var(--tbl-hd-navy);padding:16px 20px;display:flex;
                align-items:center;justify-content:space-between;border-radius:14px 14px 0 0;">
        <span style="font-size:14px;font-weight:700;color:white;">
            <i class="fas fa-user-tag me-2"></i>Assign Org Position
        </span>
        <button onclick="closeAssignOrgModal()"
                style="background:rgba(255,255,255,0.12);border:none;color:white;
                       border-radius:6px;padding:4px 12px;font-size:12px;cursor:pointer;">
            <i class="fas fa-times"></i>
        </button>
    </div>
    <div style="padding:20px;">
        <!-- User search -->
        <div class="mb-3">
            <label class="dark-label">Search &amp; Select User (any role)</label>
            <div style="position:relative;">
                <input class="dark-input" id="ao-search" placeholder="Type name or ID…"
                       autocomplete="off" oninput="filterAoDD(this.value)"
                       onfocus="filterAoDD(this.value)" style="padding-right:36px;" />
                <i class="fas fa-search"
                   style="position:absolute;right:12px;top:50%;transform:translateY(-50%);
                          color:var(--muted);pointer-events:none;"></i>
                <div id="ao-dropdown"
                     style="display:none;position:absolute;top:100%;left:0;right:0;z-index:9999;
                            background:var(--card);border:1px solid var(--border);border-radius:8px;
                            max-height:200px;overflow-y:auto;box-shadow:0 8px 24px rgba(0,0,0,0.4);
                            margin-top:4px;"></div>
            </div>
            <div id="ao-pill" style="display:none;margin-top:10px;background:rgba(56,161,105,0.1);
                 border:1px solid rgba(56,161,105,0.3);border-radius:8px;padding:10px 14px;
                 display:flex;align-items:center;justify-content:space-between;">
                <div style="display:flex;align-items:center;gap:10px;">
                    <div id="ao-pill-av" class="user-avatar-sm" style="background:#38a169;"></div>
                    <div>
                        <div id="ao-pill-name" style="font-size:13px;font-weight:700;color:var(--text);"></div>
                        <div id="ao-pill-meta" style="font-size:11px;color:var(--muted);"></div>
                    </div>
                </div>
                <button onclick="clearAoSelection()"
                        style="background:none;border:none;color:var(--muted);cursor:pointer;">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        </div>

        <!-- Position selector -->
        <div class="mb-3">
            <label class="dark-label">Position</label>
            <select class="dark-input" id="ao-pos" onchange="onAoPosChange(this.value)"
                    style="appearance:auto;-webkit-appearance:auto;cursor:pointer;">
                <option value="" disabled selected>— Select a position —</option>
                <option value="Class Adviser">Class Adviser</option>
                <option value="Departmental Chairperson">Departmental Chairperson</option>
                <option value="Organization Adviser">Organization Adviser</option>
                <option value="SSG President">SSG President</option>
                <option value="SSG Vice President">SSG Vice President</option>
                <option value="SSG Secretary">SSG Secretary</option>
                <option value="SSG Treasurer">SSG Treasurer</option>
                <option value="SSG Auditor">SSG Auditor</option>
                <option value="__custom__">Other (type manually)</option>
            </select>
        </div>
        <div id="ao-custom-wrap" style="display:none;" class="mb-3">
            <label class="dark-label">Custom Position Title</label>
            <input class="dark-input" id="ao-custom" placeholder="e.g. Club President" />
        </div>

        <!-- Class Adviser extras -->
        <div id="ao-adviser-wrap"
             style="display:none;background:rgba(66,153,225,0.06);border:1px solid rgba(66,153,225,0.2);
                    border-radius:10px;padding:14px 16px;margin-bottom:12px;">
            <div style="font-size:12px;font-weight:700;color:#4299e1;margin-bottom:12px;">
                <i class="fas fa-chalkboard-teacher me-2"></i>Class Adviser — Select Section
            </div>
            <div class="row g-2">
                <div class="col-12">
                    <label class="dark-label">Course</label>
                    <select class="dark-input" id="ao-ca-course" onchange="aoFilterYear()"
                            style="appearance:auto;-webkit-appearance:auto;cursor:pointer;">
                        <option value="" disabled selected>— Select Course —</option>
                    </select>
                </div>
                <div class="col-6">
                    <label class="dark-label">Year Level</label>
                    <select class="dark-input" id="ao-ca-year" onchange="aoFilterSection()"
                            style="appearance:auto;-webkit-appearance:auto;cursor:pointer;">
                        <option value="" disabled selected>— Year —</option>
                    </select>
                </div>
                <div class="col-6">
                    <label class="dark-label">Section</label>
                    <select class="dark-input" id="ao-ca-section"
                            style="appearance:auto;-webkit-appearance:auto;cursor:pointer;">
                        <option value="" disabled selected>— Section —</option>
                    </select>
                </div>
            </div>
        </div>

        <div id="ao-error" style="display:none;color:#fc8181;font-size:12px;margin-bottom:10px;"></div>
        <div style="display:flex;gap:10px;justify-content:flex-end;">
            <button onclick="closeAssignOrgModal()"
                    style="background:rgba(255,255,255,0.06);border:1px solid var(--border);
                           color:var(--muted);border-radius:8px;padding:9px 22px;font-size:13px;cursor:pointer;">
                Cancel
            </button>
            <button onclick="submitAssignOrg()" id="ao-submit-btn" class="btn-green-sm"
                    style="padding:9px 22px;font-size:13px;">
                <i class="fas fa-check me-1"></i>Assign
            </button>
        </div>
    </div>
</div>

<!-- ─── ASSIGN POSITIONS FLOATING PANEL (Instructor / Staff) ─── -->
<div class="mt-4 panel" id="assign-panel" style="display:none;">
    <div style="background:var(--tbl-hd-navy);padding:13px 18px;font-size:14px;font-weight:700;
                color:white;display:flex;align-items:center;justify-content:space-between;">
        <span id="assign-panel-title"><i class="fas fa-sitemap me-2"></i>Assign Positions</span>
        <button onclick="closeAssignPanel()"
                style="background:rgba(255,255,255,0.12);border:none;color:white;
                       border-radius:6px;padding:4px 12px;font-size:12px;cursor:pointer;">
            <i class="fas fa-times me-1"></i>Close
        </button>
    </div>
    <div style="padding:20px;" id="assign-panel-body"><!-- rendered by JS --></div>
    <div style="background:var(--tbl-hd-navy);padding:11px 18px;font-size:13px;font-weight:700;color:white;">
        <span id="assign-list-title">Assigned Positions</span>
    </div>
    <div class="table-responsive">
        <table class="data-table">
            <thead id="assign-thead"></thead>
            <tbody id="assign-tbody"></tbody>
        </table>
        <div id="assign-empty" style="padding:36px 24px;text-align:center;color:var(--muted);font-size:13px;">
            <i class="fas fa-list-ul" style="font-size:24px;opacity:0.3;display:block;margin-bottom:10px;"></i>
            No positions assigned yet.
        </div>
    </div>
</div>

<!-- ─── UNIFIED VIEW MODAL ─── -->
<div id="view-modal"
     style="display:none;position:fixed;inset:0;z-index:9999;
            background:rgba(0,0,0,0.65);backdrop-filter:blur(3px);
            align-items:flex-start;justify-content:center;padding:32px 16px;overflow-y:auto;">
    <div style="background:var(--card);border-radius:16px;border:1px solid var(--border);
                width:100%;max-width:700px;display:flex;flex-direction:column;
                box-shadow:0 24px 64px rgba(0,0,0,0.55);margin:auto;">
        <!-- Modal header -->
        <div style="background:var(--tbl-hd-navy);padding:16px 20px;
                    border-radius:16px 16px 0 0;
                    display:flex;align-items:center;gap:14px;flex-shrink:0;">
            <div id="vm-avatar"
                 style="width:46px;height:46px;border-radius:50%;
                        display:flex;align-items:center;justify-content:center;
                        font-size:20px;font-weight:800;color:white;flex-shrink:0;">?</div>
            <div style="flex:1;min-width:0;">
                <div id="vm-name"
                     style="font-size:16px;font-weight:800;color:white;
                            white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                    Loading…
                </div>
                <div id="vm-role-badge" style="margin-top:5px;"></div>
            </div>
            <button onclick="closeViewModal()"
                    style="background:rgba(255,255,255,0.12);border:none;color:white;
                           border-radius:8px;padding:7px 16px;font-size:12px;
                           cursor:pointer;flex-shrink:0;">
                <i class="fas fa-times me-1"></i>Close
            </button>
        </div>
        <!-- Modal body -->
        <div id="vm-body" style="padding:22px;"></div>
    </div>
</div>

@section Scripts {
<script>
// ══════════════════════════════════════════════════════════════════════════════
//  STATE
// ══════════════════════════════════════════════════════════════════════════════
let students           = [];
let instructors        = [];
let staffList          = [];
let orgSignatories     = [];
let stuSignatories     = [];
let staffPositions     = [];
let curriculums        = [];
let selectedInstructor = null;
let allUsers           = [];   // all active users for assign-org dropdown
let allOrgPositions    = [];   // unified org positions list (from API)
let allPeriodsList     = [];   // academic periods for view modal

let currentRole    = 'all';
let assignMode     = null;
let aoSelectedUser = null;

// ══════════════════════════════════════════════════════════════════════════════
//  INIT
// ══════════════════════════════════════════════════════════════════════════════
async function init() {
    try {
        await Promise.all([
            loadStudents(), loadInstructors(), loadStaff(),
            loadOrgSignatories(), loadStuSignatories(),
            loadStaffPositions(), loadCurriculums(),
            loadAllUsers(), loadAllOrgPositions(), loadAllPeriods()
        ]);
        updateStats();
        render();
    } catch(e) { console.error('INIT FAILED:', e); }
}

// ══════════════════════════════════════════════════════════════════════════════
//  LOADERS
// ══════════════════════════════════════════════════════════════════════════════
async function loadStudents() {
    try { const r = await fetch('/api/admin/students'); const d = await r.json(); students = Array.isArray(d) ? d : []; }
    catch { students = []; }
}
async function loadInstructors() {
    try { const r = await fetch('/api/admin/instructors'); instructors = await r.json(); } catch {}
    if (!Array.isArray(instructors)) instructors = [];
}
async function loadStaff() {
    try { const r = await fetch('/api/admin/staff'); staffList = await r.json(); } catch {}
    if (!Array.isArray(staffList)) staffList = [];
}
async function loadOrgSignatories() {
    try {
        const r = await fetch('/api/admin/org-signatories');
        const d = await r.json();
        orgSignatories = Array.isArray(d) ? d.map(s => ({
            id: s.id, userId: s.userId, name: s.name, eid: s.eid,
            pos: s.pos, curriculumId: s.curriculumId ?? null,
            courseCode: s.courseCode ?? '', yearLevel: s.yearLevel ?? '',
            section: s.section ?? ''
        })) : [];
    } catch { orgSignatories = []; }
}
async function loadStuSignatories() {
    try { const r = await fetch('/api/admin/student-signatories'); stuSignatories = await r.json(); } catch {}
    if (!Array.isArray(stuSignatories)) stuSignatories = [];
}
async function loadStaffPositions() {
    try { const r = await fetch('/api/admin/staff-positions'); staffPositions = await r.json(); } catch {}
    if (!Array.isArray(staffPositions)) staffPositions = [];
}
async function loadCurriculums() {
    try { const r = await fetch('/api/admin/curriculums'); curriculums = await r.json(); } catch {}
    if (!Array.isArray(curriculums)) curriculums = [];
}
async function loadAllUsers() {
    try { const r = await fetch('/api/admin/all-users'); allUsers = await r.json(); } catch {}
    if (!Array.isArray(allUsers)) allUsers = [];
}
async function loadAllOrgPositions() {
    try { const r = await fetch('/api/admin/all-org-positions'); allOrgPositions = await r.json(); } catch {}
    if (!Array.isArray(allOrgPositions)) allOrgPositions = [];
}
async function loadAllPeriods() {
    try { const r = await fetch('/api/student/periods'); allPeriodsList = await r.json(); } catch {}
    if (!Array.isArray(allPeriodsList)) allPeriodsList = [];
}

// ══════════════════════════════════════════════════════════════════════════════
//  STATS
// ══════════════════════════════════════════════════════════════════════════════
function updateStats() {
    const cleared = students.filter(s => s.cs === 'Cleared').length;
    document.getElementById('stat-all').textContent          = students.length + instructors.length + staffList.length;
    document.getElementById('stat-students').textContent     = students.length;
    document.getElementById('stat-students-sub').textContent = `${cleared} cleared`;
    document.getElementById('stat-instructors').textContent  = instructors.length;
    document.getElementById('stat-staff').textContent        = staffList.length;
}

// ══════════════════════════════════════════════════════════════════════════════
//  ROLE TABS
// ══════════════════════════════════════════════════════════════════════════════
function switchRole(role) {
    currentRole = role;
    closeAssignPanel();
    ['all','Student','Instructor','Staff','Org'].forEach(r =>
        document.getElementById('tab-' + r).classList.toggle('active', r === role)
    );
    document.getElementById('main-panel').style.display = role !== 'Org' ? '' : 'none';
    document.getElementById('org-panel').style.display  = role === 'Org' ? '' : 'none';
    render();
}

// ══════════════════════════════════════════════════════════════════════════════
//  RENDER DISPATCHER
// ══════════════════════════════════════════════════════════════════════════════
function render() {
    if (currentRole === 'Org')        { renderOrgOfficers();    return; }
    if (currentRole === 'Student')    { renderStudentTable();   return; }
    if (currentRole === 'Instructor') { renderInstructorTable();return; }
    if (currentRole === 'Staff')      { renderStaffTable();     return; }
    renderAllTable();
}

// ══════════════════════════════════════════════════════════════════════════════
//  ALL USERS TABLE
// ══════════════════════════════════════════════════════════════════════════════
function renderAllTable() {
    const panel = document.getElementById('main-panel');
    const rows  = [
        ...students.map(s => ({
            role: 'Student', name: s.name, id: s.idNum || '—',
            meta: `${s.course || '—'} · Yr${s.year || '?'} · ${s.section || '—'}`,
            badge: s.cs === 'Cleared'
                ? `<span style="${badgeStyle('#38a169','rgba(56,161,105,0.15)')}"><i class="fas fa-check-circle me-1"></i>Cleared</span>`
                : `<span style="${badgeStyle('#f6ad55','rgba(246,173,85,0.15)')}"><i class="fas fa-clock me-1"></i>Pending</span>`,
            userId: s.id
        })),
        ...instructors.map(i => ({
            role: 'Instructor', name: i.name, id: i.employeeId || '—',
            meta: i.joinedDate || '—',
            badge: `<span style="${badgeStyle('#38a169','rgba(56,161,105,0.15)')}">Active</span>`,
            userId: i.id
        })),
        ...staffList.map(s => ({
            role: 'Staff', name: s.name, id: s.id_number || '—',
            meta: '—',
            badge: `<span style="${badgeStyle('#38a169','rgba(56,161,105,0.15)')}">Active</span>`,
            userId: s.id
        }))
    ];

    if (!rows.length) {
        panel.innerHTML = emptyState('fa-users', 'No Users Found', 'No users registered yet.');
        return;
    }

    panel.innerHTML = `
        <div class="panel-hd">
            <span class="panel-hd-title"><i class="fas fa-users me-2"></i>All Users</span>
            <div class="search-wrap">
                <i class="fas fa-search"></i>
                <input class="search-input" placeholder="Search name, ID, course..."
                       oninput="filterTable(this,'all-table')" />
            </div>
        </div>
        <div class="table-responsive">
            <table class="data-table" id="all-table">
                <thead>
                    <tr>
                        <th>#</th><th>Name</th><th>Role</th>
                        <th>ID / Student No.</th><th>Details</th>
                        <th>Status</th><th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    ${rows.map((r, i) => `
                        <tr>
                            <td style="color:var(--muted);">${String(i+1).padStart(2,'0')}</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="user-avatar-sm" style="background:${roleColor(r.role)};">
                                        ${escHtml(r.name.charAt(0))}
                                    </div>
                                    <span style="font-weight:600;font-size:13px;">${escHtml(r.name)}</span>
                                </div>
                            </td>
                            <td>
                                <span style="${badgeStyle(roleColor(r.role), roleColorBg(r.role))}">
                                    ${escHtml(r.role)}
                                </span>
                            </td>
                            <td style="color:var(--muted);font-size:12px;">${escHtml(r.id)}</td>
                            <td style="color:var(--muted);font-size:12px;">${escHtml(r.meta)}</td>
                            <td>${r.badge}</td>
                            <td>
                                <button onclick="viewUser(${r.userId},'${r.role}')"
                                        style="${btnStyle('#4299e1')}">
                                    <i class="fas fa-eye me-1"></i>View
                                </button>
                            </td>
                        </tr>`).join('')}
                </tbody>
            </table>
        </div>`;
}

// ══════════════════════════════════════════════════════════════════════════════
//  STUDENT TABLE
// ══════════════════════════════════════════════════════════════════════════════
function renderStudentTable() {
    const panel = document.getElementById('main-panel');
    const subFilterHtml = `
        <div class="d-flex gap-2 mb-3" style="padding:16px 16px 0;">
            <button class="ann-filter-btn active" id="sf-all"     onclick="subFilter('all')">All</button>
            <button class="ann-filter-btn"        id="sf-cleared" onclick="subFilter('cleared')">
                <i class="fas fa-check-circle me-1"></i>Cleared
            </button>
            <button class="ann-filter-btn"        id="sf-pending" onclick="subFilter('pending')">
                <i class="fas fa-clock me-1"></i>Pending
            </button>
        </div>`;

    panel.innerHTML = `
        ${subFilterHtml}
        <div class="panel-hd">
            <span class="panel-hd-title"><i class="fas fa-user-graduate me-2"></i>Students</span>
            <div class="search-wrap">
                <i class="fas fa-search"></i>
                <input class="search-input" placeholder="Search name, ID, course..."
                       oninput="filterTable(this,'student-table')" />
            </div>
        </div>
