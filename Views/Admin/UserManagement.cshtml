@{
    ViewData["Title"]      = "User Management";
    ViewData["ActivePage"] = "UserManagement";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-title">User Management</div>

<!-- STATS ROW -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-all">0</div>
                <div class="stat-label">Total Users</div>
                <div class="stat-sub">All roles combined</div>
            </div>
            <div class="stat-icon-wrap si-blue"><i class="fas fa-users"></i></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-students">0</div>
                <div class="stat-label">Students</div>
                <div class="stat-sub" id="stat-students-sub">—</div>
            </div>
            <div class="stat-icon-wrap si-purple"><i class="fas fa-user-graduate"></i></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-instructors">0</div>
                <div class="stat-label">Instructors</div>
                <div class="stat-sub">Active faculty</div>
            </div>
            <div class="stat-icon-wrap si-green"><i class="fas fa-chalkboard-teacher"></i></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-staff">0</div>
                <div class="stat-label">Staff / Admin</div>
                <div class="stat-sub">Support personnel</div>
            </div>
            <div class="stat-icon-wrap si-teal"><i class="fas fa-user-tie"></i></div>
        </div>
    </div>
</div>

<!-- ROLE FILTER TABS -->
<div class="d-flex gap-2 flex-wrap mb-4" id="role-tabs">
    <button class="ann-filter-btn active" id="tab-all"         onclick="switchRole('all')">
        <i class="fas fa-users me-1"></i>All Users
    </button>
    <button class="ann-filter-btn"        id="tab-Student"     onclick="switchRole('Student')">
        <i class="fas fa-user-graduate me-1"></i>Students
    </button>
    <button class="ann-filter-btn"        id="tab-Instructor"  onclick="switchRole('Instructor')">
        <i class="fas fa-chalkboard-teacher me-1"></i>Instructors
    </button>
    <button class="ann-filter-btn"        id="tab-Staff"       onclick="switchRole('Staff')">
        <i class="fas fa-user-tie me-1"></i>Staff
    </button>
    <button class="ann-filter-btn"        id="tab-Org"         onclick="switchRole('Org')">
        <i class="fas fa-id-badge me-1"></i>Org Officers
    </button>
</div>

<!-- ─── MAIN TABLE PANEL (all / Student / Instructor / Staff) ─── -->
<div class="panel" id="main-panel"><!-- populated by JS --></div>

<!-- ─── INSTRUCTOR DETAIL PANEL ─── -->
<div id="detail-panel" style="display:none;" class="mt-3">
    <div class="panel">
        <div style="background:var(--tbl-hd-navy);padding:13px 18px;font-size:14px;font-weight:700;color:white;
                    display:flex;align-items:center;justify-content:space-between;border-radius:10px 10px 0 0;">
            <span><i class="fas fa-user me-2"></i>Instructor Detail — <span id="det-header-name" style="color:#63b3ed;"></span></span>
            <button onclick="closeDetail()"
                    style="background:rgba(255,255,255,0.12);border:none;color:white;border-radius:6px;padding:4px 14px;font-size:12px;cursor:pointer;">
                <i class="fas fa-times me-1"></i>Close
            </button>
        </div>
        <div style="padding:20px;">
            <div style="background:var(--card);border-radius:12px;border:1px solid var(--border);
                        padding:18px 22px;display:flex;align-items:center;gap:18px;margin-bottom:20px;">
                <div style="width:58px;height:58px;border-radius:50%;background:rgba(66,153,225,0.15);
                            display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <span id="det-avatar" style="font-size:24px;font-weight:800;color:#4299e1;"></span>
                </div>
                <div>
                    <div id="det-name" style="font-size:18px;font-weight:800;color:var(--text);"></div>
                    <div id="det-eid-label" style="font-size:12px;color:var(--muted);margin-top:3px;"></div>
                </div>
                <div style="margin-left:auto;">
                    <span style="background:rgba(56,161,105,0.15);color:#38a169;padding:4px 14px;border-radius:20px;font-size:12px;font-weight:700;">Active</span>
                </div>
            </div>
            <div id="det-error" style="display:none;background:rgba(229,62,62,0.10);border:1px solid rgba(229,62,62,0.3);
                 border-radius:10px;padding:16px;text-align:center;margin-bottom:16px;">
                <i class="fas fa-exclamation-triangle" style="color:#fc8181;font-size:20px;margin-bottom:8px;display:block;"></i>
                <div id="det-error-msg" style="font-size:12px;color:var(--muted);"></div>
            </div>
            <div class="panel" style="margin-bottom:0;">
                <div style="padding:13px 16px;border-bottom:1px solid var(--border);font-size:13px;font-weight:700;color:var(--text);">
                    <i class="fas fa-id-card me-2" style="color:#4299e1;"></i>Profile Information
                </div>
                <div style="padding:16px;">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="dark-label">First Name</label>
                            <input class="dark-input" id="det-first" type="text" readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="dark-label">Last Name</label>
                            <input class="dark-input" id="det-last" type="text" readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="dark-label">Employee ID</label>
                            <input class="dark-input" id="det-eid" type="text" readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="dark-label">Positions</label>
                            <div id="det-positions" style="min-height:38px;display:flex;flex-wrap:wrap;gap:6px;align-items:center;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ─── ORG OFFICERS PANEL ─── -->
<div id="org-panel" style="display:none;">
    <div class="panel mb-4">
        <div class="panel-hd">
            <span class="panel-hd-title"><i class="fas fa-id-badge me-2"></i>Student Org Officers</span>
        </div>
        <div style="padding:20px 20px 0;">
            <div class="row g-2 mb-3">
                <div class="col-md-5">
                    <label class="dark-label">Student</label>
                    <select class="dark-input dark-select" id="sig-student-sel">
                        <option value="">-- Select Student --</option>
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="dark-label">Position / Role</label>
                    <input class="dark-input" id="sig-position" placeholder="e.g. Organization Treasurer" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn-green-sm w-100" onclick="addStudentSignatory()">
                        <i class="fas fa-plus me-1"></i>Assign
                    </button>
                </div>
            </div>
        </div>
        <div class="table-responsive">
            <table class="data-table" id="sig-table">
                <thead>
                    <tr>
                        <th>#</th><th>Name</th><th>Student No.</th>
                        <th>Course</th><th>Position</th><th>Action</th>
                    </tr>
                </thead>
                <tbody id="sig-tbody"></tbody>
            </table>
        </div>
        <div id="sig-empty"
             style="padding:48px 24px;text-align:center;color:var(--muted);font-size:13px;display:none;">
            <i class="fas fa-id-badge" style="font-size:28px;opacity:0.3;display:block;margin-bottom:10px;"></i>
            No org officers assigned yet.
        </div>
    </div>
</div>

<!-- ─── ASSIGN POSITIONS FLOATING PANEL (Instructor / Staff) ─── -->
<div class="mt-4 panel" id="assign-panel" style="display:none;">
    <div style="background:var(--tbl-hd-navy);padding:13px 18px;font-size:14px;font-weight:700;
                color:white;display:flex;align-items:center;justify-content:space-between;">
        <span id="assign-panel-title"><i class="fas fa-sitemap me-2"></i>Assign Positions</span>
        <button onclick="closeAssignPanel()"
                style="background:rgba(255,255,255,0.12);border:none;color:white;
                       border-radius:6px;padding:4px 12px;font-size:12px;cursor:pointer;">
            <i class="fas fa-times me-1"></i>Close
        </button>
    </div>
    <div style="padding:20px;" id="assign-panel-body"><!-- rendered by JS --></div>
    <div style="background:var(--tbl-hd-navy);padding:11px 18px;font-size:13px;font-weight:700;color:white;">
        <span id="assign-list-title">Assigned Positions</span>
    </div>
    <div class="table-responsive">
        <table class="data-table">
            <thead id="assign-thead"></thead>
            <tbody id="assign-tbody"></tbody>
        </table>
        <div id="assign-empty" style="padding:36px 24px;text-align:center;color:var(--muted);font-size:13px;">
            <i class="fas fa-list-ul" style="font-size:24px;opacity:0.3;display:block;margin-bottom:10px;"></i>
            No positions assigned yet.
        </div>
    </div>
</div>

@section Scripts {
<script>
// ══════════════════════════════════════════════════════════════════════════════
//  STATE
// ══════════════════════════════════════════════════════════════════════════════
let students        = [];
let instructors     = [];
let staffList       = [];
let orgSignatories  = [];   // instructor org signatories
let stuSignatories  = [];   // student org officers
let staffPositions  = [];
let curriculums     = [];
let selectedInstructor = null;

let currentRole    = 'all';
let assignMode     = null;  // 'instructor' | 'staff' | null

// ══════════════════════════════════════════════════════════════════════════════
//  INIT
// ══════════════════════════════════════════════════════════════════════════════
async function init() {
    await Promise.all([
        loadStudents(),
        loadInstructors(),
        loadStaff(),
        loadOrgSignatories(),
        loadStuSignatories(),
        loadStaffPositions(),
        loadCurriculums()
    ]);
    updateStats();
    render();
    populateStudentDropdown();
}

// ══════════════════════════════════════════════════════════════════════════════
//  LOADERS
// ══════════════════════════════════════════════════════════════════════════════
async function loadStudents() {
    try { const r = await fetch('/api/admin/students'); students = await r.json(); } catch {}
    if (!Array.isArray(students)) students = [];
}
async function loadInstructors() {
    try { const r = await fetch('/api/admin/instructors'); instructors = await r.json(); } catch {}
    if (!Array.isArray(instructors)) instructors = [];
}
async function loadStaff() {
    try { const r = await fetch('/api/admin/staff'); staffList = await r.json(); } catch {}
    if (!Array.isArray(staffList)) staffList = [];
}
async function loadOrgSignatories() {
    try {
        const r = await fetch('/api/admin/org-signatories');
        const d = await r.json();
        orgSignatories = Array.isArray(d) ? d.map(s => ({
            id: s.id, userId: s.userId, name: s.name, eid: s.eid,
            pos: s.pos, curriculumId: s.curriculumId ?? null,
            courseCode: s.courseCode ?? '', yearLevel: s.yearLevel ?? '',
            section: s.section ?? ''
        })) : [];
    } catch { orgSignatories = []; }
}
async function loadStuSignatories() {
    try { const r = await fetch('/api/admin/student-signatories'); stuSignatories = await r.json(); } catch {}
    if (!Array.isArray(stuSignatories)) stuSignatories = [];
}
async function loadStaffPositions() {
    try { const r = await fetch('/api/admin/staff-positions'); staffPositions = await r.json(); } catch {}
    if (!Array.isArray(staffPositions)) staffPositions = [];
}
async function loadCurriculums() {
    try { const r = await fetch('/api/admin/curriculums'); curriculums = await r.json(); } catch {}
    if (!Array.isArray(curriculums)) curriculums = [];
}

// ══════════════════════════════════════════════════════════════════════════════
//  STATS
// ══════════════════════════════════════════════════════════════════════════════
function updateStats() {
    const cleared = students.filter(s => s.cs === 'Cleared').length;
    document.getElementById('stat-all').textContent         = students.length + instructors.length + staffList.length;
    document.getElementById('stat-students').textContent    = students.length;
    document.getElementById('stat-students-sub').textContent= `${cleared} cleared`;
    document.getElementById('stat-instructors').textContent = instructors.length;
    document.getElementById('stat-staff').textContent       = staffList.length;
}

// ══════════════════════════════════════════════════════════════════════════════
//  ROLE TABS
// ══════════════════════════════════════════════════════════════════════════════
function switchRole(role) {
    currentRole = role;
    closeDetail();
    closeAssignPanel();

    ['all','Student','Instructor','Staff','Org'].forEach(r =>
        document.getElementById('tab-' + r).classList.toggle('active', r === role)
    );

    document.getElementById('main-panel').style.display  = role !== 'Org' ? '' : 'none';
    document.getElementById('org-panel').style.display   = role === 'Org' ? '' : 'none';

    render();
}

// ══════════════════════════════════════════════════════════════════════════════
//  MAIN RENDER DISPATCHER
// ══════════════════════════════════════════════════════════════════════════════
function render() {
    if (currentRole === 'Org') { renderOrgOfficers(); return; }
    if (currentRole === 'Student')    { renderStudentTable();    return; }
    if (currentRole === 'Instructor') { renderInstructorTable(); return; }
    if (currentRole === 'Staff')      { renderStaffTable();      return; }
    renderAllTable();
}

// ══════════════════════════════════════════════════════════════════════════════
//  ALL USERS TABLE (merged)
// ══════════════════════════════════════════════════════════════════════════════
function renderAllTable() {
    const panel = document.getElementById('main-panel');
    const rows  = [
        ...students.map(s => ({
            role: 'Student', name: s.name, id: s.idNum || '—',
            meta: `${s.course || '—'} · Yr${s.year || '?'} · ${s.section || '—'}`,
            badge: s.cs === 'Cleared'
                ? `<span style="${badgeStyle('#38a169','rgba(56,161,105,0.15)')}"><i class="fas fa-check-circle me-1"></i>Cleared</span>`
                : `<span style="${badgeStyle('#f6ad55','rgba(246,173,85,0.15)')}"><i class="fas fa-clock me-1"></i>Pending</span>`,
            action: ''
        })),
        ...instructors.map(i => ({
            role: 'Instructor', name: i.name, id: i.employeeId || '—',
            meta: i.joinedDate || '—',
            badge: `<span style="${badgeStyle('#38a169','rgba(56,161,105,0.15)')}">Active</span>`,
            action: `<button onclick="viewDetail(${i.id})" style="${btnStyle('#4299e1')}"><i class="fas fa-eye me-1"></i>View</button>`
        })),
        ...staffList.map(s => ({
            role: 'Staff', name: s.name, id: s.id_number || '—',
            meta: '—',
            badge: `<span style="${badgeStyle('#38a169','rgba(56,161,105,0.15)')}">Active</span>`,
            action: ''
        }))
    ];

    if (!rows.length) {
        panel.innerHTML = emptyState('fa-users', 'No Users Found', 'No users registered yet.');
        return;
    }

    panel.innerHTML = `
        <div class="panel-hd">
            <span class="panel-hd-title"><i class="fas fa-users me-2"></i>All Users</span>
            <div class="search-wrap">
                <i class="fas fa-search"></i>
                <input class="search-input" placeholder="Search name, ID, course..."
                       oninput="filterTable(this,'all-table')" />
            </div>
        </div>
        <div class="table-responsive">
            <table class="data-table" id="all-table">
                <thead>
                    <tr>
                        <th>#</th><th>Name</th><th>Role</th>
                        <th>ID / Student No.</th><th>Details</th>
                        <th>Status</th><th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    ${rows.map((r, i) => `
                        <tr>
                            <td style="color:var(--muted);">${String(i+1).padStart(2,'0')}</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="user-avatar-sm" style="background:${roleColor(r.role)};">
                                        ${escHtml(r.name.charAt(0))}
                                    </div>
                                    <span style="font-weight:600;font-size:13px;">${escHtml(r.name)}</span>
                                </div>
                            </td>
                            <td>
                                <span style="${badgeStyle(roleColor(r.role), roleColorBg(r.role))}">
                                    ${escHtml(r.role)}
                                </span>
                            </td>
                            <td style="color:var(--muted);font-size:12px;">${escHtml(r.id)}</td>
                            <td style="color:var(--muted);font-size:12px;">${escHtml(r.meta)}</td>
                            <td>${r.badge}</td>
                            <td>${r.action || '<span style="color:var(--muted);font-size:12px;">—</span>'}</td>
                        </tr>`).join('')}
                </tbody>
            </table>
        </div>`;
}

// ══════════════════════════════════════════════════════════════════════════════
//  STUDENT TABLE
// ══════════════════════════════════════════════════════════════════════════════
function renderStudentTable() {
    const panel = document.getElementById('main-panel');

    // sub-filter buttons inside student view
    const subFilterHtml = `
        <div class="d-flex gap-2 mb-3" style="padding:16px 16px 0;">
            <button class="ann-filter-btn active" id="sf-all"     onclick="subFilter('all')">All</button>
            <button class="ann-filter-btn"        id="sf-cleared" onclick="subFilter('cleared')">
                <i class="fas fa-check-circle me-1"></i>Cleared
            </button>
            <button class="ann-filter-btn"        id="sf-pending" onclick="subFilter('pending')">
                <i class="fas fa-clock me-1"></i>Pending
            </button>
        </div>`;

    panel.innerHTML = `
        ${subFilterHtml}
        <div class="panel-hd">
            <span class="panel-hd-title"><i class="fas fa-user-graduate me-2"></i>Students</span>
            <div class="search-wrap">
                <i class="fas fa-search"></i>
                <input class="search-input" placeholder="Search name, ID, course..."
                       oninput="filterTable(this,'student-table')" />
            </div>
        </div>
        <div class="table-responsive">
            <table class="data-table" id="student-table">
                <thead>
                    <tr>
                        <th>#</th><th>Name</th><th>Student No.</th>
                        <th>Course</th><th>Year</th><th>Section</th><th>Status</th>
                    </tr>
                </thead>
                <tbody id="student-tbody"></tbody>
            </table>
        </div>
        <div id="student-empty" style="display:none;padding:48px 24px;text-align:center;color:var(--muted);font-size:13px;">
            <i class="fas fa-user-graduate" style="font-size:28px;opacity:0.3;display:block;margin-bottom:10px;"></i>
            No students match this filter.
        </div>`;

    renderStudentRows('all');
}

let currentSubFilter = 'all';
function subFilter(f) {
    currentSubFilter = f;
    ['all','cleared','pending'].forEach(x =>
        document.getElementById('sf-' + x)?.classList.toggle('active', x === f)
    );
    renderStudentRows(f);
}

function renderStudentRows(f) {
    let list = students;
    if (f === 'cleared') list = students.filter(s => s.cs === 'Cleared');
    if (f === 'pending') list = students.filter(s => s.cs !== 'Cleared');

    const tbody = document.getElementById('student-tbody');
    const empty = document.getElementById('student-empty');
    if (!tbody) return;

    if (!list.length) {
        tbody.innerHTML = '';
        if (empty) empty.style.display = 'block';
        return;
    }
    if (empty) empty.style.display = 'none';

    tbody.innerHTML = list.map((s, i) => `
        <tr>
            <td style="color:var(--muted);">${String(i+1).padStart(2,'0')}</td>
            <td>
                <div class="d-flex align-items-center gap-2">
                    <div class="user-avatar-sm" style="background:#9f7aea;">${escHtml(s.name.charAt(0))}</div>
                    <span style="font-weight:600;font-size:13px;">${escHtml(s.name)}</span>
                </div>
            </td>
            <td style="color:var(--muted);">${escHtml(s.idNum || '—')}</td>
            <td>${escHtml(s.course || '—')}</td>
            <td style="color:var(--muted);">${s.year || '—'}</td>
            <td style="color:var(--muted);">${escHtml(s.section || '—')}</td>
            <td>
                ${s.cs === 'Cleared'
                    ? `<span style="${badgeStyle('#38a169','rgba(56,161,105,0.15)')}"><i class="fas fa-check-circle me-1"></i>Cleared</span>`
                    : `<span style="${badgeStyle('#f6ad55','rgba(246,173,85,0.15)')}"><i class="fas fa-clock me-1"></i>Pending</span>`}
            </td>
        </tr>`).join('');
}

// ══════════════════════════════════════════════════════════════════════════════
//  INSTRUCTOR TABLE
// ══════════════════════════════════════════════════════════════════════════════
function renderInstructorTable() {
    const panel = document.getElementById('main-panel');

    if (!instructors.length) {
        panel.innerHTML = emptyState('fa-chalkboard-teacher', 'No Instructors Registered Yet',
            'Instructor accounts will appear here once they complete registration.');
        return;
    }

    panel.innerHTML = `
        <div class="panel-hd">
            <span class="panel-hd-title"><i class="fas fa-chalkboard-teacher me-2"></i>Instructors</span>
            <div class="d-flex gap-2">
                <div class="search-wrap">
                    <i class="fas fa-search"></i>
                    <input class="search-input" placeholder="Search name, ID..."
                           oninput="filterTable(this,'inst-table')" />
                </div>
                <button class="btn-blue-sm" onclick="openInstructorAssign()">
                    <i class="fas fa-sitemap me-1"></i>Assign Signatories
                </button>
            </div>
        </div>
        <div class="table-responsive">
            <table class="data-table" id="inst-table">
                <thead>
                    <tr>
                        <th>#</th><th>Name</th><th>Employee ID</th>
                        <th>Date Joined</th><th>Status</th><th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    ${instructors.map((inst, i) => `
                        <tr>
                            <td style="color:var(--muted);">${String(i+1).padStart(2,'0')}</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="user-avatar-sm" style="background:#4299e1;">${escHtml(inst.name.charAt(0))}</div>
                                    <span style="font-weight:600;">${escHtml(inst.name)}</span>
                                </div>
                            </td>
                            <td>
                                ${inst.employeeId && inst.employeeId !== '—'
                                    ? `<span style="${badgeStyle('#4299e1','rgba(66,153,225,0.15)')};">${escHtml(inst.employeeId)}</span>`
                                    : `<span style="color:var(--muted);font-size:12px;">Not assigned</span>`}
                            </td>
                            <td style="color:var(--muted);font-size:12px;">${escHtml(inst.joinedDate ?? '—')}</td>
                            <td><span style="${badgeStyle('#38a169','rgba(56,161,105,0.15)')}">Active</span></td>
                            <td>
                                <button onclick="viewDetail(${inst.id})"
                                    style="${btnStyle('#4299e1')}">
                                    <i class="fas fa-eye me-1"></i>View
                                </button>
                            </td>
                        </tr>`).join('')}
                </tbody>
            </table>
        </div>`;
}

