// ── View modal helpers ────────────────────────────────────────────────────────
function vmLoadingHtml() {
    return `<div style="text-align:center;padding:52px 24px;color:var(--muted);">
        <i class="fas fa-circle-notch fa-spin" style="font-size:28px;color:#4299e1;display:block;margin-bottom:14px;"></i>
        <div style="font-size:13px;">Loading…</div>
    </div>`;
}
function vmErrorHtml(msg) {
    return `<div style="text-align:center;padding:40px 24px;">
        <i class="fas fa-exclamation-triangle" style="font-size:30px;color:#fc8181;display:block;margin-bottom:12px;"></i>
        <div style="font-size:13px;color:var(--muted);">${escHtml(msg)}</div>
    </div>`;
}
function vmProfileCard(fields) {
    return `<div style="background:rgba(66,153,225,0.06);border:1px solid rgba(66,153,225,0.18);
                        border-radius:10px;padding:14px 18px;margin-bottom:20px;">
        <div style="font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;
                    letter-spacing:1px;margin-bottom:12px;">
            <i class="fas fa-id-card me-1" style="color:#4299e1;"></i>Profile
        </div>
        <div class="row g-2">
            ${fields.map(f => `
                <div class="col-md-6 col-12">
                    <div style="font-size:11px;color:var(--muted);margin-bottom:3px;">${f.label}</div>
                    <div style="font-size:13px;font-weight:600;color:var(--text);">
                        ${f.raw ? f.value : escHtml(String(f.value))}
                    </div>
                </div>`).join('')}
        </div>
    </div>`;
}
function vmMiniStat(icon, color, value, label) {
    return `<div class="col-4">
        <div style="background:var(--card);border:1px solid var(--border);border-radius:10px;
                    padding:12px 14px;text-align:center;">
            <i class="fas ${icon}" style="color:${color};font-size:16px;display:block;margin-bottom:6px;"></i>
            <div style="font-size:20px;font-weight:800;color:var(--text);">${value}</div>
            <div style="font-size:11px;color:var(--muted);margin-top:2px;">${label}</div>
        </div>
    </div>`;
}
function vmSectionHeader(icon, color, title) {
    return `<div style="display:inline-flex;align-items:center;gap:6px;
                        font-size:12px;font-weight:700;color:${color};
                        text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;">
        <i class="fas ${icon}"></i>${title}
    </div>`;
}
function vmCountBadge(done, total, color) {
    if (total === 0) return '';
    const pct = Math.round((done / total) * 100);
    return `<span style="float:right;font-size:11px;color:${color};font-weight:700;">
        ${done}/${total} (${pct}%)
    </span>`;
}
function vmProgressBar(done, total, label) {
    if (total === 0) return '';
    const pct      = Math.round((done / total) * 100);
    const barColor = pct === 100 ? '#38a169' : pct >= 50 ? '#4299e1' : '#f6ad55';
    return `<div style="margin-bottom:20px;">
        <div style="display:flex;justify-content:space-between;font-size:11px;
                    color:var(--muted);margin-bottom:6px;">
            <span>${label}</span>
            <span style="font-weight:700;color:${barColor};">${pct}% (${done}/${total})</span>
        </div>
        <div style="background:rgba(255,255,255,0.08);border-radius:20px;height:8px;overflow:hidden;">
            <div style="height:100%;width:${pct}%;background:${barColor};
                        border-radius:20px;transition:width 0.4s ease;"></div>
        </div>
    </div>`;
}

