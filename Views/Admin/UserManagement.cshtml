// ── Instructor view ──────────────────────────────────────────────────────────
async function vmLoadInstructor(id) {
    const inst = instructors.find(i => i.id === id);
    if (inst) {
        document.getElementById('vm-name').textContent        = inst.name;
        document.getElementById('vm-avatar').textContent      = inst.name.charAt(0);
        document.getElementById('vm-avatar').style.background = '#4299e1';
        document.getElementById('vm-role-badge').innerHTML    =
            `<span style="${badgeStyle('#90cdf4','rgba(66,153,225,0.25)')}">
                <i class="fas fa-chalkboard-teacher me-1"></i>Instructor
             </span>`;
    }

    const [detRes, subResRaw] = await Promise.all([
        fetch(`/api/admin/instructors/${id}`),
        fetch(`/api/admin/instructors/${id}/subjects`)
    ]);
    const det  = await detRes.json();
    const subs = Array.isArray(await subResRaw.json().catch(() => [])) ? await subResRaw.json().catch(() => []) : [];

    if (det.error) { document.getElementById('vm-body').innerHTML = vmErrorHtml(det.error); return; }

    const fullName  = [det.firstName, det.lastName].filter(x => x && x !== '—').join(' ');
    const positions = Array.isArray(det.positions) ? det.positions : [];

    document.getElementById('vm-name').textContent   = fullName || '—';
    document.getElementById('vm-avatar').textContent = det.firstName?.charAt(0) ?? '?';

    const totalAppr = subs.reduce((a, s) => a + (s.approved || 0), 0);
    const totalPend = subs.reduce((a, s) => a + (s.pending  || 0), 0);

    const subRows = subs.length
        ? subs.map((s, i) => `
            <tr>
                <td style="color:var(--muted);">${String(i+1).padStart(2,'0')}</td>
                <td><span style="${badgeStyle('#4299e1','rgba(66,153,225,0.13)')}">${escHtml(s.code)}</span></td>
                <td style="color:var(--muted);font-size:12px;">${escHtml(s.desc)}</td>
                <td><span style="${badgeStyle('#68d391','rgba(56,161,105,0.15)')}">${s.approved}</span></td>
                <td><span style="${badgeStyle('#f6e05e','rgba(236,201,75,0.15)')}">${s.pending}</span></td>
            </tr>`).join('')
        : `<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:28px 0;font-size:12px;">
               <i class="fas fa-book" style="display:block;font-size:22px;opacity:0.25;margin-bottom:8px;"></i>
               No subjects assigned yet.</td></tr>`;

    document.getElementById('vm-body').innerHTML = `
        ${vmProfileCard([
            { label:'Employee ID', value: det.employeeId || '—' },
            { label:'Date Joined', value: inst?.joinedDate || '—' },
            { label:'Positions', raw: true, value: positions.length
                ? positions.map(p => `<span style="${badgeStyle('#4299e1','rgba(66,153,225,0.13)')}font-size:11px;">${escHtml(p)}</span>`).join(' ')
                : '<span style="color:var(--muted);font-size:12px;">None assigned</span>' }
        ])}
        <div class="row g-2 mb-4">
            ${vmMiniStat('fa-book','#4299e1', subs.length, 'Subjects')}
            ${vmMiniStat('fa-check-circle','#38a169', totalAppr, 'Approved')}
            ${vmMiniStat('fa-clock','#f6ad55', totalPend, 'Pending')}
        </div>
        <div style="margin-bottom:6px;">
            ${vmSectionHeader('fa-book','#4299e1','Assigned Subjects')}
            ${vmCountBadge(totalAppr, totalAppr + totalPend, '#4299e1')}
        </div>
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr><th>#</th><th>Code</th><th>Description</th><th>Approved</th><th>Pending</th></tr>
                </thead>
                <tbody>${subRows}</tbody>
            </table>
        </div>`;
}

// ── Staff view ───────────────────────────────────────────────────────────────
function vmLoadStaff(id) {
    const staff = staffList.find(s => s.id === id);
    if (!staff) return;

    document.getElementById('vm-name').textContent        = staff.name;
    document.getElementById('vm-avatar').textContent      = staff.name.charAt(0);
    document.getElementById('vm-avatar').style.background = '#0d9488';
    document.getElementById('vm-role-badge').innerHTML    =
        `<span style="${badgeStyle('#81e6d9','rgba(13,148,136,0.25)')}">
            <i class="fas fa-user-tie me-1"></i>Staff
         </span>`;

    const myPositions = staffPositions.filter(p => p.name === staff.name);
    const totalAppr   = myPositions.reduce((a, p) => a + (p.approved || 0), 0);
    const totalPend   = myPositions.reduce((a, p) => a + (p.pending  || 0), 0);

    const posRows = myPositions.length
        ? myPositions.map((p, i) => `
            <tr>
