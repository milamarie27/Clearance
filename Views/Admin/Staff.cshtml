@{
    ViewData["Title"]      = "Staff";
    ViewData["ActivePage"] = "Staff";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-title">Staff</div>

<!-- STATS -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-total-staff">0</div>
                <div class="stat-label">Total Staff</div>
                <div class="stat-sub">All Departments</div>
            </div>
            <div class="stat-icon-wrap si-blue"><i class="fas fa-user-tie"></i></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-total-positions">0</div>
                <div class="stat-label">Assigned Positions</div>
                <div class="stat-sub">Organization Roles</div>
            </div>
            <div class="stat-icon-wrap si-green"><i class="fas fa-id-badge"></i></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card"
             id="assign-toggle-card"
             onclick="toggleAssignPanel()"
             style="cursor:pointer;transition:border-color 0.2s,background 0.2s;"
             title="Click to assign positions">
            <div>
                <div class="stat-label" style="margin-bottom:8px;">Assign Position</div>
                <div style="font-size:11px;color:var(--muted);" id="assign-toggle-hint">Click to manage</div>
            </div>
            <div class="stat-icon-wrap si-teal"><i class="fas fa-user-plus"></i></div>
        </div>
    </div>
</div>

<!-- STAFF LIST -->
<div style="font-size:13px;font-weight:700;color:var(--muted);
            text-transform:uppercase;letter-spacing:1px;margin-bottom:14px;">
    ALL STAFF ACCOUNT LIST
</div>

<div class="panel" id="staff-list-panel">
    <!-- Populated by JS -->
</div>

<!-- ASSIGN POSITIONS SECTION — hidden by default -->
<div class="mt-4 panel" id="assign-panel" style="display:none;">
    <div style="background:var(--tbl-hd-navy);padding:13px 18px;font-size:14px;font-weight:700;
                color:white;display:flex;align-items:center;justify-content:space-between;">
        <span><i class="fas fa-sitemap me-2"></i>Assign Staff Organization Positions</span>
        <button onclick="toggleAssignPanel()"
                style="background:rgba(255,255,255,0.12);border:none;color:white;
                       border-radius:6px;padding:4px 12px;font-size:12px;cursor:pointer;">
            <i class="fas fa-times me-1"></i>Close
        </button>
    </div>

    <div style="padding:20px;">
        <!-- Notice -->
        <div style="background:rgba(66,153,225,0.08);border:1px solid rgba(66,153,225,0.25);
                    border-radius:8px;padding:12px 16px;margin-bottom:20px;font-size:12px;
                    color:var(--muted);display:flex;align-items:flex-start;gap:10px;">
            <i class="fas fa-info-circle" style="color:#4299e1;margin-top:2px;flex-shrink:0;"></i>
            <span>
                Only registered staff can be assigned positions.
                Staff must complete their registration before they can be added here.
                As admin, you are solely responsible for assigning and managing these roles.
            </span>
        </div>

        <!-- Form -->
        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <label class="dark-label">Staff Member</label>
                <select class="dark-input dark-select" id="input-staff-user">
                    <option value="">-- Select Staff --</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="dark-label">Employee ID</label>
                <input class="dark-input" type="text" id="input-staff-eid"
                       placeholder="Auto-filled or enter manually" />
            </div>
            <div class="col-md-4">
                <label class="dark-label">Position / Department</label>
                <input class="dark-input" type="text" id="input-staff-pos"
                       placeholder="e.g. Registrar, Librarian, Cashier" />
            </div>
        </div>

        <button class="btn-blue-sm" onclick="addPosition()">
            <i class="fas fa-plus me-2"></i>Assign Position
        </button>
    </div>

    <div style="background:var(--tbl-hd-navy);padding:11px 18px;
                font-size:13px;font-weight:700;color:white;">
        Assigned Staff Positions
    </div>

    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Employee ID</th>
                    <th>Position</th>
                    <th>Clearance Requests</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="position-tbody"></tbody>
        </table>
        <div id="position-empty"
             style="padding:36px 24px;text-align:center;color:var(--muted);font-size:13px;">
            <i class="fas fa-list-ul"
               style="font-size:24px;opacity:0.3;display:block;margin-bottom:10px;"></i>
            No positions assigned yet. Use the form above to assign one.
        </div>
    </div>
</div>

@section Scripts {
<script>
    let staffList   = [];
    let positions   = [];
    let assignOpen  = false;

    // ══ INIT ══
    async function init() {
        await loadStaff();
        await loadPositions();
    }

    // ══ LOAD STAFF ══
    async function loadStaff() {
        try {
            const res  = await fetch('/api/admin/staff');
            const data = await res.json();
            staffList  = Array.isArray(data) ? data : [];
            if (!Array.isArray(data)) {
                document.getElementById('staff-list-panel').innerHTML =
                    `<div style="padding:24px;color:#fc8181;font-size:13px;">
                        API error: ${JSON.stringify(data)}
                    </div>`;
                return;
            }
        } catch (e) {
            staffList = [];
            document.getElementById('staff-list-panel').innerHTML =
                `<div style="padding:24px;color:#fc8181;font-size:13px;">
                    Fetch error: ${e.message}
                </div>`;
            return;
        }
        renderStaffList();
        populateStaffDropdown();
        document.getElementById('stat-total-staff').textContent = staffList.length;
    }

    function renderStaffList() {
        const panel = document.getElementById('staff-list-panel');

        if (staffList.length === 0) {
            panel.innerHTML = `
                <div style="padding:56px 24px;text-align:center;">
                    <div style="width:72px;height:72px;border-radius:50%;
                                background:rgba(66,153,225,0.10);
                                display:flex;align-items:center;justify-content:center;
                                margin:0 auto 18px;">
                        <i class="fas fa-user-tie"
                           style="font-size:30px;color:#4299e1;opacity:0.7;"></i>
                    </div>
                    <div style="font-size:15px;font-weight:700;color:var(--text);margin-bottom:8px;">
                        No Staff Registered Yet
                    </div>
                    <div style="font-size:13px;color:var(--muted);max-width:420px;
                                margin:0 auto;line-height:1.6;">
                        Staff accounts will appear here once they complete registration.
                        Use the <strong style="color:var(--text);">Assign Position</strong>
                        card above to manage positions.
                    </div>
                </div>`;
            return;
        }

        panel.innerHTML = `
            <div class="panel-hd">
                <span class="panel-hd-title">
                    <i class="fas fa-user-tie me-2"></i>All Staff
                </span>
                <div class="search-wrap">
                    <i class="fas fa-search"></i>
                    <input class="search-input" placeholder="Search name, ID..."
                           oninput="filterTable(this,'staff-table')" />
                </div>
            </div>
            <div class="table-responsive">
                <table class="data-table" id="staff-table">
                    <thead>
                        <tr>
                            <th>#</th><th>Name</th><th>Employee ID</th>
                            <th>Position</th><th>Status</th>
                            <th>Approved</th><th>Pending</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${staffList.map((s, i) => `
                            <tr>
                                <td style="color:var(--muted);">
                                    ${String(i+1).padStart(2,'0')}
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="user-avatar-sm" style="background:#0d9488;">
                                            ${escHtml(s.name.charAt(0))}
                                        </div>
                                        <div>
                                            <div style="font-weight:600;font-size:13px;">
                                                ${escHtml(s.name)}
                                            </div>
                                            <div style="font-size:11px;color:var(--muted);">
                                                ${escHtml(s.email || '')}
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td style="color:var(--muted);">
                                    ${escHtml(s.employeeId || '—')}
                                </td>
                                <td>
                                    ${s.position
                                        ? `<span style="background:rgba(56,178,172,0.15);color:#0d9488;
                                                        padding:3px 10px;border-radius:20px;
                                                        font-size:11px;font-weight:700;">
                                               ${escHtml(s.position)}
                                           </span>`
                                        : `<span style="color:var(--muted);font-size:12px;">—</span>`
                                    }
                                </td>
                                <td><span class="badge-active">Active</span></td>
                                <td>
                                    <span style="background:rgba(56,161,105,0.15);color:#68d391;
                                                 padding:3px 10px;border-radius:20px;
                                                 font-size:11px;font-weight:700;">
                                        ${s.approved ?? 0}
                                    </span>
                                </td>
                                <td>
                                    <span style="background:rgba(236,201,75,0.15);color:#f6e05e;
                                                 padding:3px 10px;border-radius:20px;
                                                 font-size:11px;font-weight:700;">
                                        ${s.pending ?? 0}
                                    </span>
                                </td>
                            </tr>`).join('')}
                    </tbody>
                </table>
            </div>`;
    }

    function populateStaffDropdown() {
        const sel = document.getElementById('input-staff-user');
        sel.innerHTML = '<option value="">-- Select Staff --</option>';
        staffList.forEach(s => {
            const opt       = document.createElement('option');
            opt.value       = s.id;
            opt.textContent = s.name;
            opt.dataset.eid = s.employeeId || '';
            sel.appendChild(opt);
        });

        sel.addEventListener('change', () => {
            const selected = sel.options[sel.selectedIndex];
            document.getElementById('input-staff-eid').value =
                selected.dataset.eid || '';
        });
    }

    // ══ LOAD POSITIONS ══
    async function loadPositions() {
        try {
            const res = await fetch('/api/admin/staff-positions');
            positions = await res.json();
        } catch { positions = []; }
        renderPositions();
        document.getElementById('stat-total-positions').textContent = positions.length;
    }

    function renderPositions() {
        const tbody = document.getElementById('position-tbody');
        const empty = document.getElementById('position-empty');
        tbody.innerHTML = '';

        if (positions.length === 0) { empty.style.display = 'block'; return; }
        empty.style.display = 'none';

        positions.forEach((p, i) => {
            const row = document.createElement('tr');
            row.innerHTML = `
                <td style="color:var(--muted);">${String(i+1).padStart(2,'00')}</td>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <div class="user-avatar-sm" style="background:#0d9488;">
                            ${escHtml(p.name.charAt(0))}
                        </div>
                        ${escHtml(p.name)}
                    </div>
                </td>
                <td style="color:var(--muted);">${escHtml(p.eid || '—')}</td>
                <td>
                    <span style="background:rgba(56,178,172,0.15);color:#0d9488;
                                 padding:3px 10px;border-radius:20px;
                                 font-size:11px;font-weight:700;">
                        ${escHtml(p.pos)}
                    </span>
                </td>
                <td style="text-align:center;">
                    <span style="background:rgba(56,161,105,0.15);color:#68d391;
                                 padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;">
                        ${p.approved ?? 0} Approved
                    </span>
                    &nbsp;
                    <span style="background:rgba(236,201,75,0.15);color:#f6e05e;
                                 padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;">
                        ${p.pending ?? 0} Pending
                    </span>
                </td>
                <td>
                    <button onclick="removePosition(${p.id})"
                        style="background:rgba(229,62,62,0.12);border:none;color:#e53e3e;
                               border-radius:5px;padding:4px 10px;font-size:11px;cursor:pointer;">
                        <i class="fas fa-trash-alt me-1"></i>Remove
                    </button>
                </td>`;
            tbody.appendChild(row);
        });
    }

    // ══ ASSIGN POSITION ══
    async function addPosition() {
        const staffSel = document.getElementById('input-staff-user');
        const eid      = document.getElementById('input-staff-eid').value.trim();
        const pos      = document.getElementById('input-staff-pos').value.trim();
        const staffId  = staffSel.value;
        const name     = staffSel.options[staffSel.selectedIndex]?.textContent ?? '';

        if (!staffId || !pos) {
            alert('Please select a staff member and enter a position.');
            return;
        }

        try {
            const res  = await fetch('/api/admin/staff-positions', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ staffId: parseInt(staffId), eid, pos })
            });
            const data = await res.json();
            if (data.success) {
                positions.push({ id: data.id, name, eid, pos, approved: 0, pending: 0 });
                renderPositions();
                document.getElementById('stat-total-positions').textContent = positions.length;
                staffSel.value = '';
                document.getElementById('input-staff-eid').value = '';
                document.getElementById('input-staff-pos').value = '';
            } else {
                alert(data.error || 'Failed to assign position.');
            }
        } catch (e) { alert('Error: ' + e.message); }
    }

    // ══ REMOVE POSITION ══
    async function removePosition(id) {
        if (!confirm('Remove this position assignment?')) return;
        try {
            await fetch(`/api/admin/staff-positions/${id}`, { method: 'DELETE' });
            positions = positions.filter(p => p.id !== id);
            renderPositions();
            document.getElementById('stat-total-positions').textContent = positions.length;
        } catch { }
    }

    // ══ TOGGLE PANEL ══
    function toggleAssignPanel() {
        assignOpen = !assignOpen;
        const panel = document.getElementById('assign-panel');
        const card  = document.getElementById('assign-toggle-card');
        const hint  = document.getElementById('assign-toggle-hint');
        if (assignOpen) {
            panel.style.display    = 'block';
            card.style.borderColor = 'var(--teal, #0d9488)';
            card.style.background  = 'rgba(13,148,136,0.08)';
            hint.textContent       = 'Click to close';
            setTimeout(() => panel.scrollIntoView({ behavior:'smooth', block:'start' }), 50);
        } else {
            panel.style.display    = 'none';
            card.style.borderColor = '';
            card.style.background  = '';
            hint.textContent       = 'Click to manage';
        }
    }

    function filterTable(input, id) {
        const q = input.value.toLowerCase();
        document.querySelectorAll('#'+id+' tbody tr').forEach(r =>
            r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none'
        );
    }

    function escHtml(str) {
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    init();
</script>
}