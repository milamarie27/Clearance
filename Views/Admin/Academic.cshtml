@{
    ViewData["Title"]      = "Academic Management";
    ViewData["ActivePage"] = "Academic";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <div class="page-title" style="margin-bottom:4px;">Academic Management</div>
        <div style="font-size:13px;color:var(--muted);">Manage Academic Years, Semesters, Courses &amp; Sections</div>
    </div>
</div>

<!-- STAT CARDS -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-total">0</div>
                <div class="stat-label">Total Academic Years</div>
            </div>
            <div class="stat-icon-wrap si-blue"><i class="fas fa-calendar-alt"></i></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-semesters">0</div>
                <div class="stat-label">Total Semesters</div>
            </div>
            <div class="stat-icon-wrap si-green"><i class="fas fa-layer-group"></i></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-courses">0</div>
                <div class="stat-label">Total Courses</div>
            </div>
            <div class="stat-icon-wrap si-purple"><i class="fas fa-graduation-cap"></i></div>
        </div>
    </div>
</div>

<!-- ═══ SIDE-BY-SIDE PANELS ═══ -->
<div class="row g-3">

    <!-- LEFT: ACADEMIC YEARS & SEMESTERS -->
    <div class="col-lg-5">
        <div class="panel" style="height:100%;">
            <div class="panel-hd">
                <span class="panel-hd-title" style="color:#4299e1;font-size:15px;">
                    <i class="fas fa-calendar-alt me-2"></i>Academic Years &amp; Semesters
                </span>
                <button onclick="openModal()"
                    style="background:#4299e1;color:#fff;border:none;border-radius:8px;padding:9px 20px;font-size:13px;font-weight:700;cursor:pointer;">
                   <i class="fas fa-plus me-2"></i>Add
                </button>
                <!--<div class="search-wrap">
                    <i class="fas fa-search"></i>
                    <input type="text" class="search-input" placeholder="Search academic year..."
                        oninput="filterTable(this,'academic-table')" />
                </div>-->
                
            </div>
            <div class="table-responsive">
                <table class="data-table" id="academic-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Academic Year</th>
                            <th>Semester</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="academic-tbody"></tbody>
                </table>
            </div>
            <div id="academic-empty" style="padding:56px 24px;text-align:center;">
                <div style="width:72px;height:72px;border-radius:50%;background:rgba(66,153,225,0.10);display:flex;align-items:center;justify-content:center;margin:0 auto 18px;">
                    <i class="fas fa-calendar-alt" style="font-size:30px;color:#4299e1;opacity:0.7;"></i>
                </div>
                <div style="font-size:15px;font-weight:700;color:var(--text);margin-bottom:8px;">No Academic Years Added Yet</div>
                <div style="font-size:13px;color:var(--muted);max-width:340px;margin:0 auto;line-height:1.6;">
                    Use the <strong style="color:var(--text);">Add Academic Year</strong> button above to get started.
                </div>
            </div>
        </div>
    </div>

    <!-- RIGHT: COURSES / PROGRAMS -->
    <div class="col-lg-7">
        <div class="panel" style="height:100%;">
            <div class="panel-hd">
                <span class="panel-hd-title" style="color:#9f7aea;font-size:15px;">
                    <i class="fas fa-graduation-cap me-2"></i>Courses / Programs
                </span>

                <div class="search-wrap">
                    <i class="fas fa-search"></i>
                    <input type="text" class="search-input" placeholder="Search course..."
                        oninput="filterTable(this,'course-table')" />
                </div>

                <button onclick="openCourseModal()"
                    style="background:#9f7aea;color:#fff;border:none;border-radius:8px;padding:9px 20px;font-size:13px;font-weight:700;cursor:pointer;">
                    <i class="fas fa-plus me-2"></i>Add
                </button>
            </div>
            <div class="table-responsive">
                <table class="data-table" id="course-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Course Code</th>
                            <th>Program Name</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="course-tbody"></tbody>
                </table>
            </div>
            <div id="course-empty" style="padding:56px 24px;text-align:center;">
                <div style="width:72px;height:72px;border-radius:50%;background:rgba(159,122,234,0.10);display:flex;align-items:center;justify-content:center;margin:0 auto 18px;">
                    <i class="fas fa-graduation-cap" style="font-size:30px;color:#9f7aea;opacity:0.7;"></i>
                </div>
                <div style="font-size:15px;font-weight:700;color:var(--text);margin-bottom:8px;">No Courses Added Yet</div>
                <div style="font-size:13px;color:var(--muted);max-width:340px;margin:0 auto;line-height:1.6;">
                    Use the <strong style="color:var(--text);">Add Course</strong> button above to create a program.
                </div>
            </div>
        </div>
    </div>

</div><!-- /row -->


<!-- ════════════════════════════════════════════
     MODALS
════════════════════════════════════════════ -->

<!-- ADD / EDIT ACADEMIC YEAR -->
<div id="academicModal"
    style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:9999;align-items:center;justify-content:center;">
    <div style="background:var(--card);border-radius:14px;padding:30px;width:100%;max-width:460px;border:1px solid var(--border);margin:16px;">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div style="font-size:16px;font-weight:800;color:var(--text);" id="modal-title">
                <i class="fas fa-plus-circle me-2" style="color:#4299e1;"></i>Add Academic Year
            </div>
            <button onclick="closeModal()"
                style="background:none;border:none;font-size:18px;cursor:pointer;color:var(--muted);">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="mb-3">
            <label style="font-size:13px;font-weight:700;color:var(--text);display:block;margin-bottom:5px;">Academic Year</label>
            <input type="text" id="input-ay" placeholder="e.g. 2026-2027"
                style="width:100%;padding:9px 12px;border-radius:8px;border:1px solid var(--border);background:var(--card);color:var(--text);font-size:13px;box-sizing:border-box;" />
        </div>
        <div class="mb-3">
            <label style="font-size:13px;font-weight:700;color:var(--text);display:block;margin-bottom:5px;">Semester</label>
            <select id="input-sem"
                style="width:100%;padding:9px 12px;border-radius:8px;border:1px solid var(--border);background:var(--card);color:var(--text);font-size:13px;box-sizing:border-box;">
                <option value="1st Semester">1st Semester</option>
                <option value="2nd Semester">2nd Semester</option>
                <option value="Summer">Summer</option>
            </select>
        </div>
        <div class="d-flex gap-2">
            <button onclick="saveRow()"
                style="flex:1;background:#4299e1;color:#fff;border:none;border-radius:8px;padding:10px;font-size:13px;font-weight:700;cursor:pointer;">
                <i class="fas fa-save me-1"></i>Save
            </button>
            <button onclick="closeModal()"
                style="flex:1;background:var(--border);color:var(--text);border:none;border-radius:8px;padding:10px;font-size:13px;font-weight:700;cursor:pointer;">
                Cancel
            </button>
        </div>
    </div>
</div>

<!-- ADD / EDIT COURSE -->
<div id="course-modal"
    style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:9999;align-items:center;justify-content:center;">
    <div style="background:var(--card);border:1px solid var(--border);border-radius:14px;padding:28px;width:100%;max-width:440px;margin:16px;">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div style="font-size:15px;font-weight:800;color:var(--text);" id="course-modal-title">
                <i class="fas fa-graduation-cap me-2" style="color:#9f7aea;"></i>Add Course
            </div>
            <button onclick="closeCourseModal()"
                style="background:none;border:none;font-size:18px;cursor:pointer;color:var(--muted);">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="mb-3">
            <label style="font-size:13px;font-weight:700;color:var(--text);display:block;margin-bottom:5px;">Course Code</label>
            <input class="dark-input" id="course-code" placeholder="e.g. BSIT, BIT, BSCS" />
        </div>
        <div class="mb-4">
            <label style="font-size:13px;font-weight:700;color:var(--text);display:block;margin-bottom:5px;">Program Name</label>
            <input class="dark-input" id="course-name" placeholder="e.g. Bachelor of Science in Information Technology" />
        </div>
        <div class="d-flex gap-2">
            <button onclick="saveCourse()"
                style="flex:1;background:#9f7aea;color:#fff;border:none;border-radius:8px;padding:10px;font-size:13px;font-weight:700;cursor:pointer;">
                <i class="fas fa-save me-1"></i>Save Course
            </button>
            <button onclick="closeCourseModal()"
                style="flex:1;background:var(--border);color:var(--text);border:none;border-radius:8px;padding:10px;font-size:13px;font-weight:700;cursor:pointer;">
                Cancel
            </button>
        </div>
    </div>
</div>

<!-- MANAGE SECTIONS -->
<div id="manage-course-modal"
    style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:9999;align-items:center;justify-content:center;">
    <div style="background:var(--card);border:1px solid var(--border);border-radius:14px;width:100%;max-width:560px;margin:16px;max-height:90vh;overflow-y:auto;">
        <div style="background:var(--tbl-hd-navy);padding:14px 20px;border-radius:14px 14px 0 0;
                    display:flex;align-items:center;justify-content:space-between;">
            <div>
                <div style="font-size:14px;font-weight:800;color:white;">
                    <i class="fas fa-cog me-2" style="color:#9f7aea;"></i>
                    Manage Sections — <span id="manage-course-label" style="color:#9f7aea;"></span>
                </div>
                <div id="manage-course-sub" style="font-size:11px;color:rgba(255,255,255,0.5);margin-top:2px;"></div>
            </div>
            <button onclick="closeManageCourseModal()"
                style="background:rgba(255,255,255,0.12);border:none;color:white;border-radius:6px;
                       padding:4px 14px;font-size:12px;cursor:pointer;">
                <i class="fas fa-times me-1"></i>Close
            </button>
        </div>
        <div style="padding:20px;">
            <div style="background:rgba(159,122,234,0.08);border:1px solid rgba(159,122,234,0.25);
                        border-radius:10px;padding:16px;margin-bottom:20px;">
                <div style="font-size:13px;font-weight:700;color:#9f7aea;margin-bottom:14px;">
                    <i class="fas fa-plus-circle me-2"></i>Add Section
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-12">
                        <label class="dark-label">Year Level</label>
                        <select class="dark-input" id="section-year"
                            style="appearance:auto;-webkit-appearance:auto;cursor:pointer;">
                            <option value="" disabled selected>— Select Year Level —</option>
                            <option value="1">1st Year</option>
                            <option value="2">2nd Year</option>
                            <option value="3">3rd Year</option>
                            <option value="4">4th Year</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="dark-label">Section Name</label>
                        <input class="dark-input" id="section-name-input"
                            placeholder="e.g. A, B, C or Morning, Afternoon" />
                    </div>
                </div>
                <div style="font-size:11px;color:var(--muted);margin-bottom:12px;">
                    <i class="fas fa-info-circle me-1" style="color:#9f7aea;"></i>
                    Section will be saved as: <span id="section-name-preview" style="color:#9f7aea;font-weight:700;">—</span>
                </div>
                <button onclick="addSection()"
                    style="background:#9f7aea;color:#fff;border:none;border-radius:8px;
                           padding:9px 20px;font-size:13px;font-weight:700;cursor:pointer;">
                    <i class="fas fa-plus me-2"></i>Add Section
                </button>
            </div>
            <div style="font-size:12px;font-weight:700;color:var(--muted);text-transform:uppercase;
                        letter-spacing:1px;margin-bottom:10px;">Sections in this Course</div>
            <div class="table-responsive">
                <table class="data-table" id="section-table">
                    <thead>
                        <tr><th>#</th><th>Section</th><th>Year Level</th><th>Action</th></tr>
                    </thead>
                    <tbody id="section-tbody"></tbody>
                </table>
            </div>
            <div id="section-empty"
                style="padding:32px 16px;text-align:center;color:var(--muted);font-size:13px;">
                <i class="fas fa-layer-group" style="font-size:24px;opacity:0.3;display:block;margin-bottom:10px;"></i>
                No sections yet. Use the form above to add one.
            </div>
        </div>
    </div>
</div>

<!-- SHARED DELETE CONFIRM -->
<div id="delete-modal"
    style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:99999;align-items:center;justify-content:center;">
    <div style="background:var(--card);border:1px solid var(--border);border-radius:14px;padding:28px;width:100%;max-width:400px;margin:16px;text-align:center;">
        <div style="width:56px;height:56px;border-radius:50%;background:rgba(229,62,62,0.12);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
            <i class="fas fa-trash" style="font-size:22px;color:#fc8181;"></i>
        </div>
        <div style="font-size:15px;font-weight:700;margin-bottom:8px;" id="delete-modal-title">Delete?</div>
        <div style="font-size:13px;color:var(--muted);margin-bottom:24px;" id="delete-modal-body">This cannot be undone.</div>
        <div class="d-flex justify-content-center gap-3">
            <button onclick="closeDeleteModal()"
                style="background:rgba(255,255,255,0.07);border:1px solid var(--border);color:var(--muted);border-radius:8px;padding:8px 22px;font-size:13px;cursor:pointer;">
                Cancel
            </button>
            <button onclick="confirmDelete()"
                style="background:#e53e3e;border:none;color:white;border-radius:8px;padding:8px 22px;font-size:13px;font-weight:700;cursor:pointer;">
                <i class="fas fa-trash me-1"></i>Delete
            </button>
        </div>
    </div>
</div>

@section Scripts {
<script>
// ── State ──────────────────────────────────────────────────────
let academics         = [];
let courses           = [];
let editingIndex      = null;
let courseEditingIdx  = null;
let managingCourseIdx = null;
let deleteTarget      = null;

// ── Bootstrap ─────────────────────────────────────────────────
async function init() {
    await Promise.all([loadAcademics(), loadCourses()]);
}

// ══════════════════════════════════════════════════════════════
//  ACADEMIC YEARS
// ══════════════════════════════════════════════════════════════
async function loadAcademics() {
    try {
        const res = await fetch('/api/admin/academic');
        academics = await res.json();
    } catch { academics = []; }
    renderTable();
}

async function saveRow() {
    const ay  = document.getElementById('input-ay').value.trim();
    const sem = document.getElementById('input-sem').value;
    if (!ay) { alert('Please fill in the Academic Year.'); return; }

    try {
        if (editingIndex !== null) {
            const id = academics[editingIndex].id;
            await fetch(`/api/admin/academic/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ay, sem })
            });
        } else {
            await fetch('/api/admin/academic', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ay, sem })
            });
        }
        await loadAcademics();
    } catch { }
    closeModal();
}

function openModal(idx = null) {
    editingIndex = idx;
    const isEdit = idx !== null;
    document.getElementById('modal-title').innerHTML = isEdit
        ? '<i class="fas fa-edit me-2" style="color:#4299e1;"></i>Edit Academic Year'
        : '<i class="fas fa-plus-circle me-2" style="color:#4299e1;"></i>Add Academic Year';
    document.getElementById('input-ay').value  = isEdit ? academics[idx].ay  : '';
    document.getElementById('input-sem').value = isEdit ? academics[idx].sem : '1st Semester';
    document.getElementById('academicModal').style.display = 'flex';
}
function closeModal() {
    document.getElementById('academicModal').style.display = 'none';
    editingIndex = null;
}

function renderTable() {
    const tbody = document.getElementById('academic-tbody');
    const empty = document.getElementById('academic-empty');
    tbody.innerHTML = '';
    if (!academics.length) { empty.style.display = 'block'; updateStats(); return; }
    empty.style.display = 'none';
    academics.forEach((a, i) => {
        tbody.innerHTML += `
            <tr>
                <td>${i + 1}</td>
                <td>${escHtml(a.ay)}</td>
                <td>${escHtml(a.sem)}</td>
                <td>
                    <button onclick="openDeleteModal('academic',${i})"
                        style="background:rgba(229,62,62,0.12);color:#fc8181;border:none;border-radius:6px;padding:5px 12px;font-size:12px;cursor:pointer;">
                        <i class="fas fa-trash"></i>
                    </button>
                </td>
            </tr>`;
    });
    updateStats();
}

// ══════════════════════════════════════════════════════════════
//  COURSES
// ══════════════════════════════════════════════════════════════
async function loadCourses() {
    try {
        const res = await fetch('/api/admin/courses');
        courses = await res.json();
    } catch { courses = []; }
    renderCourses();
}

function renderCourses() {
    const tbody = document.getElementById('course-tbody');
    const empty = document.getElementById('course-empty');
    tbody.innerHTML = '';
    if (!courses.length) { empty.style.display = 'block'; updateStats(); return; }
    empty.style.display = 'none';
    courses.forEach((c, i) => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td style="color:var(--muted);">${String(i + 1).padStart(2, '0')}</td>
            <td>
                <span style="background:rgba(159,122,234,0.15);color:#9f7aea;padding:3px 12px;border-radius:20px;font-size:12px;font-weight:700;">
                    ${escHtml(c.code)}
                </span>
            </td>
            <td style="font-weight:600;">${escHtml(c.name)}</td>
            <td>
                <div class="d-flex gap-2">
                    <button onclick="openEditCourse(${i})"
                        style="background:rgba(66,153,225,0.12);color:#4299e1;border:none;border-radius:6px;padding:4px 12px;font-size:12px;font-weight:600;cursor:pointer;">
                        <i class="fas fa-edit me-1"></i>Edit
                    </button>
                    <button onclick="openManageCourse(${i})"
                        style="background:rgba(159,122,234,0.12);color:#9f7aea;border:none;border-radius:6px;padding:4px 12px;font-size:12px;font-weight:600;cursor:pointer;">
                        <i class="fas fa-cog me-1"></i>Sections
                    </button>
                    <button onclick="openDeleteModal('course',${i})"
                        style="background:rgba(229,62,62,0.12);color:#fc8181;border:none;border-radius:6px;padding:4px 12px;font-size:12px;font-weight:600;cursor:pointer;">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            </td>`;
        tbody.appendChild(tr);
    });
    updateStats();
}

function openCourseModal() {
    courseEditingIdx = null;
    document.getElementById('course-modal-title').innerHTML =
        '<i class="fas fa-graduation-cap me-2" style="color:#9f7aea;"></i>Add Course';
    document.getElementById('course-code').value = '';
    document.getElementById('course-name').value = '';
    document.getElementById('course-modal').style.display = 'flex';
}
function openEditCourse(idx) {
    courseEditingIdx = idx;
    const c = courses[idx];
    document.getElementById('course-modal-title').innerHTML =
        '<i class="fas fa-edit me-2" style="color:#9f7aea;"></i>Edit Course';
    document.getElementById('course-code').value = c.code;
    document.getElementById('course-name').value = c.name;
    document.getElementById('course-modal').style.display = 'flex';
}
function closeCourseModal() {
    document.getElementById('course-modal').style.display = 'none';
    courseEditingIdx = null;
}

async function saveCourse() {
    const code = document.getElementById('course-code').value.trim();
    const name = document.getElementById('course-name').value.trim();
    if (!code || !name) { alert('Please fill in both Course Code and Program Name.'); return; }

    if (courseEditingIdx !== null) {
        const id  = courses[courseEditingIdx].id;
        const res = await fetch(`/api/admin/courses/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ code, name })
        });
        const data = await res.json();
        if (data.success) { courses[courseEditingIdx].code = code; courses[courseEditingIdx].name = name; }
        else { alert('Error: ' + (data.error || 'Could not update course')); return; }
    } else {
        const res  = await fetch('/api/admin/courses', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ code, name })
        });
        const data = await res.json();
        if (data.success) courses.push({ id: data.id, code, name });
        else { alert('Error: ' + (data.error || 'Could not save course')); return; }
    }
    closeCourseModal();
    renderCourses();
}

// ══════════════════════════════════════════════════════════════
//  SECTIONS
// ══════════════════════════════════════════════════════════════
function openManageCourse(idx) {
    managingCourseIdx = idx;
    const c = courses[idx];
    document.getElementById('manage-course-label').textContent  = c.code;
    document.getElementById('manage-course-sub').textContent    = c.name;
    document.getElementById('section-year').value               = '';
    document.getElementById('section-name-input').value         = '';
    document.getElementById('section-name-preview').textContent = '—';

    const nameInput = document.getElementById('section-name-input');
    const preview   = document.getElementById('section-name-preview');
    document.getElementById('section-year').onchange = () => { preview.textContent = nameInput.value.trim() || '—'; };
    nameInput.oninput = () => { preview.textContent = nameInput.value.trim() || '—'; };

    document.getElementById('manage-course-modal').style.display = 'flex';
    loadSections(c.id);
}
function closeManageCourseModal() {
    document.getElementById('manage-course-modal').style.display = 'none';
    managingCourseIdx = null;
}

async function loadSections(courseId) {
    const tbody = document.getElementById('section-tbody');
    const empty = document.getElementById('section-empty');
    tbody.innerHTML = `<tr><td colspan="4" style="text-align:center;color:var(--muted);padding:20px;font-size:12px;">
        <i class="fas fa-spinner fa-spin me-2"></i>Loading...</td></tr>`;
    empty.style.display = 'none';
    try {
        const res  = await fetch(`/api/admin/sections?courseId=${courseId}`);
        const data = await res.json();
        renderSections(Array.isArray(data) ? data : []);
    } catch {
        tbody.innerHTML = '';
        empty.style.display = 'block';
    }
}

function renderSections(list) {
    const tbody = document.getElementById('section-tbody');
    const empty = document.getElementById('section-empty');
    tbody.innerHTML = '';
    if (!list.length) { empty.style.display = 'block'; return; }
    empty.style.display = 'none';
    list.forEach((s, i) => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td style="color:var(--muted);">${String(i + 1).padStart(2, '0')}</td>
            <td style="font-weight:700;color:var(--text);">${escHtml(s.name)}</td>
            <td style="color:var(--muted);">Year ${escHtml(String(s.year ?? '—'))}</td>
            <td>
                <button onclick="deleteSection(${s.id})"
                    style="background:rgba(229,62,62,0.12);border:none;color:#e53e3e;
                           border-radius:6px;padding:4px 10px;font-size:11px;cursor:pointer;font-weight:600;">
                    <i class="fas fa-trash-alt me-1"></i>Remove
                </button>
            </td>`;
        tbody.appendChild(tr);
    });
}

async function addSection() {
    const year    = document.getElementById('section-year').value;
    const nameVal = document.getElementById('section-name-input').value.trim();
    if (!year)    { alert('Please select a year level.'); return; }
    if (!nameVal) { alert('Please enter a section name.'); return; }
    const c = courses[managingCourseIdx];
    try {
        const res  = await fetch('/api/admin/sections', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ courseId: c.id, name: nameVal, year })
        });
        const data = await res.json();
        if (data.success) {
            document.getElementById('section-year').value               = '';
            document.getElementById('section-name-input').value         = '';
            document.getElementById('section-name-preview').textContent = '—';
            loadSections(c.id);
        } else { alert('Error: ' + (data.error ?? 'Unknown error')); }
    } catch (e) { alert('Error: ' + e.message); }
}

async function deleteSection(id) {
    if (!confirm('Remove this section?')) return;
    try {
        await fetch(`/api/admin/sections/${id}`, { method: 'DELETE' });
        loadSections(courses[managingCourseIdx].id);
    } catch (e) { alert('Error: ' + e.message); }
}

// ══════════════════════════════════════════════════════════════
//  SHARED DELETE MODAL
// ══════════════════════════════════════════════════════════════
function openDeleteModal(type, idx) {
    deleteTarget = { type, idx };
    const titles = { academic: 'Delete Academic Record?', course: 'Delete Course?' };
    const bodies = {
        academic: 'This action cannot be undone. The record will be permanently removed.',
        course:   'This course and all its sections will be permanently removed. This cannot be undone.'
    };
    document.getElementById('delete-modal-title').textContent = titles[type];
    document.getElementById('delete-modal-body').textContent  = bodies[type];
    document.getElementById('delete-modal').style.display = 'flex';
}
function closeDeleteModal() {
    document.getElementById('delete-modal').style.display = 'none';
    deleteTarget = null;
}

async function confirmDelete() {
    const { type, idx } = deleteTarget;
    if (type === 'academic') {
        const id = academics[idx].id;
        try {
            await fetch(`/api/admin/academic/${id}`, { method: 'DELETE' });
            await loadAcademics();
        } catch { }
    } else if (type === 'course') {
        const id   = courses[idx].id;
        const res  = await fetch(`/api/admin/courses/${id}`, { method: 'DELETE' });
        const data = await res.json();
        if (data.success) { courses.splice(idx, 1); renderCourses(); }
        else { alert('Error: ' + (data.error || 'Could not delete course')); }
    }
    closeDeleteModal();
}

// ══════════════════════════════════════════════════════════════
//  STATS & HELPERS
// ══════════════════════════════════════════════════════════════
function updateStats() {
    document.getElementById('stat-total').textContent     = new Set(academics.map(a => a.ay)).size;
    document.getElementById('stat-semesters').textContent = academics.length;
    document.getElementById('stat-courses').textContent   = courses.length;
}

function filterTable(input, tableId) {
    const q = input.value.toLowerCase();
    document.querySelectorAll(`#${tableId} tbody tr`).forEach(r => {
        r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
}

function escHtml(str) {
    return String(str)
        .replace(/&/g,'&amp;').replace(/</g,'&lt;')
        .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// Backdrop click to close
['academicModal','course-modal','manage-course-modal','delete-modal'].forEach(id => {
    document.getElementById(id).addEventListener('click', function(e) {
        if (e.target === this) this.style.display = 'none';
    });
});

init();
</script>
}